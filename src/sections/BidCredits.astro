---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Verification-credit purchase (self-serve 입찰검증). Session-authed: reads the
// miriboa_session from localStorage, bootstraps packs+orderIds from
// site.creditsCheckoutEndpoint, and starts a one-time Toss payment
// (requestPayment, ANONYMOUS customer). Success/fail land on
// /bid-verification/credits/{success,fail}, which POST confirm.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.verifyCredits;
const endpoint = site.creditsCheckoutEndpoint;
const successPath = localizePath('/bid-verification/credits/success', lang);
const failPath = localizePath('/bid-verification/credits/fail', lang);
const accountPath = localizePath('/account', lang) + '?return=' + encodeURIComponent(localizePath('/bid-verification/credits', lang));
---

<Base title={c.title} description={c.lede} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
  </section>

  <section class="section wrap">
    <div class="panel" data-credits
         data-endpoint={endpoint || undefined}
         data-success-path={successPath} data-fail-path={failPath}
         data-starting={c.starting} data-error={c.error}
         data-order-name-prefix={lang === 'ko' ? '미리보아 입찰검증 크레딧 ' : 'Miriboa verification credits × '}>

      <div class="beta-note" role="note">
        <strong>{c.beta.title}</strong>
        <p>{c.beta.body}</p>
      </div>

      <p class="loading" data-loading>…</p>

      <div class="login" hidden data-login-view>
        <h2>{c.loginTitle}</h2>
        <p>{c.loginBody}</p>
        <a class="btn btn-primary" href={accountPath}>{c.loginCta} <span class="arrow">&rarr;</span></a>
      </div>

      <div hidden data-shop-view
           data-reason-labels={JSON.stringify(c.reasonLabels)} data-valid-until={c.validUntil}>
        <p class="balance">{c.balanceLabel}: <strong data-balance></strong> {c.creditUnit}</p>
        <div class="packs" data-packs></div>
        <p class="locked" hidden data-locked>{c.lockedNote}</p>
        <p class="note eyebrow">{c.afterNote}</p>
        <p class="note eyebrow">{c.refundNote} · <a class="terms" href={localizePath('/legal/terms', lang)}>{c.termsLabel}</a></p>
        <div class="history" hidden data-history>
          <h2>{c.historyHeading}</h2>
          <ul data-ledger></ul>
        </div>
      </div>

      <p class="verr" hidden data-error-msg>{c.error}</p>
    </div>
  </section>
</Base>

<script is:inline src="https://js.tosspayments.com/v2/standard"></script>
<script>
  const root = document.querySelector<HTMLElement>('[data-credits]');
  const endpoint = root?.dataset.endpoint || '';
  const fmt = (n: number) => '₩' + n.toLocaleString();
  const show = (sel: string, on = true) => {
    const el = root?.querySelector<HTMLElement>(`[data-${sel}]`);
    if (el) el.hidden = !on;
  };

  async function boot() {
    if (!root) return;
    const session = localStorage.getItem('miriboa_session') || '';
    if (!endpoint || !session) { show('loading', false); show('login-view', true); return; }
    let res: Response;
    try {
      res = await fetch(endpoint, { headers: { Authorization: 'Bearer ' + session } });
    } catch { show('loading', false); show('error-msg', true); return; }
    if (res.status === 401) { show('loading', false); show('login-view', true); return; }
    const data = await res.json().catch(() => null);
    if (!res.ok || !data || !data.ok) { show('loading', false); show('error-msg', true); return; }
    show('loading', false);
    const bal = root.querySelector<HTMLElement>('[data-balance]');
    if (bal) bal.textContent = String(data.balance);
    const wrap = root.querySelector<HTMLElement>('[data-packs]');
    if (wrap) {
      for (const p of data.packs) {
        const per = Math.round(p.amount / p.n);
        const card = document.createElement('div');
        card.className = 'pack';
        card.innerHTML = `<div class="pack-n">${p.n}</div>
          <div class="pack-price">${fmt(p.amount)} <span class="vat"></span></div>
          <div class="pack-per">${fmt(per)} <span class="pernote"></span></div>
          <button class="btn btn-primary" type="button"></button>`;
        card.querySelector('.vat')!.textContent = (document.documentElement.lang === 'ko' ? '부가세 포함' : 'VAT included');
        card.querySelector('.pernote')!.textContent = (document.documentElement.lang === 'ko' ? '/ 개' : '/ credit');
        const btn = card.querySelector<HTMLButtonElement>('button')!;
        btn.textContent = (document.documentElement.lang === 'ko' ? '구매하기' : 'Buy') + ' →';
        if (data.locked) { btn.disabled = true; }
        else btn.addEventListener('click', () => buy(data.clientKey, p, data.email));
        wrap.appendChild(card);
      }
    }
    if (data.locked) show('locked', true);
    // 구매·사용 내역 (원장 최근 10건)
    const shop = root.querySelector<HTMLElement>('[data-shop-view]');
    const ledger = root.querySelector<HTMLElement>('[data-ledger]');
    if (ledger && shop && Array.isArray(data.ledger) && data.ledger.length) {
      let labels: Record<string, string> = {};
      try { labels = JSON.parse(shop.dataset.reasonLabels || '{}'); } catch {}
      for (const e of data.ledger) {
        const li = document.createElement('li');
        const sign = e.delta > 0 ? '+' + e.delta : String(e.delta);
        const parts = [
          String(e.created_at || '').slice(0, 10),
          labels[e.reason] || e.reason,
          sign,
        ];
        if (e.amount_krw > 0) parts.push(fmt(e.amount_krw));
        if (e.delta > 0 && e.expires_at) parts.push(`${shop.dataset.validUntil} ${String(e.expires_at).slice(0, 10)}`);
        li.innerHTML = `<span class="h-date"></span><span class="h-reason"></span><span class="h-delta ${e.delta > 0 ? 'pos' : 'neg'}"></span><span class="h-extra"></span>`;
        const cells = li.querySelectorAll('span');
        cells[0].textContent = parts[0]; cells[1].textContent = parts[1];
        cells[2].textContent = parts[2]; cells[3].textContent = parts.slice(3).join(' · ');
        ledger.appendChild(li);
      }
      show('history', true);
    }
    show('shop-view', true);
  }

  async function buy(clientKey: string, pack: { n: number; amount: number; orderId: string }, email: string) {
    const Toss = (window as any).TossPayments;
    if (!Toss || !clientKey) { show('error-msg', true); return; }
    try {
      const payment = Toss(clientKey).payment({ customerKey: Toss.ANONYMOUS });
      await payment.requestPayment({
        method: 'CARD',
        amount: { currency: 'KRW', value: pack.amount },
        orderId: pack.orderId,
        orderName: `${root?.dataset.orderNamePrefix || ''}${pack.n}`,
        successUrl: `${location.origin}${root?.dataset.successPath}`,
        failUrl: `${location.origin}${root?.dataset.failPath}`,
        customerEmail: email || undefined,
      });
    } catch {
      // user closed the Toss window — nothing charged; stay on the page
    }
  }

  boot();
</script>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  [hidden] { display: none !important; }
  .panel { max-width: 52rem; margin-inline: auto; display: flex; flex-direction: column; gap: 1rem; }
  .beta-note { border: 1px solid #9a6700; border-radius: var(--radius); background: color-mix(in srgb, #9a6700 7%, var(--color-vellum)); padding: 0.9rem 1.1rem; }
  .beta-note strong { color: #9a6700; font-size: var(--step--1); }
  .beta-note p { font-size: var(--step--1); color: var(--color-slate); margin: 0.3rem 0 0; }
  .loading { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .login { display: flex; flex-direction: column; gap: 0.75rem; align-items: flex-start; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .login h2 { font-size: var(--step-1); }
  .balance { font-size: var(--step-0); color: var(--color-ink); }
  .packs { display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 0.5rem + 2vw, 1.5rem); }
  .packs :global(.pack) { display: flex; flex-direction: column; gap: 0.5rem; padding: 1.5rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); align-items: flex-start; }
  .packs :global(.pack-n) { font-size: var(--step-3); font-weight: 700; color: var(--color-ink); }
  .packs :global(.pack-n)::after { content: ' credits'; font-size: var(--step--1); font-weight: 400; color: var(--color-slate); }
  :global(html[lang="ko"]) .packs :global(.pack-n)::after { content: ' 개'; }
  .packs :global(.pack-price) { font-size: var(--step-1); font-weight: 700; color: var(--color-ink); }
  .packs :global(.pack-price .vat) { font-family: var(--font-mono); font-size: var(--step--2); font-weight: 400; color: var(--color-slate); border: 1px solid var(--hairline); border-radius: 999px; padding: 0.1rem 0.5rem; margin-left: 0.25rem; }
  .packs :global(.pack-per) { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .packs :global(.btn) { margin-top: auto; }
  .locked { border: 1px solid #9a6700; border-radius: var(--radius); background: color-mix(in srgb, #9a6700 7%, var(--color-vellum)); padding: 0.9rem 1.1rem; font-size: var(--step--1); color: var(--color-slate); }
  .note { margin: 0; }
  .history { margin-top: 0.75rem; }
  .history h2 { font-size: var(--step-0); font-family: var(--font-mono); color: var(--color-slate); margin-bottom: 0.6rem; }
  .history ul { list-style: none; margin: 0; padding: 0; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .history :global(li) { display: grid; grid-template-columns: 6.5rem 1fr auto auto; gap: 0.75rem; padding: 0.55rem 1rem; font-size: var(--step--1); color: var(--color-ink); align-items: baseline; }
  .history :global(li + li) { border-top: 1px dashed var(--hairline); }
  .history :global(.h-date), .history :global(.h-extra) { font-family: var(--font-mono); font-size: var(--step--2); color: var(--color-slate); }
  .history :global(.h-delta) { font-weight: 700; }
  .history :global(.h-delta.pos) { color: #1a7f37; }
  .history :global(.h-delta.neg) { color: #b3261e; }
  .terms { color: var(--color-ink); text-decoration: underline; text-underline-offset: 3px; }
  .verr { color: #b3261e; font-size: var(--step--1); }
  @media (max-width: 760px) { .packs { grid-template-columns: 1fr; } }
</style>
