---
import Base from '../layouts/Base.astro';
import StrategyLadder from '../components/StrategyLadder.astro';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.how;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
  </section>

  <section class="section wrap steps-section">
    <ol class="steps">
      {c.steps.map((s, i) => (
        <li class="step">
          <span class="n eyebrow">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{s.name}</h3>
            <p>{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section wrap ladder-section">
    <div class="ladder-copy">
      <span class="eyebrow">{c.ladderEyebrow}</span>
      <h2>{c.ladderH2}</h2>
      <p class="lede">{c.ladderLede}</p>
    </div>
    <StrategyLadder lang={lang} />
  </section>

  <section class="cta-band band-ink">
    <div class="wrap cta-inner">
      <h2>{c.closingH2}</h2>
      <a class="btn btn-primary" href={localizePath('/contact', lang)}>{tr.common.requestDemo} <span class="arrow">&rarr;</span></a>
    </div>
  </section>
</Base>

<style>
  .head { padding-bottom: 0; display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .steps { list-style: none; margin: 0; padding: 0; display: grid; gap: 1px; background: var(--hairline); border: 1px solid var(--hairline); border-radius: var(--radius); overflow: hidden; }
  .step { background: var(--color-vellum); display: grid; grid-template-columns: 4rem 1fr; gap: 1rem; padding: 1.75rem; }
  .step .n { padding-top: 0.2rem; }
  .step h3 { margin-bottom: 0.4rem; }
  .ladder-section { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .ladder-copy { display: flex; flex-direction: column; gap: 1rem; }
  .cta-band { padding-block: var(--section-y); }
  .cta-inner { display: flex; justify-content: space-between; align-items: center; gap: 2rem; flex-wrap: wrap; }
  @media (max-width: 760px) {
    .ladder-section { grid-template-columns: 1fr; }
    .step { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>
