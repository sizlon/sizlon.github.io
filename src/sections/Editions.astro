---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.editions;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
    <a class="product-link" href={localizePath('/web-crawling', lang)}>{c.productLink} <span class="arrow">&rarr;</span></a>
  </section>

  <section class="section wrap">
    <aside class="common">
      <div class="common-head">
        <p class="common-title">{c.commonTitle}</p>
        <p class="common-note">{c.commonNote}</p>
      </div>
      <ul class="common-rows">
        {c.commonRows.map((r) => <li>{r}</li>)}
      </ul>
    </aside>
    <div class="grid">
      {c.list.map((e) => (
        <article class:list={['edition', { featured: 'featured' in e && e.featured }]}>
          <header>
            <h3>{e.name}</h3>
            <p class="target">{e.target}</p>
          </header>
          {'includes' in e && <p class="includes">{e.includes}</p>}
          <ul class="rows">
            {e.rows.map((r) => <li>{r}</li>)}
          </ul>
          <div class="price">
            <span class="amount">{c.priceAmount}</span>
            <span class="period">{c.pricePeriod}</span>
          </div>
          <a class="btn btn-primary" href={`${localizePath('/contact', lang)}?topic=pricing`}>{c.requestPricing} <span class="arrow">&rarr;</span></a>
        </article>
      ))}
    </div>
    <aside class="managed">
      <div class="managed-copy">
        <span class="eyebrow">{c.managedEyebrow}</span>
        <h2>{c.managedTitle}</h2>
        <p>{c.managedBody}</p>
      </div>
      <a class="btn btn-ghost" href={`${localizePath('/contact', lang)}?topic=managed`}>{c.managedCta} <span class="arrow">&rarr;</span></a>
    </aside>
    <p class="anchor eyebrow">{c.anchor}</p>
  </section>
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .edition { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .edition.featured { border-color: var(--color-recovered); box-shadow: 0 0 0 1px var(--color-recovered); }
  .target { color: var(--color-slate); font-family: var(--font-mono); font-size: var(--step--1); }
  .includes { font-family: var(--font-mono); font-size: var(--step--1); font-weight: 600; color: var(--color-recovered); margin-bottom: -0.25rem; }
  .rows { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .rows li { padding-left: 1.25rem; position: relative; }
  .rows li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 8px; height: 8px; border-radius: 50%; background: var(--color-recovered); }
  .price { margin-top: auto; display: flex; flex-direction: column; gap: 0.1rem; }
  .amount { font-family: var(--font-display); font-size: var(--step-2); font-weight: 600; }
  .period { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .product-link { font-weight: 600; font-size: var(--step--1); text-decoration: none; color: var(--color-ink); }
  .product-link .arrow { display: inline-block; transition: transform 0.15s ease; color: var(--color-recovered); }
  .product-link:hover .arrow { transform: translateX(3px); }
  .common { background: color-mix(in srgb, var(--color-recovered) 7%, var(--color-vellum)); border: 1px solid color-mix(in srgb, var(--color-recovered) 35%, transparent); border-radius: var(--radius); padding: 1.25rem 1.75rem; margin-bottom: 1.25rem; display: flex; flex-wrap: wrap; gap: 1rem 2.5rem; align-items: baseline; }
  .common-head { display: flex; flex-direction: column; gap: 0.15rem; min-width: 220px; }
  .common-title { font-family: var(--font-mono); font-size: var(--step--1); font-weight: 600; color: var(--color-recovered); }
  .common-note { font-size: var(--step--1); color: var(--color-slate); }
  .common-rows { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; }
  .common-rows li { padding-left: 1.25rem; position: relative; font-size: var(--step--1); }
  .common-rows li::before { content: ''; position: absolute; left: 0; top: 0.5em; width: 8px; height: 8px; border-radius: 50%; background: var(--color-recovered); }
  .managed {
    margin-top: 1.25rem;
    padding: 1.75rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--color-vellum);
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem 2.5rem;
    align-items: center;
    justify-content: space-between;
  }
  .managed-copy { display: flex; flex-direction: column; gap: 0.5rem; max-width: var(--measure); }
  .managed-copy h2 { font-size: var(--step-1); }
  .anchor { margin-top: 1.5rem; text-align: center; }
</style>
