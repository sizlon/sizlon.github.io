---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.editions;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
  </section>

  <section class="section wrap">
    <div class="grid">
      {c.list.map((e) => (
        <article class:list={['edition', { featured: 'featured' in e && e.featured }]}>
          <header>
            <h3>{e.name}</h3>
            <p class="target">{e.target}</p>
          </header>
          <ul class="rows">
            {e.rows.map((r) => <li>{r}</li>)}
          </ul>
          <div class="price">
            <span class="amount">{c.priceAmount}</span>
            <span class="period">{c.pricePeriod}</span>
          </div>
          <a class="btn btn-primary" href={localizePath('/contact', lang)}>{c.requestPricing} <span class="arrow">&rarr;</span></a>
        </article>
      ))}
    </div>
    <p class="anchor eyebrow">{c.anchor}</p>
  </section>
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; }
  .edition { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .edition.featured { border-color: var(--color-recovered); box-shadow: 0 0 0 1px var(--color-recovered); }
  .target { color: var(--color-slate); font-family: var(--font-mono); font-size: var(--step--1); }
  .rows { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .rows li { padding-left: 1.25rem; position: relative; }
  .rows li::before { content: ''; position: absolute; left: 0; top: 0.6em; width: 8px; height: 8px; border-radius: 50%; background: var(--color-recovered); }
  .price { margin-top: auto; display: flex; flex-direction: column; gap: 0.1rem; }
  .amount { font-family: var(--font-display); font-size: var(--step-2); font-weight: 600; }
  .period { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .anchor { margin-top: 1.5rem; text-align: center; }
</style>
