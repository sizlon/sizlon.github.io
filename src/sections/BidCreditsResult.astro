---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Toss one-time payment redirect landing for credit purchases. mode='success':
// the redirect carries ?paymentKey&orderId&amount — POST them (session-authed)
// to confirm; the server re-checks the amount against the pack encoded in the
// orderId. mode='fail': nothing was charged.

interface Props { lang: Lang; mode: 'success' | 'fail' }
const { lang, mode } = Astro.props;
const tr = t(lang);
const c = tr.verifyCredits;
const confirmEndpoint = site.creditsConfirmEndpoint;
const creditsPath = localizePath('/bid-verification/credits', lang);
const verifyPath = localizePath('/verify-request', lang);
---

<Base title={mode === 'success' ? c.successTitle : c.failTitle} description={c.lede} lang={lang}>
  <section class="section wrap narrow">
    {mode === 'success' ? (
      <div class="result" data-credits-success
           data-confirm-endpoint={confirmEndpoint || undefined}
           data-balance-label={c.balanceLabel} data-unit={c.creditUnit}>
        <span class="eyebrow">{c.eyebrow}</span>
        <p class="pending" data-pending>…</p>
        <div class="done" hidden data-done>
          <h1>{c.successTitle}</h1>
          <p>{c.successBody}</p>
          <p class="balance" data-balance-line></p>
          <p><a class="btn btn-primary" href={verifyPath}>{c.successCta} <span class="arrow">&rarr;</span></a></p>
        </div>
        <p class="verr" hidden data-error>{c.error}</p>
      </div>
    ) : (
      <div class="result">
        <span class="eyebrow">{c.eyebrow}</span>
        <h1>{c.failTitle}</h1>
        <p>{c.failBody}</p>
        <p><a class="btn btn-primary" href={creditsPath}>{c.retry} <span class="arrow">&rarr;</span></a></p>
      </div>
    )}
  </section>
</Base>

<script>
  const root = document.querySelector<HTMLElement>('[data-credits-success]');
  if (root) {
    const q = new URLSearchParams(location.search);
    const endpoint = root.dataset.confirmEndpoint || '';
    const session = localStorage.getItem('miriboa_session') || '';
    const done = (ok: boolean) => {
      root.querySelector<HTMLElement>('[data-pending]')!.hidden = true;
      root.querySelector<HTMLElement>(ok ? '[data-done]' : '[data-error]')!.hidden = false;
    };
    (async () => {
      const pk = q.get('paymentKey') || '', oid = q.get('orderId') || '', amt = q.get('amount') || '';
      if (!pk || !oid || !amt || !endpoint || !session) { done(false); return; }
      try {
        const fd = new FormData();
        fd.append('paymentKey', pk); fd.append('orderId', oid); fd.append('amount', amt);
        const res = await fetch(endpoint, { method: 'POST', body: fd, headers: { Authorization: 'Bearer ' + session } });
        const data = await res.json().catch(() => null);
        if (res.ok && data && data.ok) {
          const line = root.querySelector<HTMLElement>('[data-balance-line]');
          if (line) line.textContent = `${root.dataset.balanceLabel}: ${data.balance} ${root.dataset.unit}`;
          done(true);
        } else { done(false); }
      } catch { done(false); }
    })();
  }
</script>

<style>
  .narrow { max-width: 52ch; }
  [hidden] { display: none !important; }
  .result { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .pending { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .done { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .balance { font-weight: 600; color: var(--color-ink); }
  .verr { color: #b3261e; font-size: var(--step--1); }
</style>
