---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// The form fetch-POSTs to the site backend (site.contactFormEndpoint →
// svc.sizlon.io, source: sizlon-platform repo `site-backend/`), which verifies
// Turnstile server-side, stores the submission, and emails contactEmail.
// `company_url` is a honeypot. While the endpoint is empty the submit no-ops
// and the mailto fallback carries.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.contact;
const endpoint = site.contactFormEndpoint;
const turnstileKey = site.turnstileSiteKey;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="section wrap grid">
    <div class="copy">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
      <p class="alt">{c.applyPrefix} <a href={localizePath('/verify-request', lang)}>{c.applyLink} &rarr;</a></p>
      <p class="alt">{c.altPrefix} <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p>
    </div>

    <div class="formcol">
      <form
        class="form"
        method="post"
        action={endpoint || undefined}
        data-contact-form
        data-sending={c.sending}
        data-turnstile={turnstileKey ? 'on' : undefined}
      >
        <label>
          <span>{c.labels.name}</span>
          <input type="text" name="name" autocomplete="name" maxlength="120" required />
        </label>
        <label>
          <span>{c.labels.email}</span>
          <input type="email" name="email" autocomplete="email" maxlength="180" required />
        </label>
        <label>
          <span>{c.labels.company}</span>
          <input type="text" name="company" autocomplete="organization" maxlength="160" />
        </label>
        <label>
          <span>{c.labels.topic}</span>
          <select name="topic">
            <option value="">{c.topicPlaceholder}</option>
            {Object.entries(c.topics).map(([key, label]) => (
              <option value={key}>{label}</option>
            ))}
          </select>
        </label>
        <label>
          <span>{c.labels.message}</span>
          <textarea name="message" rows="4" maxlength="4000" required></textarea>
        </label>

        <div class="hp" aria-hidden="true">
          <label>Company URL
            <input type="text" name="company_url" tabindex="-1" autocomplete="off" />
          </label>
        </div>
        <input type="hidden" name="elapsed" value="" data-elapsed />

        {turnstileKey && <div class="cf-turnstile" data-sitekey={turnstileKey}></div>}
        {turnstileKey && <p class="verr" hidden data-verify-error>{c.verifyNeeded}</p>}
        <p class="verr" hidden data-send-error>{c.sendError}</p>

        <button class="btn btn-primary" type="submit">{c.submit} <span class="arrow">&rarr;</span></button>
        <p class="note eyebrow">{c.note}</p>
      </form>

      <div class="sent" hidden data-contact-sent>
        <h2>{c.sentTitle}</h2>
        <p>{c.sentBody}</p>
      </div>
    </div>
  </section>
</Base>

{turnstileKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  // fetch 제출: 성공/검증실패/오류를 서버 응답으로 구분해 표시한다.
  // 허니팟·최소 작성시간·Turnstile은 서버가 최종 강제하고, 여기서는 UX만 돕는다.
  const loadedAt = Date.now();
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
  const sent = document.querySelector<HTMLElement>('[data-contact-sent]');
  // Preselect the topic carried by the referring CTA (?topic=demo|pilot|...).
  const topicParam = new URLSearchParams(location.search).get('topic');
  const topicSel = form?.querySelector<HTMLSelectElement>('select[name="topic"]');
  if (topicSel && topicParam && [...topicSel.options].some((o) => o.value === topicParam)) {
    topicSel.value = topicParam;
  }
  if (form && sent) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = form.querySelector<HTMLInputElement>('[name="company_url"]');
      if (hp && hp.value) return; // bot — silent no-op (server enforces too)
      const endpoint = form.getAttribute('action');
      if (!endpoint) return; // endpoint not set yet — mailto fallback carries
      const verr = document.querySelector<HTMLElement>('[data-verify-error]');
      const serr = document.querySelector<HTMLElement>('[data-send-error]');
      // Turnstile: block submit until the widget has produced a token.
      if (form.dataset.turnstile) {
        const tok = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
        if (!tok || !tok.value) {
          if (verr) verr.hidden = false;
          return;
        }
        if (verr) verr.hidden = true;
      }
      if (serr) serr.hidden = true;
      // Stamp elapsed ms since load; the backend drops bot-fast posts.
      const elapsed = form.querySelector<HTMLInputElement>('[data-elapsed]');
      if (elapsed) elapsed.value = String(Date.now() - loadedAt);
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const btnLabel = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.textContent = form.dataset.sending || 'Sending…'; }
      try {
        const res = await fetch(endpoint, { method: 'POST', body: new FormData(form) });
        const data = await res.json().catch(() => null);
        if (res.ok && data && data.ok) {
          form.hidden = true;
          sent.hidden = false;
          sent.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        if (res.status === 403 && verr) verr.hidden = false;
        else if (serr) serr.hidden = false;
      } catch {
        if (serr) serr.hidden = false;
      }
      // 실패 — 재시도 가능 상태로 복원 (Turnstile 토큰은 1회용이라 리셋)
      if (btn) { btn.disabled = false; btn.innerHTML = btnLabel; }
      const ts = (window as { turnstile?: { reset: () => void } }).turnstile;
      if (ts) ts.reset();
    });
  }
</script>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  /* The `display` rules below beat the UA [hidden] rule, so restore it: an
     element with the hidden attribute must stay hidden until JS clears it. */
  [hidden] { display: none !important; }
  .copy { display: flex; flex-direction: column; gap: 1rem; max-width: 46ch; }
  .alt { color: var(--color-slate); }
  .alt a { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }
  .form { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  label { display: flex; flex-direction: column; gap: 0.4rem; }
  label span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  input, textarea, select { font-family: var(--font-body); font-size: var(--step-0); color: var(--color-ink); background: var(--color-vellum); border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.7rem 0.85rem; }
  input:focus, textarea:focus, select:focus { outline: 2px solid var(--color-recovered); outline-offset: 1px; border-color: transparent; }
  .form .btn { align-self: flex-start; }
  .note { margin-top: 0.25rem; }
  .verr { color: #b3261e; font-size: var(--step--1); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .sent {
    padding: 1.75rem;
    border: 1px solid var(--color-recovered);
    border-radius: var(--radius);
    background: var(--color-mist);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .sent h2 { font-size: var(--step-1); }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
