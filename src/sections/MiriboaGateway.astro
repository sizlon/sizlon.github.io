---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';
// Thin company-side overview of Miriboa (the service itself lives at
// miriboa.sizlon.io — 2026-07-23 split). Deliberately light: what/who, the two
// offerings, one proof line, CTAs. The full landings stay on the service site
// so we don't maintain the copy twice.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.miriboaGw;
---

<Base title={c.title} description={c.lede} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
    <div class="ctas">
      <a class="btn btn-primary" href={c.href}>{c.cta} <span class="arrow">&rarr;</span></a>
    </div>
    <p class="trust eyebrow">{c.trust}</p>
  </section>

  <section class="section wrap">
    <div class="cards">
      {c.cards.map((card) => (
        <div class="card">
          <h2>{card.t}</h2>
          <p>{card.d}</p>
          <a class="btn btn-ghost" href={card.href}>{card.cta} <span class="arrow">&rarr;</span></a>
        </div>
      ))}
    </div>
  </section>
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  .ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .trust { margin: 0.25rem 0 0; }
  .cards { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 0.5rem + 2vw, 1.75rem); }
  .card { display: flex; flex-direction: column; gap: 0.75rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .card h2 { font-size: var(--step-1); }
  .card p { font-size: var(--step-0); color: var(--color-slate); line-height: 1.6; margin: 0; }
  .card .btn { align-self: flex-start; margin-top: auto; }
  .btn-ghost { background: transparent; border: 1px solid var(--color-recovered); color: var(--color-ink); }
  @media (max-width: 760px) { .cards { grid-template-columns: 1fr; } }
</style>
