---
import Base from '../layouts/Base.astro';
import SolutionCard from '../components/SolutionCard.astro';
import { solutions } from '../config/site';
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.solutions;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
  </section>

  <section class="section wrap">
    <div class="sol-grid">
      {solutions.map((s) => <SolutionCard solution={s} lang={lang} />)}
    </div>
  </section>
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  .sol-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.25rem; }
</style>
