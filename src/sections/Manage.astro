---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Miriboa verification management. Reached from the account hub (/account) or an
// emailed link. Modes:
//   ?t=<token>  → one request detail (view + add/replace/delete documents). Works
//                 with or without login (capability link); a logged-in session is
//                 bound to the owner email server-side.
//   session     → full list of your requests.
//   (neither)   → redirect to /account to log in.
// Login, account settings and the cross-product hub live on /account, not here.
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.verifyManage;
const strings = {
  f: c.f, noDocs: c.noDocs, purgeAt: c.purgeAt, error: c.error, deleteConfirm: c.deleteConfirm,
  reverify: { intro: c.reverifyIntro, ok: c.reverifyOk, errLimit: c.reverifyErrLimit, errDeadline: c.reverifyErrDeadline },
  runsBadge: c.runsBadge,
  statusMap: c.statusMap, updatedLabel: c.updatedLabel, discardConfirm: c.discardConfirm,
};
---

<Base title={c.manageTitle} description={c.description} lang={lang}>
  <section
    class="section wrap manage"
    data-manage-base={site.manageBase}
    data-precheck-endpoint={site.precheckEndpoint}
    data-auth-logout={site.authLogoutEndpoint}
    data-account-requests={site.accountRequestsEndpoint}
    data-account-path={localizePath('/account', lang)}
    data-home-path={localizePath('/', lang)}
    data-manage-path={localizePath('/manage', lang)}
    data-verify-path={localizePath('/verify-request', lang)}
    data-doc-badges={JSON.stringify(c.badges)}
    data-strings={JSON.stringify(strings)}
  >
    <div class="pagehead">
      <a class="alt" href={localizePath('/account', lang)}>&larr; {c.backToAccount}</a>
      <button class="linkbtn" type="button" hidden data-logout>{c.logout}</button>
    </div>
    <span class="eyebrow">{c.manageEyebrow}</span>
    <h1>{c.manageH1}</h1>
    <p class="loading" data-loading>{c.loading}</p>

    <!-- LIST — all your verification requests -->
    <div class="panel" hidden data-list>
      <a class="btn btn-primary newcta" href={localizePath('/verify-request', lang)}>{c.newVerify} <span class="arrow">&rarr;</span></a>
      <ul class="reqlist" data-reqlist></ul>
      <p class="statusnote" hidden data-account-empty>{c.accountEmpty}</p>
    </div>

    <!-- ONE REQUEST detail -->
    <p class="verr" role="alert" hidden data-notfound>{c.notFound}</p>
    <div class="panel" hidden data-request>
      <dl class="summary" data-summary></dl>
      <p class="statusnote" hidden data-locked>{c.lockedNote}</p>
      <p class="statusnote" hidden data-purged>{c.purgedNote}</p>
      <div class="block reverify" hidden data-reverify-block>
        <h2>{c.reverifyHeading}</h2>
        <p class="hint" data-reverify-intro></p>
        <button class="btn btn-primary" type="button" data-reverify>{c.reverifyBtn}</button>
        <p class="verr" role="alert" hidden data-reverify-err></p>
      </div>
      <p class="ok" role="status" hidden data-reverify-ok></p>
      <div class="editblock" hidden data-editblock>
        <div class="block">
          <h2>{c.addHeading}</h2>
          <p class="hint">{c.addIntro}</p>
          <label class="drop" tabindex="0" data-drop>
            <span class="drop-big">{c.dropBig}</span>
            <span class="hint">{c.dropHint}</span>
            <input type="file" multiple accept=".hwp,.hwpx,.pdf,.docx,.xlsx,.xlsm,.txt,.md" data-docs-input />
          </label>
          <p class="lookup-status" hidden data-docs-checking>{tr.verifyRequest.docs.checking}</p>
          <ul class="filelist" data-filelist></ul>
          <button class="btn btn-primary" type="button" data-save>{c.saveBtn}</button>
          <p class="ok" role="status" hidden data-saved>{c.saved}</p>
          <p class="verr" role="alert" hidden data-error>{c.error}</p>
        </div>
        <div class="block danger" data-purge-block>
          <h2>{c.deleteHeading}</h2>
          <p class="hint">{c.deleteIntro}</p>
          <button class="btn btn-danger" type="button" data-delete>{c.deleteBtn}</button>
        </div>
        <div class="block danger" hidden data-discard-block>
          <h2>{c.discardHeading}</h2>
          <p class="hint">{c.discardIntro}</p>
          <button class="btn btn-danger" type="button" data-discard>{c.discardBtn}</button>
        </div>
      </div>
      <p class="ok" role="status" hidden data-deleted>{c.deleted}</p>
      <p class="ok" role="status" hidden data-discarded>{c.discarded}</p>
      <p class="alt"><a data-back-list href="#">&larr; {c.manageH1}</a></p>
    </div>

    <p class="alt">{c.altPrefix} <a href={localizePath('/contact', lang)}>{c.altQuestion}</a></p>
  </section>
</Base>

<script>
  const root = document.querySelector('.manage');
  const base = root && root.getAttribute('data-manage-base');
  const precheckEndpoint = root && root.getAttribute('data-precheck-endpoint');
  const authLogout = root && root.getAttribute('data-auth-logout');
  const accountEndpoint = root && root.getAttribute('data-account-requests');
  const accountPath = root && root.getAttribute('data-account-path') || '/account';
  const managePath = root && root.getAttribute('data-manage-path') || '/manage';
  const verifyPath = root && root.getAttribute('data-verify-path') || '/verify-request';
  // draft는 미완성 신청 → 위저드에서 완료(서류·NDA·finalize). 접수건만 /manage 상세.
  const hrefFor = (r) => r.status === 'draft'
    ? (verifyPath + '?resume=' + encodeURIComponent(r.token))
    : (managePath + '?t=' + encodeURIComponent(r.token));
  let S = {}, badges = {};
  try { S = JSON.parse(root.getAttribute('data-strings') || '{}'); } catch { S = {}; }
  try { badges = JSON.parse(root.getAttribute('data-doc-badges') || '{}'); } catch { badges = {}; }
  const $ = (s) => root && root.querySelector(s);
  const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  const SKEY = 'miriboa_session';
  // 로그인 중이면 /r/ 호출에 세션을 실어 서버가 신원(소유 이메일)을 대조하게 한다.
  const authHeaders = () => { const s = localStorage.getItem(SKEY); return s ? { Authorization: 'Bearer ' + s } : {}; };
  const q = new URLSearchParams(location.search);

  const loading = $('[data-loading]'), listP = $('[data-list]'), requestP = $('[data-request]'), notfound = $('[data-notfound]');
  const show = (el) => { if (el) el.hidden = false; };
  const hideAll = () => { [loading, listP, requestP, notfound].forEach((e) => { if (e) e.hidden = true; }); };

  // 로그인 상태면 로그아웃 버튼을 노출(비로그인 이메일 링크 열람 땐 숨김).
  const logoutBtn = $('[data-logout]');
  if (logoutBtn && localStorage.getItem(SKEY)) logoutBtn.hidden = false;
  if (logoutBtn) logoutBtn.addEventListener('click', () => {
    const sess = localStorage.getItem(SKEY);
    localStorage.removeItem(SKEY);
    if (authLogout) { try { fetch(authLogout, { method: 'POST', credentials: 'include', headers: sess ? { Authorization: 'Bearer ' + sess } : {}, keepalive: true }); } catch (e) {} }
    // 로그아웃 후엔 홈으로 (Account 와 동일).
    location.href = (root && root.getAttribute('data-home-path')) || '/';
  });

  async function boot() {
    const tok = q.get('t'), login = q.get('login');
    if (tok) return loadRequest(tok);
    if (login) { location.href = accountPath + '?login=' + encodeURIComponent(login); return; }   // 로그인은 허브에서
    const sess = localStorage.getItem(SKEY);
    if (sess) return loadList(sess);
    location.href = accountPath;
  }

  async function loadList(session) {
    hideAll(); show(loading);
    try {
      const res = await fetch(accountEndpoint, { headers: { Authorization: 'Bearer ' + session } });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) renderList(d.requests || []);
      else { localStorage.removeItem(SKEY); location.href = accountPath; }
    } catch { hideAll(); show(notfound); }
  }

  function renderList(requests) {
    hideAll();
    const list = $('[data-reqlist]'), empty = $('[data-account-empty]');
    if (list) {
      list.innerHTML = '';
      const fmtWhen = (iso) => { if (!iso) return ''; return String(iso).slice(0, 16).replace('T', ' '); };
      requests.forEach((r) => {
        const st = (S.statusMap && S.statusMap[r.status]) || r.status;
        const title = ((r.notice_no || '') + ' ' + (r.notice_name || '')).trim() || '—';
        const when = fmtWhen(r.updated_at || r.created_at);
        const li = document.createElement('li');
        li.innerHTML = '<a href="' + esc(hrefFor(r)) + '">'
          + '<span class="rq-main"><span class="rq-title">' + esc(title) + '</span>'
          + '<span class="rq-when">' + esc((S.updatedLabel || '') + ' ' + when) + '</span></span>'
          + '<span class="rq-meta">'
          + (r.credit_used ? '<span class="rq-runs">' + esc((S.runsBadge || '').replace('{n}', String(r.verify_count)).replace('{max}', String(r.max_verifications))) + '</span>' : '')
          + '<span class="rq-status s-' + esc(r.status) + '">' + esc(st) + '</span></span>'
          + '</a>';
        list.appendChild(li);
      });
    }
    if (empty) empty.hidden = requests.length > 0;
    show(listP);
  }

  const backList = $('[data-back-list]');
  if (backList) backList.addEventListener('click', (e) => { e.preventDefault(); location.href = managePath; });

  // ── ONE REQUEST (summary + edit) ──
  const summary = $('[data-summary]'), editblock = $('[data-editblock]');
  const lockedEl = $('[data-locked]'), purgedEl = $('[data-purged]'), deletedEl = $('[data-deleted]');
  const purgeBlock = $('[data-purge-block]'), discardBlock = $('[data-discard-block]'), discardedEl = $('[data-discarded]');
  let reqToken = '';

  function renderSummary(d) {
    if (!summary) return;
    const f = S.f || {};
    const st = (S.statusMap && S.statusMap[d.status]) || d.status;
    const rows = [
      [f.notice, ((d.notice_no || '') + ' ' + (d.notice_name || '')).trim()],
      [f.deadline, d.deadline], [f.institution, d.institution], [f.status, st],
      [d.creditUsed ? f.runs : '', d.creditUsed ? d.verifyCount + '/' + d.maxVerifications : ''],
    ];
    let html = rows.filter((r) => r[1]).map((r) => '<div><dt>' + esc(r[0]) + '</dt><dd>' + esc(r[1]) + '</dd></div>').join('');
    const docs = (d.doc_names && d.doc_names.length)
      ? d.doc_names.map((n) => '<li>' + esc(n) + '</li>').join('')
      : '<li class="muted">' + esc(S.noDocs) + '</li>';
    html += '<div><dt>' + esc(f.docs) + '</dt><dd><ul class="docnames">' + docs + '</ul>';
    if (d.purge_at && d.doc_count) html += '<p class="purge">' + esc(S.purgeAt) + ' ' + esc(String(d.purge_at).slice(0, 10)) + '</p>';
    html += '</dd></div>';
    summary.innerHTML = html;
  }
  async function loadRequest(token) {
    reqToken = token;
    hideAll(); show(loading);
    if (!token || !base) { hideAll(); show(notfound); return; }
    try {
      const res = await fetch(base + '/' + encodeURIComponent(token), { headers: authHeaders() });
      const d = await res.json().catch(() => null);
      if (!res.ok || !d || !d.ok) { hideAll(); show(notfound); return; }
      // draft(미완성)는 위저드에서 완료 — 옛 /manage?t= 링크도 위저드 재개로 보낸다.
      if (d.status === 'draft') { location.href = verifyPath + '?resume=' + encodeURIComponent(token); return; }
      hideAll(); renderSummary(d);
      if (d.editable) {
        const isDraft = d.status === 'draft';
        if (purgeBlock) purgeBlock.hidden = isDraft;
        if (discardBlock) discardBlock.hidden = !isDraft;
        show(editblock);
      } else if (d.purged) show(purgedEl);
      else if (!d.reverifiable) show(lockedEl);
      // 재검증 (delivered 이후·마감 전·횟수 남음): 요청 → received 로 되돌아가
      // 서류 교체가 열린다. 요청 성공 시 loadRequest 재호출로 편집 화면 전환.
      const rvBlock = $('[data-reverify-block]');
      if (rvBlock) {
        rvBlock.hidden = !d.reverifiable;
        if (d.reverifiable) {
          const intro = $('[data-reverify-intro]');
          if (intro) intro.textContent = (S.reverify && S.reverify.intro || '')
            .replace('{remaining}', String(d.maxVerifications - d.verifyCount));
        }
      }
      show(requestP);
    } catch { hideAll(); show(notfound); }
  }

  const rvBtn = $('[data-reverify]');
  if (rvBtn) rvBtn.addEventListener('click', async () => {
    if (!reqToken || !base) return;
    rvBtn.disabled = true;
    const ok = $('[data-reverify-ok]'), err = $('[data-reverify-err]');
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/reverify', { method: 'POST', headers: authHeaders() });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) {
        if (ok) { ok.textContent = (S.reverify && S.reverify.ok || '').replace('{count}', String(d.verifyCount)); ok.hidden = false; }
        await loadRequest(reqToken);   // received 로 돌아가 서류 교체 UI가 열린다
        if (ok) ok.hidden = false;
        return;
      }
      const code = d && d.error;
      if (err) {
        err.textContent = code === 'limit' ? (S.reverify && S.reverify.errLimit || '')
          : code === 'deadline_passed' ? (S.reverify && S.reverify.errDeadline || '')
          : (S.error || '');
        err.hidden = false;
      }
    } catch { if (err) { err.textContent = S.error || ''; err.hidden = false; } }
    rvBtn.disabled = false;
  });

  // dropzone (add/replace)
  const docInput = $('[data-docs-input]'), drop = $('[data-drop]'), filelist = $('[data-filelist]'), docChecking = $('[data-docs-checking]');
  function renderFiles(arr, statuses) {
    if (!filelist) return; filelist.innerHTML = '';
    arr.forEach((f, i) => {
      const st = statuses && statuses[i];
      const badge = st ? '<span class="fbadge ' + st.status + '">' + esc(badges[st.status] || st.status) + '</span>' : '';
      const li = document.createElement('li');
      li.innerHTML = '<span class="fname">' + esc(f.name) + '</span>' + badge;
      filelist.appendChild(li);
    });
  }
  function setFiles(arr2) {
    const arr = arr2.slice(0, 20).filter((f) => f.size <= 40 * 1024 * 1024);
    const dt = new DataTransfer(); arr.forEach((f) => dt.items.add(f));
    if (docInput) docInput.files = dt.files;
    renderFiles(arr, null); if (arr.length) precheckFiles(arr);
  }
  let pcSeq = 0;
  async function precheckFiles(arr) {
    if (!precheckEndpoint) return; const seq = ++pcSeq;
    if (docChecking) docChecking.hidden = false;
    const fd = new FormData(); arr.forEach((f) => fd.append('files', f, f.name));
    try {
      const res = await fetch(precheckEndpoint, { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (seq !== pcSeq) return; if (docChecking) docChecking.hidden = true;
      if (d && d.files) { const by = {}; d.files.forEach((r) => { by[r.name] = r; }); renderFiles(arr, arr.map((f) => by[f.name] || null)); }
    } catch { if (seq === pcSeq && docChecking) docChecking.hidden = true; }
  }
  if (docInput) docInput.addEventListener('change', () => setFiles([...docInput.files]));
  if (drop && docInput) {
    ['dragenter', 'dragover'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); }));
    ['dragleave', 'drop'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); }));
    drop.addEventListener('drop', (e) => { if (e.dataTransfer) setFiles([...e.dataTransfer.files]); });
    drop.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); docInput.click(); } });
  }
  const saveBtn = $('[data-save]'), savedEl = $('[data-saved]'), errEl = $('[data-error]');
  if (saveBtn) saveBtn.addEventListener('click', async () => {
    if (errEl) errEl.hidden = true; if (savedEl) savedEl.hidden = true;
    if (!docInput || !docInput.files.length) return;
    const lbl = saveBtn.textContent; saveBtn.disabled = true;
    const fd = new FormData(); [...docInput.files].forEach((f) => fd.append('documents', f, f.name));
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/documents', { method: 'POST', body: fd, headers: authHeaders() });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (savedEl) savedEl.hidden = false; loadRequest(reqToken); }
      else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    saveBtn.disabled = false; saveBtn.textContent = lbl;
  });
  const delBtn = $('[data-delete]');
  if (delBtn) delBtn.addEventListener('click', async () => {
    if (!confirm(S.deleteConfirm || 'Delete?')) return;
    delBtn.disabled = true;
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/delete', { method: 'POST', headers: authHeaders() });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (editblock) editblock.hidden = true; if (deletedEl) deletedEl.hidden = false; loadRequest(reqToken); }
      else delBtn.disabled = false;
    } catch { delBtn.disabled = false; }
  });
  const discardBtn = $('[data-discard]');
  if (discardBtn) discardBtn.addEventListener('click', async () => {
    if (!confirm(S.discardConfirm || 'Delete draft?')) return;
    discardBtn.disabled = true;
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/discard', { method: 'POST', headers: authHeaders() });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) {
        if (editblock) editblock.hidden = true;
        if (summary) summary.hidden = true;
        if (discardedEl) discardedEl.hidden = false;
      } else discardBtn.disabled = false;
    } catch { discardBtn.disabled = false; }
  });

  boot();
</script>

<style>
  [hidden] { display: none !important; }
  .manage { max-width: 640px; display: flex; flex-direction: column; gap: 1rem; }
  .loading, .statusnote { color: var(--color-slate); }
  .statusnote { padding: 0.9rem 1.1rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .verr { color: #b3261e; }
  .ok { color: var(--color-recovered); font-weight: 600; }
  .panel { display: flex; flex-direction: column; gap: 1.1rem; }
  .alt { color: var(--color-slate); margin: 0; }
  .alt a, a.alt { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }
  .pagehead { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .linkbtn { background: none; border: 0; color: var(--color-slate); cursor: pointer; text-decoration: underline; font: inherit; font-size: var(--step--1); }
  .newcta { align-self: flex-start; }

  /* 목록 항목(li·fname·fbadge 내부)은 JS innerHTML로 그려져 Astro 스코프 속성이
     없다. 정적 앵커(data-* 컨테이너) 하위는 :global()로 풀어야 먹는다. */
  .reqlist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .reqlist :global(a) { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 0.9rem 1.1rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); text-decoration: none; color: var(--color-ink); transition: border-color .15s ease; }
  .reqlist :global(a:hover) { border-color: var(--color-recovered); }
  .reqlist :global(.rq-main) { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .reqlist :global(.rq-when) { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .reqlist :global(.rq-title) { font-weight: 600; }
  .reqlist :global(.rq-meta) { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); white-space: nowrap; }
  .reqlist :global(.rq-status) { font-weight: 700; }
  .reqlist :global(.rq-runs) { font-family: var(--font-mono); font-size: var(--step--2); color: var(--color-slate); border: 1px solid var(--hairline); border-radius: 999px; padding: 0.15rem 0.55rem; margin-right: 0.4rem; }
  .reqlist :global(.rq-status.s-draft) { color: #a2570f; }
  .reqlist :global(.rq-status.s-received) { color: var(--color-recovered); }

  .summary { margin: 0; display: grid; gap: 0.5rem; padding: 1.1rem 1.25rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .summary :global(> div) { display: grid; grid-template-columns: 6rem 1fr; gap: 0.6rem; align-items: baseline; }
  .summary :global(dt) { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); margin: 0; }
  .summary :global(dd) { margin: 0; }
  .summary :global(.docnames) { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.15rem; }
  .summary :global(.docnames .muted) { color: var(--color-slate); }
  .summary :global(.purge) { font-size: var(--step--1); color: var(--color-slate); margin: 0.35rem 0 0; }

  .editblock { display: flex; flex-direction: column; gap: 1.5rem; }
  .block { display: flex; flex-direction: column; gap: 0.7rem; padding: 1.25rem; border: 1px solid var(--hairline); border-radius: var(--radius); }
  .block.danger { border-color: color-mix(in srgb, #b3261e 40%, var(--hairline)); }
  .block h2 { font-size: var(--step-1); margin: 0; }
  .hint { font-size: var(--step--1); color: var(--color-slate); }
  .lookup-status { font-size: var(--step--1); color: var(--color-slate); margin: 0; }

  .drop { display: block; border: 2px dashed var(--hairline); border-radius: var(--radius); background: var(--color-vellum); padding: 1.4rem 1rem; text-align: center; cursor: pointer; transition: border-color .15s ease; }
  .drop:hover, .drop.over { border-color: var(--color-recovered); }
  .drop:focus-visible { outline: 2px solid var(--color-recovered); outline-offset: 2px; }
  .drop .drop-big { display: block; font-weight: 600; }
  .drop .hint { display: block; margin-top: 0.4rem; }
