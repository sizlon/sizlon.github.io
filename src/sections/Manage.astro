---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// "Manage your requests" page. Modes:
//   ?t=<token>     → one request (summary + add/replace/delete documents)
//   ?login=<tok>   → verify a magic-link → session → list of all your requests
//   (default)      → session? list ; else email+password login (magic link for first-time/forgot)
// Auth: email+password (portal-compatible bcrypt on the backend), with the magic
// link as the first-time/forgot path; once logged in you can set/change a password.
// Documents can be changed while a request is 'draft' or 'received'.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.verifyManage;
const strings = {
  f: c.f, noDocs: c.noDocs, purgeAt: c.purgeAt, error: c.error, deleteConfirm: c.deleteConfirm,
  statusMap: c.statusMap, loginSent: c.loginSent, accountEmpty: c.accountEmpty, open: c.open,
  setPw: c.setPw, updatedLabel: c.updatedLabel, discardConfirm: c.discardConfirm,
};
---

<Base title={c.title} description={c.description} lang={lang}>
  <section
    class="section wrap manage"
    data-manage-base={site.manageBase}
    data-precheck-endpoint={site.precheckEndpoint}
    data-auth-request={site.authRequestEndpoint}
    data-auth-verify={site.authVerifyEndpoint}
    data-auth-login={site.authLoginEndpoint}
    data-auth-set-password={site.authSetPasswordEndpoint}
    data-account-requests={site.accountRequestsEndpoint}
    data-manage-path={localizePath('/manage', lang)}
    data-doc-badges={JSON.stringify(c.badges)}
    data-strings={JSON.stringify(strings)}
  >
    <span class="eyebrow">{c.eyebrow}</span>
    <h1 data-h1>{c.h1}</h1>
    <p class="loading" data-loading>{c.loading}</p>

    <!-- LOGIN (email + password; magic link for first-time/forgot) -->
    <div class="panel" hidden data-login>
      <p>{c.loginIntro}</p>
      <form class="loginform" data-login-form>
        <label><span>{c.loginEmail}</span>
          <input type="email" name="email" autocomplete="email" maxlength="180" required /></label>
        <label><span>{c.loginPassword}</span>
          <input type="password" name="password" autocomplete="current-password" maxlength="200" required /></label>
        <button class="btn btn-primary" type="submit">{c.loginBtn} <span class="arrow">&rarr;</span></button>
        <p class="verr" role="alert" hidden data-login-error>{c.loginError}</p>
      </form>
      <p class="alt"><button type="button" class="linkbtn" data-magic-link>{c.loginMagic}</button></p>
      <p class="ok" role="status" hidden data-login-sent>{c.loginSent}</p>
    </div>

    <!-- ACCOUNT (list of requests) -->
    <div class="panel" hidden data-account>
      <div class="acct-head">
        <span class="acct-email" data-acct-email></span>
        <button class="linkbtn" type="button" data-logout>{c.logout}</button>
      </div>
      <ul class="reqlist" data-reqlist></ul>
      <p class="statusnote" hidden data-account-empty>{c.accountEmpty}</p>
      <div class="block setpw" data-setpw hidden>
        <h2>{c.setPw.heading}</h2>
        <p class="hint" data-setpw-intro>{c.setPw.intro}</p>
        <form class="loginform" data-setpw-form>
          <label><span>{c.setPw.new}</span>
            <input type="password" name="password" autocomplete="new-password" minlength="8" maxlength="200" required /></label>
          <button class="btn btn-primary" type="submit">{c.setPw.save}</button>
        </form>
        <p class="ok" role="status" hidden data-setpw-saved>{c.setPw.saved}</p>
        <p class="verr" role="alert" hidden data-setpw-error>{c.setPw.weak}</p>
      </div>
    </div>

    <!-- ONE REQUEST -->
    <p class="verr" role="alert" hidden data-notfound>{c.notFound}</p>
    <div class="panel" hidden data-request>
      <dl class="summary" data-summary></dl>
      <p class="statusnote" hidden data-locked>{c.lockedNote}</p>
      <p class="statusnote" hidden data-purged>{c.purgedNote}</p>
      <div class="editblock" hidden data-editblock>
        <div class="block">
          <h2>{c.addHeading}</h2>
          <p class="hint">{c.addIntro}</p>
          <label class="drop" tabindex="0" data-drop>
            <span class="drop-big">{c.dropBig}</span>
            <span class="hint">{c.dropHint}</span>
            <input type="file" multiple accept=".hwp,.hwpx,.pdf,.docx,.xlsx,.xlsm,.txt,.md" data-docs-input />
          </label>
          <p class="lookup-status" hidden data-docs-checking>{tr.verifyRequest.docs.checking}</p>
          <ul class="filelist" data-filelist></ul>
          <button class="btn btn-primary" type="button" data-save>{c.saveBtn}</button>
          <p class="ok" role="status" hidden data-saved>{c.saved}</p>
          <p class="verr" role="alert" hidden data-error>{c.error}</p>
        </div>
        <div class="block danger" data-purge-block>
          <h2>{c.deleteHeading}</h2>
          <p class="hint">{c.deleteIntro}</p>
          <button class="btn btn-danger" type="button" data-delete>{c.deleteBtn}</button>
        </div>
        <div class="block danger" hidden data-discard-block>
          <h2>{c.discardHeading}</h2>
          <p class="hint">{c.discardIntro}</p>
          <button class="btn btn-danger" type="button" data-discard>{c.discardBtn}</button>
        </div>
      </div>
      <p class="ok" role="status" hidden data-deleted>{c.deleted}</p>
      <p class="ok" role="status" hidden data-discarded>{c.discarded}</p>
      <p class="alt"><a data-back-account href="#">&larr; {c.accountHeading}</a></p>
    </div>

    <p class="alt">{c.altPrefix} <a href={localizePath('/contact', lang)}>{c.altQuestion}</a></p>
  </section>
</Base>

<script>
  const root = document.querySelector('.manage');
  const base = root && root.getAttribute('data-manage-base');
  const precheckEndpoint = root && root.getAttribute('data-precheck-endpoint');
  const authRequest = root && root.getAttribute('data-auth-request');
  const authVerify = root && root.getAttribute('data-auth-verify');
  const authLogin = root && root.getAttribute('data-auth-login');
  const authSetPassword = root && root.getAttribute('data-auth-set-password');
  const accountEndpoint = root && root.getAttribute('data-account-requests');
  const managePath = root && root.getAttribute('data-manage-path') || '/manage';
  let S = {}, badges = {};
  try { S = JSON.parse(root.getAttribute('data-strings') || '{}'); } catch { S = {}; }
  try { badges = JSON.parse(root.getAttribute('data-doc-badges') || '{}'); } catch { badges = {}; }
  const $ = (s) => root && root.querySelector(s);
  const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  const SKEY = 'miriboa_session';
  const q = new URLSearchParams(location.search);

  const loading = $('[data-loading]'), loginP = $('[data-login]'), accountP = $('[data-account]');
  const requestP = $('[data-request]'), notfound = $('[data-notfound]');
  const show = (el) => { if (el) el.hidden = false; };
  const hideAll = () => { [loading, loginP, accountP, requestP, notfound].forEach((e) => { if (e) e.hidden = true; }); };

  // ── mode dispatch ──
  async function boot() {
    const t = q.get('t'), login = q.get('login');
    if (t) return loadRequest(t);
    if (login) return verifyLogin(login);
    const sess = localStorage.getItem(SKEY);
    if (sess) return loadAccount(sess);
    hideAll(); show(loginP);
  }

  // ── LOGIN (이메일+비밀번호) ──
  const loginForm = $('[data-login-form]');
  if (loginForm) loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const errEl = $('[data-login-error]');
    if (errEl) errEl.hidden = true;
    const email = loginForm.querySelector('[name="email"]').value.trim();
    const password = loginForm.querySelector('[name="password"]').value;
    const btn = loginForm.querySelector('button'); btn.disabled = true;
    try {
      const fd = new FormData(); fd.append('email', email); fd.append('password', password);
      const res = await fetch(authLogin, { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok && d.session) {
        localStorage.setItem(SKEY, d.session);
        renderAccount(d.email, d.requests || [], !!d.has_password);
      } else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    btn.disabled = false;
  });

  // ── 매직 링크(처음/분실) — 입력한 이메일로 로그인 링크 발송 ──
  const magicBtn = $('[data-magic-link]');
  if (magicBtn) magicBtn.addEventListener('click', async () => {
    const sentEl = $('[data-login-sent]'), errEl = $('[data-login-error]');
    if (errEl) errEl.hidden = true;
    const email = (loginForm && loginForm.querySelector('[name="email"]').value.trim()) || '';
    if (!email) { const inp = loginForm && loginForm.querySelector('[name="email"]'); if (inp) inp.focus(); return; }
    magicBtn.disabled = true;
    try {
      const fd = new FormData(); fd.append('email', email);
      const res = await fetch(authRequest, { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (sentEl) sentEl.hidden = false; if (loginForm) loginForm.hidden = true; magicBtn.hidden = true; }
      else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    magicBtn.disabled = false;
  });

  async function verifyLogin(token) {
    hideAll(); show(loading);
    try {
      const fd = new FormData(); fd.append('token', token);
      const res = await fetch(authVerify, { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok && d.session) {
        localStorage.setItem(SKEY, d.session);
        history.replaceState(null, '', managePath);   // 링크에서 토큰 제거
        renderAccount(d.email, d.requests || [], !!d.has_password);
      } else { hideAll(); show(loginP); }   // 만료/무효 → 다시 로그인
    } catch { hideAll(); show(loginP); }
  }

  async function loadAccount(session) {
    hideAll(); show(loading);
    try {
      const res = await fetch(accountEndpoint, { headers: { Authorization: 'Bearer ' + session } });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) renderAccount(d.email, d.requests || [], !!d.has_password);
      else { localStorage.removeItem(SKEY); hideAll(); show(loginP); }
    } catch { hideAll(); show(loginP); }
  }

  function renderAccount(email, requests, hasPassword) {
    hideAll();
    const em = $('[data-acct-email]'); if (em) em.textContent = email;
    // 비밀번호 설정/변경 블록: 미설정이면 안내를 강조.
    const setpw = $('[data-setpw]'), setpwIntro = $('[data-setpw-intro]');
    if (setpw) setpw.hidden = false;
    if (setpwIntro && S.setPw) setpwIntro.textContent = hasPassword ? S.setPw.intro : S.setPw.introFirst;
    const list = $('[data-reqlist]'), empty = $('[data-account-empty]');
    if (list) {
      list.innerHTML = '';
      const fmtWhen = (iso) => { if (!iso) return ''; return String(iso).slice(0, 16).replace('T', ' '); };
      requests.forEach((r) => {
        const st = (S.statusMap && S.statusMap[r.status]) || r.status;
        const title = ((r.notice_no || '') + ' ' + (r.notice_name || '')).trim() || '—';
        const when = fmtWhen(r.updated_at || r.created_at);
        const li = document.createElement('li');
        li.innerHTML = '<a href="' + esc(managePath) + '?t=' + encodeURIComponent(r.token) + '">'
          + '<span class="rq-main"><span class="rq-title">' + esc(title) + '</span>'
          + '<span class="rq-when">' + esc((S.updatedLabel || '') + ' ' + when) + '</span></span>'
          + '<span class="rq-meta"><span class="rq-status s-' + esc(r.status) + '">' + esc(st) + '</span></span>'
          + '</a>';
        list.appendChild(li);
      });
    }
    if (empty) empty.hidden = requests.length > 0;
    show(accountP);
  }

  const logoutBtn = $('[data-logout]');
  if (logoutBtn) logoutBtn.addEventListener('click', () => { localStorage.removeItem(SKEY); location.href = managePath; });

  // ── 비밀번호 설정/변경 (현재 세션으로) ──
  const setpwForm = $('[data-setpw-form]');
  if (setpwForm) setpwForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const savedEl = $('[data-setpw-saved]'), errEl = $('[data-setpw-error]');
    if (savedEl) savedEl.hidden = true; if (errEl) errEl.hidden = true;
    const session = localStorage.getItem(SKEY);
    const password = setpwForm.querySelector('[name="password"]').value;
    if (!session) { location.href = managePath; return; }
    if (password.length < 8) { if (errEl) errEl.hidden = false; return; }
    const btn = setpwForm.querySelector('button'); btn.disabled = true;
    try {
      const fd = new FormData(); fd.append('password', password);
      const res = await fetch(authSetPassword, { method: 'POST', body: fd, headers: { Authorization: 'Bearer ' + session } });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) {
        if (savedEl) savedEl.hidden = false; setpwForm.reset();
        const intro = $('[data-setpw-intro]'); if (intro && S.setPw) intro.textContent = S.setPw.intro;
      } else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    btn.disabled = false;
  });
  const backAccount = $('[data-back-account]');
  if (backAccount) backAccount.addEventListener('click', (e) => { e.preventDefault(); location.href = managePath; });

  // ── ONE REQUEST (summary + edit) ──
  const summary = $('[data-summary]'), editblock = $('[data-editblock]');
  const lockedEl = $('[data-locked]'), purgedEl = $('[data-purged]'), deletedEl = $('[data-deleted]');
  const purgeBlock = $('[data-purge-block]'), discardBlock = $('[data-discard-block]'), discardedEl = $('[data-discarded]');
  let reqToken = '';

  function renderSummary(d) {
    if (!summary) return;
    const f = S.f || {};
    const st = (S.statusMap && S.statusMap[d.status]) || d.status;
    const rows = [
      [f.notice, ((d.notice_no || '') + ' ' + (d.notice_name || '')).trim()],
      [f.deadline, d.deadline], [f.institution, d.institution], [f.status, st],
    ];
    let html = rows.filter((r) => r[1]).map((r) => '<div><dt>' + esc(r[0]) + '</dt><dd>' + esc(r[1]) + '</dd></div>').join('');
    const docs = (d.doc_names && d.doc_names.length)
      ? d.doc_names.map((n) => '<li>' + esc(n) + '</li>').join('')
      : '<li class="muted">' + esc(S.noDocs) + '</li>';
    html += '<div><dt>' + esc(f.docs) + '</dt><dd><ul class="docnames">' + docs + '</ul>';
    if (d.purge_at && d.doc_count) html += '<p class="purge">' + esc(S.purgeAt) + ' ' + esc(String(d.purge_at).slice(0, 10)) + '</p>';
    html += '</dd></div>';
    summary.innerHTML = html;
  }
  async function loadRequest(token) {
    reqToken = token;
    hideAll(); show(loading);
    if (!token || !base) { hideAll(); show(notfound); return; }
    try {
      const res = await fetch(base + '/' + encodeURIComponent(token));
      const d = await res.json().catch(() => null);
      if (!res.ok || !d || !d.ok) { hideAll(); show(notfound); return; }
      hideAll(); renderSummary(d);
      if (d.editable) {
        // draft(미접수)면 '신청 자체 삭제', 접수(received)면 '문서 파기'를 보인다.
        const isDraft = d.status === 'draft';
        if (purgeBlock) purgeBlock.hidden = isDraft;
        if (discardBlock) discardBlock.hidden = !isDraft;
        show(editblock);
      } else if (d.purged) show(purgedEl);
      else show(lockedEl);
      // 로그인 세션이 없으면 '목록으로' 링크는 로그인으로 보낸다
      show(requestP);
    } catch { hideAll(); show(notfound); }
  }

  // dropzone (add/replace)
  const docInput = $('[data-docs-input]'), drop = $('[data-drop]'), filelist = $('[data-filelist]'), docChecking = $('[data-docs-checking]');
  function renderFiles(arr, statuses) {
    if (!filelist) return; filelist.innerHTML = '';
    arr.forEach((f, i) => {
      const st = statuses && statuses[i];
      const badge = st ? '<span class="fbadge ' + st.status + '">' + esc(badges[st.status] || st.status) + '</span>' : '';
      const li = document.createElement('li');
      li.innerHTML = '<span class="fname">' + esc(f.name) + '</span>' + badge;
      filelist.appendChild(li);
    });
  }
  function setFiles(arr2) {
    const arr = arr2.slice(0, 20).filter((f) => f.size <= 40 * 1024 * 1024);
    const dt = new DataTransfer(); arr.forEach((f) => dt.items.add(f));
    if (docInput) docInput.files = dt.files;
    renderFiles(arr, null); if (arr.length) precheckFiles(arr);
  }
  let pcSeq = 0;
  async function precheckFiles(arr) {
    if (!precheckEndpoint) return; const seq = ++pcSeq;
    if (docChecking) docChecking.hidden = false;
    const fd = new FormData(); arr.forEach((f) => fd.append('files', f, f.name));
    try {
      const res = await fetch(precheckEndpoint, { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (seq !== pcSeq) return; if (docChecking) docChecking.hidden = true;
      if (d && d.files) { const by = {}; d.files.forEach((r) => { by[r.name] = r; }); renderFiles(arr, arr.map((f) => by[f.name] || null)); }
    } catch { if (seq === pcSeq && docChecking) docChecking.hidden = true; }
  }
  if (docInput) docInput.addEventListener('change', () => setFiles([...docInput.files]));
  if (drop && docInput) {
    ['dragenter', 'dragover'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); }));
    ['dragleave', 'drop'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); }));
    drop.addEventListener('drop', (e) => { if (e.dataTransfer) setFiles([...e.dataTransfer.files]); });
    drop.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); docInput.click(); } });
  }
  const saveBtn = $('[data-save]'), savedEl = $('[data-saved]'), errEl = $('[data-error]');
  if (saveBtn) saveBtn.addEventListener('click', async () => {
    if (errEl) errEl.hidden = true; if (savedEl) savedEl.hidden = true;
    if (!docInput || !docInput.files.length) return;
    const lbl = saveBtn.textContent; saveBtn.disabled = true;
    const fd = new FormData(); [...docInput.files].forEach((f) => fd.append('documents', f, f.name));
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/documents', { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (savedEl) savedEl.hidden = false; loadRequest(reqToken); }
      else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    saveBtn.disabled = false; saveBtn.textContent = lbl;
  });
  const delBtn = $('[data-delete]');
  if (delBtn) delBtn.addEventListener('click', async () => {
    if (!confirm(S.deleteConfirm || 'Delete?')) return;
    delBtn.disabled = true;
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/delete', { method: 'POST' });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (editblock) editblock.hidden = true; if (deletedEl) deletedEl.hidden = false; loadRequest(reqToken); }
      else delBtn.disabled = false;
    } catch { delBtn.disabled = false; }
  });
  // draft(신청 자체) 삭제 — 성공하면 신청은 사라지므로 요약·편집을 감추고 안내만 남긴다.
  const discardBtn = $('[data-discard]');
  if (discardBtn) discardBtn.addEventListener('click', async () => {
    if (!confirm(S.discardConfirm || 'Delete draft?')) return;
    discardBtn.disabled = true;
    try {
      const res = await fetch(base + '/' + encodeURIComponent(reqToken) + '/discard', { method: 'POST' });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) {
        if (editblock) editblock.hidden = true;
        if (summary) summary.hidden = true;
        if (discardedEl) discardedEl.hidden = false;
      } else discardBtn.disabled = false;
    } catch { discardBtn.disabled = false; }
  });

  boot();
</script>

<style>
  [hidden] { display: none !important; }
  .manage { max-width: 640px; display: flex; flex-direction: column; gap: 1rem; }
  .loading, .statusnote { color: var(--color-slate); }
  .statusnote { padding: 0.9rem 1.1rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .verr { color: #b3261e; }
  .ok { color: var(--color-recovered); font-weight: 600; }
  .panel { display: flex; flex-direction: column; gap: 1.1rem; }
  .alt { color: var(--color-slate); margin: 0; }
  .alt a { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }

  .loginform { display: flex; flex-direction: column; gap: 0.7rem; max-width: 22rem; }
  .loginform label { display: flex; flex-direction: column; gap: 0.4rem; }
  .loginform label span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .loginform input { font-family: var(--font-body); font-size: var(--step-0); color: var(--color-ink); background: var(--color-vellum); border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.7rem 0.85rem; }
  .loginform .btn { align-self: flex-start; }

  .acct-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .acct-email { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .linkbtn { background: none; border: 0; color: var(--color-slate); cursor: pointer; text-decoration: underline; font: inherit; font-size: var(--step--1); }
  /* 아래 목록들(reqlist·summary·filelist 내부)은 JS innerHTML로 그려져 Astro
     스코프 속성이 없다. 정적 앵커(data-* 컨테이너) 하위는 :global()로 풀어야 먹는다. */
  .reqlist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .reqlist :global(a) { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 0.9rem 1.1rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); text-decoration: none; color: var(--color-ink); transition: border-color .15s ease; }
  .reqlist :global(a:hover) { border-color: var(--color-recovered); }
