---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Free notice-alert signup. fetch-POSTs to site.subscribeEndpoint (site-backend,
// svc.sizlon.io), which verifies Turnstile server-side and, on a new email,
// sends a double opt-in confirmation link before any alert goes out.
// `company_url` is a honeypot; `elapsed` is the min-fill timer. While the
// endpoint is empty the submit no-ops.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.monitor;
const endpoint = site.subscribeEndpoint;
const turnstileKey = site.turnstileSiteKey;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="section wrap">
    <div class="copy hero">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href="#signup">{c.heroCtaFree} <span class="arrow">&rarr;</span></a>
        <a class="btn btn-ghost" href={localizePath('/monitor/screening', lang)}>{c.heroCtaPaid} <span class="arrow">&rarr;</span></a>
      </div>
      <p class="alt">{tr.contact.applyPrefix} <a href={`${localizePath('/verify-request', lang)}?src=monitor`}>{tr.contact.applyLink} &rarr;</a></p>
    </div>

    <div class="how">
      <h2 class="sub-heading">{c.how.heading}</h2>
      <ol class="steps">
        {c.how.steps.map((s, i) => (
          <li class="step">
            <span class="stepnum">{i + 1}</span>
            <h3>{s.t}</h3>
            <p>{s.b}</p>
          </li>
        ))}
      </ol>
    </div>

    <div class="sample">
      <h2 class="sub-heading">{c.sample.heading}</h2>
      <div class="mail">
        <div class="mail-subject">{c.sample.subject}</div>
        <ul class="mail-lines">
          {c.sample.lines.map((l) => (
            <li>
              <div class="mline-head"><span class="mline-name">{l.name}</span><span class="mline-meta">{l.meta}</span></div>
              <div class={`mline-verdict v-${l.kind}`}>{l.verdict}</div>
            </li>
          ))}
        </ul>
        <p class="mail-note eyebrow">{c.sample.note}</p>
      </div>
    </div>

    <h2 class="tiers-heading">{c.tiers.heading}</h2>
    <div class="tiers">
      <div class="tier">
        <div class="tier-head">
          <h3>{c.tiers.free.name}</h3>
          <div class="price"><span class="amount">{c.tiers.free.price}</span></div>
        </div>
        <p class="tier-tag">{c.tiers.free.tagline}</p>
        <ul>{c.tiers.free.features.map((f) => <li>{f}</li>)}</ul>
        <a class="btn btn-primary" href="#signup">{c.tiers.free.cta} <span class="arrow">&rarr;</span></a>
      </div>
      <div class="tier featured">
        <span class="badge">{c.tiers.paid.badge}</span>
        <div class="tier-head">
          <h3>{c.tiers.paid.name}</h3>
          <div class="price"><span class="amount">{c.tiers.paid.price}</span><span class="per">{c.tiers.paid.priceSuffix}</span></div>
        </div>
        <p class="tier-tag">{c.tiers.paid.tagline}</p>
        <ul>{c.tiers.paid.features.map((f) => <li>{f}</li>)}</ul>
        <a class="btn btn-primary" href={localizePath('/monitor/screening', lang)}>{c.tiers.paid.cta} <span class="arrow">&rarr;</span></a>
        <p class="tier-note">{c.tiers.paid.ctaNote}</p>
      </div>
    </div>
  </section>

  <section class="section wrap signup" id="signup">
    <div class="formcol">
      <form
        class="form"
        method="post"
        action={endpoint || undefined}
        data-monitor-form
        data-sending={c.sending}
        data-need-sector={c.needSector}
        data-updated-title={c.updatedTitle}
        data-updated-body={c.updatedBody}
        data-turnstile={turnstileKey ? 'on' : undefined}
      >
        <label>
          <span>{c.labels.email}</span>
          <input type="email" name="email" autocomplete="email" maxlength="180" required />
        </label>

        <fieldset class="sectors">
          <legend>{c.labels.sectors}</legend>
          {c.sectorList.map((s) => (
            <label class="check">
              <input type="checkbox" name="sectors" value={s.value} />
              <span>{s.label}</span>
            </label>
          ))}
        </fieldset>

        <label>
          <span>{c.labels.keywords}</span>
          <input type="text" name="keywords" maxlength="200" />
          <small class="hint">{c.keywordsHint}</small>
        </label>

        <div class="hp" aria-hidden="true">
          <label>Company URL
            <input type="text" name="company_url" tabindex="-1" autocomplete="off" />
          </label>
        </div>
        <input type="hidden" name="elapsed" value="" data-elapsed />

        {turnstileKey && <div class="cf-turnstile" data-sitekey={turnstileKey}></div>}
        {turnstileKey && <p class="verr" hidden data-verify-error>{c.verifyNeeded}</p>}
        <p class="verr" hidden data-need-error>{c.needSector}</p>
        <p class="verr" hidden data-send-error>{c.sendError}</p>

        <button class="btn btn-primary" type="submit">{c.submit} <span class="arrow">&rarr;</span></button>
        <p class="note eyebrow">{c.note}</p>
      </form>

      <div class="sent" hidden data-monitor-sent>
        <h2 data-sent-title>{c.sentTitle}</h2>
        <p data-sent-body>{c.sentBody}</p>
      </div>
    </div>
  </section>
</Base>

{turnstileKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  // fetch 제출: status(confirm/updated)·검증실패·오류를 서버 응답으로 구분해 표시한다.
  // 허니팟·최소 작성시간·Turnstile은 서버가 최종 강제하고, 여기서는 UX만 돕는다.
  const loadedAt = Date.now();
  const form = document.querySelector<HTMLFormElement>('[data-monitor-form]');
  const sent = document.querySelector<HTMLElement>('[data-monitor-sent]');
  const monitorCopy = {
    confirm: {
      title: document.querySelector<HTMLElement>('[data-sent-title]')?.textContent || '',
      body: document.querySelector<HTMLElement>('[data-sent-body]')?.textContent || '',
    },
    updated: {
      title: form?.getAttribute('data-updated-title') || '',
      body: form?.getAttribute('data-updated-body') || '',
    },
  };
  if (form && sent) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = form.querySelector<HTMLInputElement>('[name="company_url"]');
      if (hp && hp.value) return; // bot — silent no-op (server enforces too)
      const endpoint = form.getAttribute('action');
      if (!endpoint) return; // endpoint not set yet
      const verr = document.querySelector<HTMLElement>('[data-verify-error]');
      const nerr = document.querySelector<HTMLElement>('[data-need-error]');
      const serr = document.querySelector<HTMLElement>('[data-send-error]');
      // At least one sector or a keyword — mirror the server's 422.
      const sectors = form.querySelectorAll<HTMLInputElement>('[name="sectors"]:checked');
      const kw = form.querySelector<HTMLInputElement>('[name="keywords"]');
      if (sectors.length === 0 && !(kw && kw.value.trim())) {
        if (nerr) nerr.hidden = false;
        return;
      }
      if (nerr) nerr.hidden = true;
      if (form.dataset.turnstile) {
        const tok = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
        if (!tok || !tok.value) {
          if (verr) verr.hidden = false;
          return;
        }
        if (verr) verr.hidden = true;
      }
      if (serr) serr.hidden = true;
      const elapsed = form.querySelector<HTMLInputElement>('[data-elapsed]');
      if (elapsed) elapsed.value = String(Date.now() - loadedAt);
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const btnLabel = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.textContent = form.dataset.sending || 'Subscribing…'; }
      try {
        const res = await fetch(endpoint, { method: 'POST', body: new FormData(form) });
        const data = await res.json().catch(() => null);
        if (res.ok && data && data.ok) {
          if (data.status === 'updated' && monitorCopy.updated.title) {
            const th = sent.querySelector<HTMLElement>('[data-sent-title]');
            const bd = sent.querySelector<HTMLElement>('[data-sent-body]');
            if (th) th.textContent = monitorCopy.updated.title;
            if (bd) bd.textContent = monitorCopy.updated.body;
          }
          form.hidden = true;
          sent.hidden = false;
          sent.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        if (res.status === 403 && verr) verr.hidden = false;
        else if (serr) serr.hidden = false;
      } catch {
        if (serr) serr.hidden = false;
      }
      if (btn) { btn.disabled = false; btn.innerHTML = btnLabel; }
      const ts = (window as { turnstile?: { reset: () => void } }).turnstile;
      if (ts) ts.reset();
    });
  }
</script>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  [hidden] { display: none !important; }
  .copy { display: flex; flex-direction: column; gap: 1rem; max-width: 46ch; }
  .hero { max-width: 62ch; }
  .alt { color: var(--color-slate); }
  .alt a { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }

  .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn-ghost { background: transparent; border: 1px solid var(--color-recovered); color: var(--color-ink); }

  /* How it works — 3 steps */
  .sub-heading { font-size: var(--step-1); margin: clamp(2rem, 1rem + 3vw, 3.25rem) 0 1.25rem; }
  .steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 0.5rem + 2vw, 1.75rem); }
  .step { position: relative; display: flex; flex-direction: column; gap: 0.5rem; padding: 1.5rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .stepnum { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-vellum); background: var(--color-recovered); width: 1.7rem; height: 1.7rem; border-radius: 999px; display: grid; place-items: center; font-weight: 700; }
  .step h3 { font-size: var(--step-0); }
  .step p { font-size: var(--step--1); color: var(--color-slate); line-height: 1.55; margin: 0; }

  /* Sample screened alert — mock email */
  .mail { max-width: 46rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); overflow: hidden; }
  .mail-subject { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-ink); padding: 0.85rem 1.25rem; border-bottom: 1px solid var(--hairline); background: var(--color-vellum); }
  .mail-lines { list-style: none; margin: 0; padding: 0.5rem 0; }
  .mail-lines li { padding: 0.7rem 1.25rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .mail-lines li + li { border-top: 1px dashed var(--hairline); }
  .mline-head { display: flex; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
  .mline-name { font-weight: 600; color: var(--color-ink); }
  .mline-meta { font-family: var(--font-mono); font-size: var(--step--2); color: var(--color-slate); }
  .mline-verdict { font-size: var(--step--1); font-weight: 600; }
  .v-ok { color: #1a7f37; }
  .v-warn { color: #9a6700; }
  .v-no { color: #b3261e; }
  .mail-note { margin: 0; padding: 0.75rem 1.25rem; border-top: 1px solid var(--hairline); }

  /* Two-tier product comparison */
  .tiers-heading { font-size: var(--step-1); margin: clamp(2rem, 1rem + 3vw, 3.25rem) 0 1.25rem; }
  .tiers { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 0.5rem + 2vw, 1.75rem); align-items: stretch; }
  .tier { position: relative; display: flex; flex-direction: column; gap: 0.85rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .tier.featured { border-color: var(--color-recovered); box-shadow: 0 4px 18px rgba(20, 25, 31, 0.06); }
  .tier .badge { position: absolute; top: -0.7rem; right: 1.25rem; font-family: var(--font-mono); font-size: var(--step--2); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-vellum); background: var(--color-recovered); border-radius: 999px; padding: 0.2rem 0.6rem; }
  .tier-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
  .tier-head h3 { font-size: var(--step-1); }
  .tier .price { display: flex; align-items: baseline; gap: 0.3rem; }
  .tier .price .amount { font-size: var(--step-2); font-weight: 700; color: var(--color-ink); }
  .tier .price .per { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .tier-tag { font-weight: 600; color: var(--color-ink); }
  .tier ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .tier li { position: relative; padding-left: 1.3rem; font-size: var(--step-0); color: var(--color-slate); line-height: 1.5; }
  .tier li::before { content: '✓'; position: absolute; left: 0; color: var(--color-recovered); font-weight: 700; }
  .tier .btn { align-self: flex-start; margin-top: auto; }
  .tier-note { font-family: var(--font-mono); font-size: var(--step--2); color: var(--color-slate); margin: 0; }
  .signup .formcol { max-width: 34rem; }
  .form { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  label { display: flex; flex-direction: column; gap: 0.4rem; }
  label > span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  input[type="email"], input[type="text"] { font-family: var(--font-body); font-size: var(--step-0); color: var(--color-ink); background: var(--color-vellum); border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.7rem 0.85rem; }
  input:focus { outline: 2px solid var(--color-recovered); outline-offset: 1px; border-color: transparent; }
  .hint { font-size: var(--step--1); color: var(--color-slate); }
  fieldset.sectors { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.9rem 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1rem; margin: 0; }
  fieldset.sectors legend { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); padding: 0 0.4rem; }
  label.check { flex-direction: row; align-items: center; gap: 0.5rem; }
  label.check input { width: 1.05rem; height: 1.05rem; accent-color: var(--color-recovered); }
  label.check span { font-size: var(--step-0); color: var(--color-ink); }
  .form .btn { align-self: flex-start; }
  .note { margin-top: 0.25rem; }
  .verr { color: #b3261e; font-size: var(--step--1); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .sent { padding: 1.75rem; border: 1px solid var(--color-recovered); border-radius: var(--radius); background: var(--color-mist); display: flex; flex-direction: column; gap: 0.6rem; }
  .sent h2 { font-size: var(--step-1); }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } .tiers { grid-template-columns: 1fr; } .steps { grid-template-columns: 1fr; } fieldset.sectors { grid-template-columns: 1fr; } }
</style>
