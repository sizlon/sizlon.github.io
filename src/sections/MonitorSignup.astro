---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// The /monitor product page: hero → how it works → sample screened alert →
// two-tier comparison. Pure marketing — both applications live on their own
// pages (free → /monitor/free, paid → /monitor/screening), mirroring each other.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.monitor;
const freePath = localizePath('/monitor/free', lang);
const screeningPath = localizePath('/monitor/screening', lang);
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="section wrap">
    <div class="copy hero">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
      <div class="hero-ctas">
        <a class="btn btn-primary" href={freePath}>{c.heroCtaFree} <span class="arrow">&rarr;</span></a>
        <a class="btn btn-ghost" href={screeningPath}>{c.heroCtaPaid} <span class="arrow">&rarr;</span></a>
      </div>
      <p class="alt">{tr.contact.applyPrefix} <a href={`${localizePath('/verify-request', lang)}?src=monitor`}>{tr.contact.applyLink} &rarr;</a></p>
    </div>

    <div class="how">
      <h2 class="sub-heading">{c.how.heading}</h2>
      <ol class="steps">
        {c.how.steps.map((s, i) => (
          <li class="step">
            <span class="stepnum">{i + 1}</span>
            <h3>{s.t}</h3>
            <p>{s.b}</p>
          </li>
        ))}
      </ol>
    </div>

    <div class="sample">
      <h2 class="sub-heading">{c.sample.heading}</h2>
      <div class="mail">
        <div class="mail-subject">{c.sample.subject}</div>
        <ul class="mail-lines">
          {c.sample.lines.map((l) => (
            <li>
              <div class="mline-head"><span class="mline-name">{l.name}</span><span class="mline-meta">{l.meta}</span></div>
              <div class={`mline-verdict v-${l.kind}`}>{l.verdict}</div>
            </li>
          ))}
        </ul>
        <p class="mail-note eyebrow">{c.sample.note}</p>
      </div>
    </div>

    <h2 class="tiers-heading">{c.tiers.heading}</h2>
    <div class="tiers">
      <div class="tier">
        <div class="tier-head">
          <h3>{c.tiers.free.name}</h3>
          <div class="price"><span class="amount">{c.tiers.free.price}</span></div>
        </div>
        <p class="tier-tag">{c.tiers.free.tagline}</p>
        <ul>{c.tiers.free.features.map((f) => <li>{f}</li>)}</ul>
        <a class="btn btn-primary" href={freePath}>{c.tiers.free.cta} <span class="arrow">&rarr;</span></a>
      </div>
      <div class="tier featured">
        <span class="badge">{c.tiers.paid.badge}</span>
        <div class="tier-head">
          <h3>{c.tiers.paid.name}</h3>
          <div class="price"><span class="amount">{c.tiers.paid.price}</span><span class="per">{c.tiers.paid.priceSuffix}</span></div>
        </div>
        <p class="tier-tag">{c.tiers.paid.tagline}</p>
        <ul>{c.tiers.paid.features.map((f) => <li>{f}</li>)}</ul>
        <a class="btn btn-primary" href={screeningPath}>{c.tiers.paid.cta} <span class="arrow">&rarr;</span></a>
        <p class="tier-note">{c.tiers.paid.ctaNote}</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .copy { display: flex; flex-direction: column; gap: 1rem; max-width: 46ch; }
  .hero { max-width: 62ch; }
  .alt { color: var(--color-slate); }
  .alt a { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }
  .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .btn-ghost { background: transparent; border: 1px solid var(--color-recovered); color: var(--color-ink); }

  /* How it works — 3 steps */
  .sub-heading { font-size: var(--step-1); margin: clamp(2rem, 1rem + 3vw, 3.25rem) 0 1.25rem; }
  .steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(1rem, 0.5rem + 2vw, 1.75rem); }
  .step { position: relative; display: flex; flex-direction: column; gap: 0.5rem; padding: 1.5rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .stepnum { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-vellum); background: var(--color-recovered); width: 1.7rem; height: 1.7rem; border-radius: 999px; display: grid; place-items: center; font-weight: 700; }
  .step h3 { font-size: var(--step-0); }
  .step p { font-size: var(--step--1); color: var(--color-slate); line-height: 1.55; margin: 0; }

  /* Sample screened alert — mock email */
  .mail { max-width: 46rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); overflow: hidden; }
  .mail-subject { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-ink); padding: 0.85rem 1.25rem; border-bottom: 1px solid var(--hairline); background: var(--color-vellum); }
  .mail-lines { list-style: none; margin: 0; padding: 0.5rem 0; }
  .mail-lines li { padding: 0.7rem 1.25rem; display: flex; flex-direction: column; gap: 0.25rem; }
  .mail-lines li + li { border-top: 1px dashed var(--hairline); }
  .mline-head { display: flex; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
  .mline-name { font-weight: 600; color: var(--color-ink); }
  .mline-meta { font-family: var(--font-mono); font-size: var(--step--2); color: var(--color-slate); }
  .mline-verdict { font-size: var(--step--1); font-weight: 600; }
  .v-ok { color: #1a7f37; }
  .v-warn { color: #9a6700; }
  .v-no { color: #b3261e; }
  .mail-note { margin: 0; padding: 0.75rem 1.25rem; border-top: 1px solid var(--hairline); }

  /* Two-tier product comparison */
  .tiers-heading { font-size: var(--step-1); margin: clamp(2rem, 1rem + 3vw, 3.25rem) 0 1.25rem; }
  .tiers { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(1rem, 0.5rem + 2vw, 1.75rem); align-items: stretch; }
  .tier { position: relative; display: flex; flex-direction: column; gap: 0.85rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .tier.featured { border-color: var(--color-recovered); box-shadow: 0 4px 18px rgba(20, 25, 31, 0.06); }
  .tier .badge { position: absolute; top: -0.7rem; right: 1.25rem; font-family: var(--font-mono); font-size: var(--step--2); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-vellum); background: var(--color-recovered); border-radius: 999px; padding: 0.2rem 0.6rem; }
  .tier-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.75rem; flex-wrap: wrap; }
  .tier-head h3 { font-size: var(--step-1); }
  .tier .price { display: flex; align-items: baseline; gap: 0.3rem; }
  .tier .price .amount { font-size: var(--step-2); font-weight: 700; color: var(--color-ink); }
  .tier .price .per { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .tier-tag { font-weight: 600; color: var(--color-ink); }
  .tier ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .tier li { position: relative; padding-left: 1.3rem; font-size: var(--step-0); color: var(--color-slate); line-height: 1.5; }
  .tier li::before { content: '✓'; position: absolute; left: 0; color: var(--color-recovered); font-weight: 700; }
  .tier .btn { align-self: flex-start; margin-top: auto; }
  .tier-note { font-family: var(--font-mono); font-size: var(--step--2); color: var(--color-slate); margin: 0; }

  @media (max-width: 760px) { .tiers { grid-template-columns: 1fr; } .steps { grid-template-columns: 1fr; } }
</style>
