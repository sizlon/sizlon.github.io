---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';
// Self-serve eligibility profile (A2). The page reads ?token=<subscriber token>
// from the subscription/alert email, prefills via GET site.subscribeProfileEndpoint,
// and saves via POST. `company_url` is a honeypot. The token is the auth.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.monitor.profile;
const endpoint = site.subscribeProfileEndpoint;
---

<Base title={c.title} description={c.lede} lang={lang}>
  <section class="section wrap grid">
    <div class="copy">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
    </div>

    <div class="formcol">
      <form class="form" method="post" action={endpoint || undefined} data-profile-form data-sending={c.sending}>
        <input type="hidden" name="token" data-token />

        <label>
          <span>{c.labels.region}</span>
          <input type="text" name="region" maxlength="60" />
          <small class="hint">{c.hints.region}</small>
        </label>

        <label>
          <span>{c.labels.size}</span>
          <select name="size">
            <option value="">{c.sizePlaceholder}</option>
            {c.sizeList.map((s) => <option value={s.value}>{s.label}</option>)}
          </select>
        </label>

        <label>
          <span>{c.labels.licenses}</span>
          <textarea name="licenses" rows="3" maxlength="1000"></textarea>
          <small class="hint">{c.hints.licenses}</small>
        </label>

        <label>
          <span>{c.labels.track_record}</span>
          <textarea name="track_record" rows="3" maxlength="2000"></textarea>
          <small class="hint">{c.hints.track_record}</small>
        </label>

        <label>
          <span>{c.labels.grades}</span>
          <input type="text" name="grades" maxlength="200" />
          <small class="hint">{c.hints.grades}</small>
        </label>

        <label class="check">
          <input type="checkbox" name="clean" value="1" />
          <span>{c.labels.clean}</span>
        </label>

        <div class="hp" aria-hidden="true">
          <label>Company URL<input type="text" name="company_url" tabindex="-1" autocomplete="off" /></label>
        </div>

        <p class="verr" hidden data-token-error>{c.badToken}</p>
        <p class="verr" hidden data-send-error>{c.sendError}</p>

        <button class="btn btn-primary" type="submit">{c.submit} <span class="arrow">&rarr;</span></button>
        <p class="note eyebrow">{c.note}</p>
      </form>

      <div class="sent" hidden data-profile-sent>
        <h2>{c.sentTitle}</h2>
        <p>{c.sentBody}</p>
      </div>
    </div>
  </section>
</Base>

<script>
  // token from ?token=, prefill via GET, save via POST. The token is the auth.
  const form = document.querySelector<HTMLFormElement>('[data-profile-form]');
  const sent = document.querySelector<HTMLElement>('[data-profile-sent]');
  const tokenErr = document.querySelector<HTMLElement>('[data-token-error]');
  const serr = document.querySelector<HTMLElement>('[data-send-error]');
  const token = new URLSearchParams(location.search).get('token') || '';
  const endpoint = form?.getAttribute('action') || '';
  const set = (name: string, v: string) => {
    const el = form?.querySelector<HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement>(`[name="${name}"]`);
    if (el) el.value = v;
  };

  const tokenField = form?.querySelector<HTMLInputElement>('[data-token]');
  if (tokenField) tokenField.value = token;

  if (form && !token && tokenErr) tokenErr.hidden = false;

  // Prefill from the stored profile (token-authed GET).
  if (form && token && endpoint) {
    fetch(`${endpoint}?token=${encodeURIComponent(token)}`)
      .then((r) => (r.ok ? r.json() : null))
      .then((data) => {
        if (!data || !data.ok || !data.profile) {
          if (tokenErr) tokenErr.hidden = false;
          return;
        }
        const p = data.profile;
        set('region', p.region || '');
        set('size', p.size || '');
        set('licenses', Array.isArray(p.licenses) ? p.licenses.join('\n') : '');
        set('track_record', p.track_record || '');
        set('grades', p.grades && typeof p.grades === 'object'
          ? Object.entries(p.grades).map(([k, v]) => `${k}=${v}`).join(', ') : '');
        const clean = form.querySelector<HTMLInputElement>('[name="clean"]');
        if (clean) clean.checked = !!p.clean;
      })
      .catch(() => { if (tokenErr) tokenErr.hidden = false; });
  }

  if (form && sent) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = form.querySelector<HTMLInputElement>('[name="company_url"]');
      if (hp && hp.value) return; // bot
      if (!endpoint || !token) { if (tokenErr) tokenErr.hidden = false; return; }
      if (serr) serr.hidden = true;
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.textContent = form.dataset.sending || 'Saving…'; }
      try {
        const res = await fetch(endpoint, { method: 'POST', body: new FormData(form) });
        const data = await res.json().catch(() => null);
        if (res.ok && data && data.ok) {
          form.hidden = true;
          sent.hidden = false;
          sent.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        if (res.status === 404 && tokenErr) tokenErr.hidden = false;
        else if (serr) serr.hidden = false;
      } catch {
        if (serr) serr.hidden = false;
      }
      if (btn) { btn.disabled = false; btn.innerHTML = label; }
    });
  }
</script>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  [hidden] { display: none !important; }
  .copy { display: flex; flex-direction: column; gap: 1rem; max-width: 46ch; }
  .form { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  label { display: flex; flex-direction: column; gap: 0.4rem; }
  label > span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  input[type="text"], textarea, select { font-family: var(--font-body); font-size: var(--step-0); color: var(--color-ink); background: var(--color-vellum); border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.7rem 0.85rem; }
  input:focus, textarea:focus, select:focus { outline: 2px solid var(--color-recovered); outline-offset: 1px; border-color: transparent; }
  .hint { font-size: var(--step--1); color: var(--color-slate); }
  label.check { flex-direction: row; align-items: center; gap: 0.5rem; }
  label.check input { width: 1.05rem; height: 1.05rem; accent-color: var(--color-recovered); }
  label.check span { font-size: var(--step-0); color: var(--color-ink); }
  .form .btn { align-self: flex-start; }
  .note { margin-top: 0.25rem; }
  .verr { color: #b3261e; font-size: var(--step--1); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .sent { padding: 1.75rem; border: 1px solid var(--color-recovered); border-radius: var(--radius); background: var(--color-mist); display: flex; flex-direction: column; gap: 0.6rem; }
  .sent h2 { font-size: var(--step-1); }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
