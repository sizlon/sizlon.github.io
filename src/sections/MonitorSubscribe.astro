---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Paid tier checkout (A2 billing). Reads ?token=<subscriber token>, bootstraps the
// Toss Payments SDK via site.billingCheckoutEndpoint (clientKey + per-subscriber
// customerKey + amount), and starts requestBillingAuth. The success/fail redirects
// land on the localized billing pages, which POST to confirm. The token is the auth.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.monitor.subscribe;
const checkout = site.billingCheckoutEndpoint;
const cancelEndpoint = site.billingCancelEndpoint;
const successPath = localizePath('/bid-monitoring/billing/success', lang);
const failPath = localizePath('/bid-monitoring/billing/fail', lang);
---

<Base title={c.title} description={c.lede} lang={lang}>
  <section class="section wrap grid">
    <div class="copy">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
    </div>

    <div class="formcol">
      <div class="card" data-checkout
           data-checkout-endpoint={checkout || undefined}
           data-cancel-endpoint={cancelEndpoint || undefined}
           data-success-path={successPath} data-fail-path={failPath}
           data-price-suffix={c.priceSuffix} data-card-label={c.cardLabel}
           data-cancel-confirm={c.cancelConfirm} data-canceling={c.canceling}
           data-canceled-note={c.canceledNote} data-starting={c.starting}
           data-error={c.error}
           data-active-title={c.activeTitle} data-active-body={c.activeBody}
           data-pastdue-title={c.pastDueTitle} data-pastdue-body={c.pastDueBody}
           data-canceled-title={c.canceledTitle} data-canceled-body={c.canceledBody}>

        <div class="beta-note" role="note">
          <strong>{tr.monitor.beta.title}</strong>
          <p>{tr.monitor.beta.body}</p>
        </div>

        <p class="loading" data-loading>{c.loading}</p>

        <div class="price" hidden data-price-row>
          <span class="amount" data-price></span>
          <span class="per" data-price-suffix-el></span>
        </div>

        <div class="pay" hidden data-pay-view>
          <button class="btn btn-primary" type="button" data-subscribe-btn>{c.subscribe} <span class="arrow">&rarr;</span></button>
          <p class="note eyebrow">{c.priceNote}</p>
          <p class="note eyebrow">{c.refundNote} · <a class="terms" href={localizePath('/legal/terms', lang)}>{c.termsLabel}</a></p>
        </div>

        <div class="status" hidden data-status-view>
          <h2 data-status-title></h2>
          <p data-status-body></p>
          <p class="cardline" hidden data-card-line></p>
          <button class="btn btn-line" type="button" hidden data-cancel-btn>{c.cancel}</button>
        </div>

        <p class="verr" hidden data-bad-token>{c.badToken}</p>
        <p class="verr" hidden data-disabled>{c.disabled}</p>
        <p class="verr" hidden data-error-msg>{c.error}</p>
      </div>
    </div>
  </section>
</Base>

<script is:inline src="https://js.tosspayments.com/v2/standard"></script>
<script>
  const root = document.querySelector<HTMLElement>('[data-checkout]');
  const token = new URLSearchParams(location.search).get('token') || '';
  const d = (k: string) => root?.dataset[k] || '';
  const show = (sel: string, on = true) => {
    const el = root?.querySelector<HTMLElement>(`[data-${sel}]`);
    if (el) el.hidden = !on;
  };
  const fmtDate = (iso: string | null) => (iso ? iso.slice(0, 10) : '');

  const checkoutEndpoint = root?.dataset.checkoutEndpoint || '';
  const cancelEndpoint = root?.dataset.cancelEndpoint || '';
  let clientKey = '', customerKey = '', email = '';

  function fail(kind: 'badToken' | 'disabled' | 'errorMsg') {
    show('loading', false);
    show(kind === 'badToken' ? 'bad-token' : kind === 'disabled' ? 'disabled' : 'error-msg', true);
  }

  function renderStatus(status: string, paidUntil: string | null, card: string) {
    show('loading', false);
    const view = root?.querySelector<HTMLElement>('[data-status-view]');
    const title = root?.querySelector<HTMLElement>('[data-status-title]');
    const body = root?.querySelector<HTMLElement>('[data-status-body]');
    const cardLine = root?.querySelector<HTMLElement>('[data-card-line]');
    const cancelBtn = root?.querySelector<HTMLButtonElement>('[data-cancel-btn]');
    const map: Record<string, [string, string]> = {
      active: [d('activeTitle'), d('activeBody')],
      past_due: [d('pastdueTitle'), d('pastdueBody')],
      canceled: [d('canceledTitle'), d('canceledBody')],
    };
    const [tt, bb] = map[status] || map.active;
    if (title) title.textContent = tt;
    if (body) body.textContent = bb.replace('{date}', fmtDate(paidUntil));
    if (cardLine && card) { cardLine.textContent = `${d('cardLabel')}: ${card}`; cardLine.hidden = false; }
    if (cancelBtn && (status === 'active' || status === 'past_due')) cancelBtn.hidden = false;
    if (view) view.hidden = false;
    // Canceled but still in paid period: let them re-subscribe too.
    if (status === 'canceled') showPay();
  }

  function showPay() {
    show('loading', false);
    show('pay-view', true);
  }

  async function startCheckout() {
    const btn = root?.querySelector<HTMLButtonElement>('[data-subscribe-btn]');
    const Toss = (window as any).TossPayments;
    if (!Toss || !clientKey) { fail('errorMsg'); return; }
    if (btn) { btn.disabled = true; btn.textContent = d('starting'); }
    try {
      const payment = Toss(clientKey).payment({ customerKey });
      await payment.requestBillingAuth({
        method: 'CARD',
        successUrl: `${location.origin}${d('successPath')}?token=${encodeURIComponent(token)}`,
        failUrl: `${location.origin}${d('failPath')}?token=${encodeURIComponent(token)}`,
        customerEmail: email || undefined,
      });
    } catch {
      // user closed the window or SDK error — restore the button
      if (btn) { btn.disabled = false; btn.innerHTML = ''; }
      location.reload();
    }
  }

  async function cancelSub() {
    const btn = root?.querySelector<HTMLButtonElement>('[data-cancel-btn]');
    if (!confirm(d('cancelConfirm'))) return;
    if (btn) { btn.disabled = true; btn.textContent = d('canceling'); }
    try {
      const fd = new FormData(); fd.append('token', token);
      const res = await fetch(cancelEndpoint, { method: 'POST', body: fd });
      const data = await res.json().catch(() => null);
      if (res.ok && data && data.ok) {
        const body = root?.querySelector<HTMLElement>('[data-status-body]');
        const title = root?.querySelector<HTMLElement>('[data-status-title]');
        if (title) title.textContent = d('canceledTitle');
        if (body) body.textContent = d('canceledBody').replace('{date}', fmtDate(data.paidUntil));
        if (btn) btn.hidden = true;
        showPay();
      } else if (btn) { btn.disabled = false; btn.textContent = 'Cancel'; }
    } catch {
      if (btn) { btn.disabled = false; btn.textContent = 'Cancel'; }
    }
  }

  async function boot() {
    if (!token) { fail('badToken'); return; }
    if (!checkoutEndpoint) { fail('disabled'); return; }
    let res: Response;
    try {
      res = await fetch(`${checkoutEndpoint}?token=${encodeURIComponent(token)}`);
    } catch { fail('errorMsg'); return; }
    if (res.status === 503) { fail('disabled'); return; }
    if (res.status === 404) { fail('badToken'); return; }
    const data = await res.json().catch(() => null);
    if (!res.ok || !data || !data.ok) { fail('errorMsg'); return; }
    clientKey = data.clientKey; customerKey = data.customerKey; email = data.email || '';
    const priceEl = root?.querySelector<HTMLElement>('[data-price]');
    const sufEl = root?.querySelector<HTMLElement>('[data-price-suffix-el]');
    if (priceEl) priceEl.textContent = `₩${Number(data.amount).toLocaleString()}`;
    if (sufEl) sufEl.textContent = d('priceSuffix');
    show('price-row', true);
    if (data.status === 'active' || data.status === 'past_due' || data.status === 'canceled') {
      renderStatus(data.status, data.paidUntil, data.card || '');
    } else {
      showPay();
    }
    root?.querySelector('[data-subscribe-btn]')?.addEventListener('click', startCheckout);
    root?.querySelector('[data-cancel-btn]')?.addEventListener('click', cancelSub);
  }

  boot();
</script>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  [hidden] { display: none !important; }
  .copy { display: flex; flex-direction: column; gap: 1rem; max-width: 46ch; }
  .card { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .beta-note { border: 1px solid #9a6700; border-radius: var(--radius); background: color-mix(in srgb, #9a6700 7%, var(--color-vellum)); padding: 0.9rem 1.1rem; }
  .beta-note strong { color: #9a6700; font-size: var(--step--1); }
  .beta-note p { font-size: var(--step--1); color: var(--color-slate); margin: 0.3rem 0 0; }
  .loading { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .price { display: flex; align-items: baseline; gap: 0.4rem; }
  .price .amount { font-size: var(--step-3); font-weight: 700; color: var(--color-ink); }
  .price .per { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .pay { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
  .note { margin: 0; }
  .terms { color: var(--color-ink); text-decoration: underline; text-underline-offset: 3px; }
  .status { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
  .status h2 { font-size: var(--step-1); }
  .cardline { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .btn-line { background: transparent; border: 1px solid var(--hairline); color: var(--color-slate); }
  .verr { color: #b3261e; font-size: var(--step--1); }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
