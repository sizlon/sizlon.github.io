---
import Base from '../layouts/Base.astro';
import StrategyLadder from '../components/StrategyLadder.astro';
import { crawlerPages } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.product;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
    <div class="cta-row">
      <a class="btn btn-primary" href={`${localizePath('/contact', lang)}?topic=demo`}>{tr.common.requestDemo} <span class="arrow">&rarr;</span></a>
      <a class="btn btn-ghost" href={localizePath('/how-it-works', lang)}>{c.ctaHeal}</a>
    </div>
  </section>

  <section class="section wrap">
    <ul class="caps">
      {c.caps.map((cap) => (
        <li class="cap">
          <h3>{cap.name}</h3>
          <p>{cap.text}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="section wrap ladder-section">
    <div class="ladder-copy">
      <span class="eyebrow">{c.ladderEyebrow}</span>
      <h2>{c.ladderH2}</h2>
      <p class="lede">{c.ladderLede}</p>
      <a class="btn btn-ghost" href={localizePath('/how-it-works', lang)}>{c.ladderBtn}</a>
    </div>
    <StrategyLadder lang={lang} />
  </section>

  <section class="section wrap deploy">
    <div class="deploy-copy">
      <span class="eyebrow">{c.deployEyebrow}</span>
      <h2>{c.deployH2}</h2>
      <p class="lede">{c.deployLede}</p>
    </div>
    <ul class="deploy-points">
      {c.deployPoints.map((pt) => (
        <li>
          <h3>{pt.name}</h3>
          <p>{pt.text}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="section wrap model">
    <span class="eyebrow">{c.modelEyebrow}</span>
    <p class="model-note">
      {c.modelNote} <a href={localizePath('/editions', lang)}>{c.compareEditions} &rarr;</a>
    </p>
  </section>

  <section class="section wrap more">
    <span class="eyebrow">{c.moreOn}</span>
    <nav class="more-links" aria-label={c.moreOn}>
      {crawlerPages.map((p) => (
        <a href={localizePath(p.href, lang)}>{tr.nav[p.key]} <span class="arrow">&rarr;</span></a>
      ))}
    </nav>
  </section>
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .caps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; }
  .cap { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 1.5rem; background: var(--color-mist); display: flex; flex-direction: column; gap: 0.5rem; }
  .ladder-section { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .ladder-copy { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .deploy { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .deploy-copy { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .deploy-points { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .deploy-points li { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 1.25rem 1.5rem; background: var(--color-mist); display: flex; flex-direction: column; gap: 0.5rem; }
  .deploy-points p { font-size: var(--step--1); }
  .model { max-width: var(--measure); }
  .model-note { font-size: var(--step-1); }
  .model-note a { color: var(--color-ink); font-weight: 600; text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; white-space: nowrap; }
  .more { display: flex; flex-direction: column; gap: 1rem; border-top: 1px solid var(--hairline); }
  .more-links { display: flex; gap: 1.5rem; flex-wrap: wrap; }
  .more-links a { font-weight: 600; font-size: var(--step--1); text-decoration: none; color: var(--color-ink); }
  .more-links a:hover .arrow { transform: translateX(3px); }
  .more-links .arrow { display: inline-block; transition: transform 0.15s ease; color: var(--color-recovered); }
  @media (max-width: 760px) { .ladder-section, .deploy, .deploy-points { grid-template-columns: 1fr; } }
</style>
