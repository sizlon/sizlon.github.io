---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Multi-step Miriboa verification intake (CONTEXT §94 → wizard). Steps:
//   1 Notice (공고번호 → auto-fill from parse.sizlon.io)
//   2 Your details + PIPA consent + Turnstile  → creates a DRAFT (server row + token)
//   3 Bid documents (required) — upload + inline precheck
//   4 NDA / confidentiality agreement (required) → finalize (upload + draft→received)
//   5 Done
// A draft persists from step 2, resumable via the emailed manage link or magic-link
// login (/manage). Documents can be replaced/deleted later from the manage page.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.verifyRequest;
const turnstileKey = site.turnstileSiteKey;
const privacyHref = localizePath('/legal/privacy', lang);
const termsHref = localizePath('/legal/terms', lang);
const stepKeys = ['notice', 'who', 'docs', 'nda', 'done'] as const;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="section wrap grid">
    <div class="copy">
      <span class="eyebrow">{c.eyebrow}</span>
      <h1>{c.h1}</h1>
      <p class="lede">{c.lede}</p>
      <div class="price">
        <span class="ph eyebrow">{c.price.heading}</span>
        <ul>
          <li class="free"><strong>{c.price.first}</strong><span>{c.price.firstNote}</span></li>
          <li>{c.price.standard}</li>
          <li>{c.price.express}</li>
        </ul>
        <p class="refund">{c.price.refund}</p>
      </div>
      <p class="alt">{c.returning} <a href={localizePath('/manage', lang)}>{c.returningLink} &rarr;</a></p>
      <p class="alt">{c.altPrefix} <a href={localizePath('/contact', lang)}>{c.altQuestion}</a></p>
    </div>

    <div class="formcol">
      <ol class="progress" aria-label="Steps">
        {stepKeys.map((k, i) => (
          <li class="pstep" data-pstep={i + 1}><span class="pnum">{i + 1}</span>{c.steps[k]}</li>
        ))}
      </ol>

      <form
        class="form" data-verify-form
        data-notice-endpoint={site.noticeLookupEndpoint}
        data-draft-endpoint={site.verifyDraftEndpoint}
        data-manage-base={site.manageBase}
        data-precheck-endpoint={site.precheckEndpoint}
        data-doc-badges={JSON.stringify(c.docs.badges)}
        data-doc-remove={c.docs.remove}
        data-manage-path={localizePath('/manage', lang)}
        data-profile-endpoint={site.accountProfileEndpoint}
        data-auth-verify={site.authVerifyEndpoint}
        data-auth-set-password={site.authSetPasswordEndpoint}
        data-turnstile={turnstileKey ? 'on' : undefined}
      >
        <!-- STEP 1 · Notice -->
        <fieldset class="step" data-step="1">
          <legend>{c.notice.heading}</legend>
          <label>
            <span>{c.notice.no}</span>
            <input type="text" name="notice" maxlength="80" autocomplete="off" data-field-notice />
            <small class="hint">{c.notice.noHint}</small>
          </label>
          <p class="lookup-status" hidden data-lookup-looking>{c.notice.looking}</p>
          <p class="lookup-warn" role="status" hidden data-lookup-notfound>{c.notice.notFound}</p>
          <dl class="notice-auto" hidden data-notice-auto>
            <div><dt>{c.notice.nameLabel}</dt><dd data-auto-name></dd></div>
            <div><dt>{c.notice.deadlineLabel}</dt><dd data-auto-deadline></dd></div>
            <div><dt>{c.notice.institutionLabel}</dt><dd data-auto-institution></dd></div>
            <div><dt>{c.stakesLabel}</dt><dd data-auto-stakes></dd></div>
          </dl>
          <input type="hidden" name="notice_name" data-field-notice-name />
          <input type="hidden" name="deadline" data-field-deadline />
          <input type="hidden" name="institution" data-field-institution />
          <input type="hidden" name="stakes" data-field-stakes />
          <input type="hidden" name="src" value="site" data-field-src />
          <p class="verr" role="alert" hidden data-step-error="1">{c.notice.notFound}</p>
          <div class="wnav"><button type="button" class="btn btn-primary" data-next="1" disabled>{c.next} <span class="arrow">&rarr;</span></button></div>
        </fieldset>

        <!-- STEP 2 · Your details + consent -->
        <fieldset class="step" data-step="2" hidden>
          <legend>{c.who.heading}</legend>
          <p class="fillme" hidden data-fill>
            <select class="fillsel" hidden data-fill-select aria-label={c.fillMe}></select>
            <button type="button" class="linklike" data-fill-btn>{c.fillMe}</button>
            <span class="filled" hidden data-fill-note>{c.filled} · <button type="button" class="linklike" data-fill-clear>{c.clear}</button></span>
          </p>
          <label><span>{c.who.company}</span>
            <input type="text" name="company" autocomplete="organization" maxlength="160" /></label>
          <label><span>{c.who.brn}</span>
            <input type="text" name="brn" inputmode="numeric" autocomplete="off" maxlength="12" placeholder="123-45-67890" data-brn aria-describedby="brn-hint brn-err" />
            <small class="hint" id="brn-hint">{c.who.brnHint}</small>
            <small class="verr" id="brn-err" role="alert" hidden data-brn-error>{c.brnInvalid}</small></label>
          <label><span>{c.who.person}</span>
            <input type="text" name="person" autocomplete="name" maxlength="80" /></label>
          <label><span>{c.who.phone}</span>
            <input type="tel" name="phone" autocomplete="tel" inputmode="numeric" maxlength="20" placeholder="01012345678" data-phone /></label>
          <label><span>{c.who.email}</span>
            <input type="email" name="email" autocomplete="email" maxlength="180" />
            <small class="hint">{c.emailVerifyNote}</small></label>
          <label><span>{c.noteLabel}</span>
            <textarea name="note" rows="2" maxlength="2000" placeholder={c.notePlaceholder}></textarea></label>

          <label class="check consent-check">
            <input type="checkbox" name="consent" data-consent />
            <span class="checktext">
              <span class="checklabel">{c.consentAgree}</span>
              <small class="hint consent-detail">{c.consent} <a href={privacyHref}>{c.consentLink}</a>{lang === 'ko' ? '' : ' '}{c.consentAfter}</small>
            </span>
          </label>

          <div class="hp" aria-hidden="true">
            <label>Company URL<input type="text" name="company_url" tabindex="-1" autocomplete="off" /></label>
          </div>
          <input type="hidden" name="elapsed" value="" data-elapsed />

          {turnstileKey && <div class="cf-turnstile" data-sitekey={turnstileKey} data-callback="onTurnstile" data-expired-callback="offTurnstile" data-error-callback="offTurnstile"></div>}
          {turnstileKey && <p class="verr" role="alert" hidden data-verify-error>{c.verifyNeeded}</p>}
          <p class="verr" role="alert" hidden data-step-error="2">{c.sendError} <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p>

          <div class="wnav">
            <button type="button" class="btn btn-ghost" data-back="2">&larr; {c.back}</button>
            <button type="button" class="btn btn-primary" data-next="2" disabled>{c.next} <span class="arrow">&rarr;</span></button>
          </div>
        </fieldset>

        <!-- STEP 3 · Documents -->
        <fieldset class="step" data-step="3" hidden>
          <legend>{c.docs.heading}</legend>
          <p class="hint">{c.docs.intro}</p>
          <label class="drop" tabindex="0" data-drop>
            <span class="drop-big">{c.docs.dropBig}</span>
            <span class="hint">{c.docs.dropHint}</span>
            <input type="file" multiple accept=".hwp,.hwpx,.pdf,.docx,.xlsx,.xlsm,.txt,.md" data-docs-input />
          </label>
          <p class="lookup-status" hidden data-docs-checking>{c.docs.checking}</p>
          <ul class="filelist" data-filelist></ul>
          <p class="verr" role="alert" hidden data-docs-error>{c.docs.required}</p>

          <p class="verr" role="alert" hidden data-step-error="3">{c.sendError} <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p>
          <div class="wnav">
            <button type="button" class="btn btn-ghost" data-back="3">&larr; {c.back}</button>
            <button type="button" class="btn btn-primary" data-next="3" disabled>{c.next} <span class="arrow">&rarr;</span></button>
          </div>
        </fieldset>

        <!-- STEP 4 · NDA / confidentiality agreement -->
        <fieldset class="step" data-step="4" hidden>
          <legend>{c.nda.heading}</legend>
          <p class="hint nda-intro">{c.nda.intro} <button type="button" class="linklike" data-nda-open>{c.nda.link}</button>.</p>
          <label class="check consent-check">
            <input type="checkbox" name="nda" data-nda />
            <span class="checktext"><span class="checklabel">{c.nda.agree}</span></span>
          </label>
          <p class="verr" role="alert" hidden data-nda-error>{c.nda.required}</p>
          <p class="verr" role="alert" hidden data-step-error="4">{c.sendError} <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a></p>
          <p class="verr" role="alert" hidden data-no-credit>{c.noCredit} <a href={localizePath('/bid-verification/credits', lang)}>{c.noCreditCta} &rarr;</a></p>
          <div class="wnav">
            <button type="button" class="btn btn-ghost" data-back="4">&larr; {c.back}</button>
            <button type="button" class="btn btn-primary" data-submit disabled>{c.submitFinal} <span class="arrow">&rarr;</span></button>
          </div>
        </fieldset>

        <p class="note eyebrow">{c.note}</p>
        <p class="legalnote">{c.legalNote}</p>
      </form>

      <div class="sent" tabindex="-1" hidden data-verify-sent>
        <h2>{c.sentTitle}</h2>
        <p hidden data-sent-first>{c.sentFirst}</p>
        <p hidden data-sent-first-express>{c.sentFirstExpress}</p>
        <p hidden data-sent-returning>{c.sentReturning}</p>
        <p class="sent-manage" hidden data-sent-manage><a data-sent-manage-link href="">{c.sentManage} <span class="arrow">&rarr;</span></a></p>
      </div>

      <!-- 신규/미인증 이메일: 확인 메일 안내(진행 차단) -->
      <div class="sent" tabindex="-1" hidden data-check-email>
        <h2>{c.checkEmailTitle}</h2>
        <p>{c.checkEmailBody}</p>
      </div>

      <!-- 이메일 링크 재진입: 비밀번호 생성(더블 입력) -->
      <div class="sent pwgate" tabindex="-1" hidden data-pwgate>
        <h2>{c.pwCreateTitle}</h2>
        <p class="hint">{c.pwCreateIntro}</p>
        <form class="pwform" data-pwgate-form>
          <label><span>{c.pwNew}</span>
            <input type="password" name="pw1" autocomplete="new-password" minlength="8" maxlength="200" required /></label>
          <label><span>{c.pwConfirm}</span>
            <input type="password" name="pw2" autocomplete="new-password" minlength="8" maxlength="200" required /></label>
          <button type="submit" class="btn btn-primary">{c.pwCreateBtn} <span class="arrow">&rarr;</span></button>
          <p class="verr" role="alert" hidden data-pw-mismatch>{c.pwMismatch}</p>
          <p class="verr" role="alert" hidden data-pw-error>{c.pwError}</p>
        </form>
      </div>
    </div>
  </section>

  <dialog class="nda-modal" data-nda-modal>
    <article>
      <header>
        <h2>{c.nda.docTitle}</h2>
        <button type="button" class="nda-close" data-nda-close aria-label={c.nda.close}>&times;</button>
      </header>
      <div class="nda-body">
        {c.nda.doc.map((p) => (<p>{p}</p>))}
      </div>
      <footer>
        <a href={termsHref} target="_blank" rel="noopener">{c.nda.fullTerms} &rarr;</a>
        <button type="button" class="btn btn-primary" data-nda-agree>{c.nda.agreeBtn}</button>
      </footer>
    </article>
  </dialog>
</Base>

{turnstileKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  const loadedAt = Date.now();
  const form = document.querySelector('[data-verify-form]');
  const sent = document.querySelector('[data-verify-sent]');
  if (form && sent) {
    const q = new URLSearchParams(location.search);
    const noticeEndpoint = form.getAttribute('data-notice-endpoint');
    const draftEndpoint = form.getAttribute('data-draft-endpoint');
    const manageBase = form.getAttribute('data-manage-base');
    const precheckEndpoint = form.getAttribute('data-precheck-endpoint');
    const managePath = form.getAttribute('data-manage-path') || '/manage';
    let docBadges = {};
    try { docBadges = JSON.parse(form.getAttribute('data-doc-badges') || '{}'); } catch { docBadges = {}; }
    const docRemove = form.getAttribute('data-doc-remove') || 'Remove';
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const $ = (s) => form.querySelector(s);
    let token = '';
    let resuming = false, resumeHasDocs = false, pendingResume = null;   // draft 재개 상태

    // ── step navigation ──
    const steps = [...form.querySelectorAll('.step')];
    const psteps = [...document.querySelectorAll('[data-pstep]')];
    let cur = 1;
    function showStep(n) {
      cur = n;
      steps.forEach((s) => { s.hidden = Number(s.getAttribute('data-step')) !== n; });
      psteps.forEach((p) => {
        const i = Number(p.getAttribute('data-pstep'));
        p.classList.toggle('active', i === n);
        p.classList.toggle('done', i < n);
      });
      const top = form.closest('.formcol');
      if (top && top.scrollIntoView) top.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (n === 2) { autoFillStep2(); refreshStep2(); } else if (n === 3) refreshStep3(); else if (n === 4) refreshStep4();
    }
    const stepErr = (n) => form.querySelector('[data-step-error="' + n + '"]');

    // ── 신원 확정: 미인증 이메일 안내 / 이메일 링크 재진입(비번 생성) ──
    const authVerify = form.getAttribute('data-auth-verify');
    const authSetPassword = form.getAttribute('data-auth-set-password');
    const checkEmail = document.querySelector('[data-check-email]');
    const pwgate = document.querySelector('[data-pwgate]');
    function showCheckEmail() {
      form.hidden = true;
      if (checkEmail) { checkEmail.hidden = false; checkEmail.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    }
    function showPwgate() {
      form.hidden = true;
      if (pwgate) { pwgate.hidden = false; pwgate.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
    }
    // draft 데이터를 불러와 1·2단계를 채운다(재개 시 앞/뒤 단계 이동·편집 가능).
    async function fetchDraft(resume) {
      const s = localStorage.getItem('miriboa_session');
      const res = await fetch(manageBase + '/' + encodeURIComponent(resume) + '/draft', { headers: s ? { Authorization: 'Bearer ' + s } : {} });
      const d = await res.json().catch(() => null);
      return (res.ok && d && d.ok) ? d : null;
    }
    function rehydrateDraft(d) {
      // step 1: 공고
      if (noticeInput) noticeInput.value = d.notice_no || '';
      setText(aName, d.notice_name); setText(aDeadline, d.deadline);
      setText(aInstitution, d.institution); setText(aStakes, d.stakes);
      if (hName) hName.value = d.notice_name || '';
      if (hDeadline) hDeadline.value = d.deadline || '';
      if (hInstitution) hInstitution.value = d.institution || '';
      if (hStakes) hStakes.value = (d.stakes || '').slice(0, 200);
      if (auto) auto.hidden = false;
      setNoticeOk(!!(d.notice_no));
      // step 2: 고객 정보
      setVal('company', d.company);
      if (brnInput) brnInput.value = formatBrn(d.brn);
      setVal('person', d.person);
      if (phoneInput) phoneInput.value = String(d.phone || '').replace(/\D/g, '');
      setVal('email', d.email);
      setVal('note', d.note);
      refreshStep2();
    }
    function enterResumeAtDocs(resume, d) {
      rehydrateDraft(d);
      resuming = true; resumeHasDocs = Number(d.doc_count) > 0; token = resume;
      const tw = form.querySelector('.cf-turnstile'); if (tw) tw.hidden = true;   // 재개엔 Turnstile 불필요
      // step1부터 열어 채워진 단계를 훑으며 진행/편집(앞·뒤 이동)하게 한다.
      form.hidden = false; showStep(1);
    }
    async function resumeFlow(login, resume) {
      form.hidden = true;                                    // 검증 전 깜빡임 방지
      try {
        const fd = new FormData(); fd.append('token', login);
        const res = await fetch(authVerify, { method: 'POST', body: fd, credentials: 'include' });
        const d = await res.json().catch(() => null);
        if (!(res.ok && d && d.ok && d.session)) { form.hidden = false; showStep(1); return; }
        localStorage.setItem('miriboa_session', d.session);
        history.replaceState(null, '', location.pathname);   // 링크에서 토큰 제거
        const dd = await fetchDraft(resume);
        if (!dd) { form.hidden = false; showStep(1); return; }   // draft 없음/무효
        if (d.has_password) enterResumeAtDocs(resume, dd);       // 이미 비번 있으면 바로
        else { pendingResume = { resume, dd }; showPwgate(); }   // 없으면 비번 생성 후
      } catch { form.hidden = false; showStep(1); }
    }
    const pwgateForm = pwgate && pwgate.querySelector('[data-pwgate-form]');
    if (pwgateForm) pwgateForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const mis = pwgate.querySelector('[data-pw-mismatch]'), perr = pwgate.querySelector('[data-pw-error]');
      if (mis) mis.hidden = true; if (perr) perr.hidden = true;
      const p1 = pwgateForm.querySelector('[name="pw1"]').value, p2 = pwgateForm.querySelector('[name="pw2"]').value;
      if (p1.length < 8 || p1 !== p2) { if (mis) mis.hidden = false; return; }
      const session = localStorage.getItem('miriboa_session');
      if (!session) { showStep(1); return; }
      const btn = pwgateForm.querySelector('button'); btn.disabled = true;
      try {
        const fd = new FormData(); fd.append('password', p1);
        const res = await fetch(authSetPassword, { method: 'POST', body: fd, headers: { Authorization: 'Bearer ' + session } });
        const d = await res.json().catch(() => null);
        if (res.ok && d && d.ok) {
          pwgate.hidden = true;
          if (pendingResume) enterResumeAtDocs(pendingResume.resume, pendingResume.dd);
          else { form.hidden = false; showStep(3); }
        } else if (perr) perr.hidden = false;
      } catch { if (perr) perr.hidden = false; }
      btn.disabled = false;
    });

    // 이어받기(로그인 없이 token만): draft면 재개(1·2 채움→서류), 접수건이면 관리로.
    async function capabilityResume(resume) {
      form.hidden = true;
      try {
        const dd = await fetchDraft(resume);
        if (dd) { enterResumeAtDocs(resume, dd); return; }
        // draft 아님 — 접수건이면 관리로, 아니면 새 폼
        const r2 = await fetch(manageBase + '/' + encodeURIComponent(resume));
        const d2 = await r2.json().catch(() => null);
        if (r2.ok && d2 && d2.ok && d2.status === 'received') { location.href = managePath + '?t=' + encodeURIComponent(resume); return; }
      } catch {}
      form.hidden = false; showStep(1);   // 못 찾음/무효 → 새 폼
    }

    const loginQ = q.get('login'), resumeQ = q.get('resume');
    if (loginQ && resumeQ && authVerify) resumeFlow(loginQ, resumeQ);
    else if (resumeQ) capabilityResume(resumeQ);
    else showStep(1);

    // ── STEP 1: 공고 자동채움 ──
    const noticeInput = $('[data-field-notice]');
    const auto = $('[data-notice-auto]'), looking = $('[data-lookup-looking]'), notfound = $('[data-lookup-notfound]');
    const hName = $('[data-field-notice-name]'), hDeadline = $('[data-field-deadline]'), hInstitution = $('[data-field-institution]'), hStakes = $('[data-field-stakes]');
    const aName = $('[data-auto-name]'), aDeadline = $('[data-auto-deadline]'), aInstitution = $('[data-auto-institution]'), aStakes = $('[data-auto-stakes]');
    const setText = (el, v) => { if (el) el.textContent = v || '—'; };
    const next1 = $('[data-next="1"]');
    // 공고가 실제로 추출됐을 때만 '다음'이 활성화된다. 번호가 바뀌면 즉시 다시 비활성.
    const setNoticeOk = (ok) => { if (next1) next1.disabled = !ok; };
    let lookSeq = 0;
    let lastOkNo = '';   // 마지막으로 성공 조회된 번호 — blur 재조회 가드
    async function lookupNotice(no) {
      no = (no || '').trim();
      // 같은 번호가 이미 성공 조회된 상태면 재조회하지 않는다. 특히 '다음' 클릭
      // 직전의 blur 가 재조회를 돌리면 setNoticeOk(false)로 버튼이 꺼져 첫
      // 클릭이 씹히는 버그(클릭보다 blur 가 먼저 발생)가 있었다.
      if (no && no === lastOkNo) return;
      if (notfound) notfound.hidden = true;
      setNoticeOk(false);
      if (!no || !noticeEndpoint) { if (auto) auto.hidden = true; return; }
      const seq = ++lookSeq;
      if (looking) looking.hidden = false;
      try {
        const res = await fetch(noticeEndpoint + '?no=' + encodeURIComponent(no));
        const d = await res.json().catch(() => null);
        if (seq !== lookSeq) return;
        if (looking) looking.hidden = true;
        if (d && d.found) {
          setText(aName, d.name); setText(aDeadline, d.deadline);
          setText(aInstitution, d.institution); setText(aStakes, d.stakes);
          if (hName) hName.value = d.name || '';
          if (hDeadline) hDeadline.value = d.deadline || '';
          if (hInstitution) hInstitution.value = d.institution || '';
          if (hStakes) hStakes.value = (d.stakes || '').slice(0, 200);
          if (auto) auto.hidden = false;
          if (d.no && noticeInput && d.no !== no) noticeInput.value = d.no;
          lastOkNo = (noticeInput && noticeInput.value.trim()) || no;
          setNoticeOk(true);
        } else {
          if (auto) auto.hidden = true;
          if (notfound) notfound.hidden = false;
        }
      } catch { if (seq === lookSeq && looking) looking.hidden = true; }
    }
    let lookTimer;
    if (noticeInput) {
      // 붙여넣기는 완성된 번호가 한 번에 들어오므로 450ms 디바운스를 건너뛴다
      // (원천 g2b가 초 단위로 느린 날엔 0.5초도 아깝다).
      let pasted = false;
      noticeInput.addEventListener('paste', () => { pasted = true; });
      noticeInput.addEventListener('input', () => {
        const v = noticeInput.value.trim();
        clearTimeout(lookTimer);
        const delay = pasted ? 0 : 450;
        pasted = false;
        if (v && v === lastOkNo) { setNoticeOk(true); return; }  // 지웠다 같은 번호로 복귀
        lastOkNo = '';
        setNoticeOk(false);
        lookTimer = setTimeout(() => lookupNotice(noticeInput.value), delay);
      });
      noticeInput.addEventListener('blur', () => lookupNotice(noticeInput.value));
    }
    const srcQ = q.get('src'); const srcEl = $('[data-field-src]'); if (srcEl && srcQ) srcEl.value = srcQ;
    const noticeQ = q.get('notice'); if (noticeInput && noticeQ) { noticeInput.value = noticeQ; lookupNotice(noticeQ); }

    $('[data-next="1"]').addEventListener('click', () => {
      const e1 = stepErr(1);
      if (!noticeInput.value.trim()) { if (e1) e1.hidden = false; noticeInput.focus(); return; }
      if (e1) e1.hidden = true; showStep(2);
    });

    // ── STEP 2: 신원 + 동의 + Turnstile → draft 생성 ──
    const brnValid = (raw) => {
      const d = (raw || '').replace(/\D/g, '');
      if (d.length !== 10) return false;
      const w = [1, 3, 7, 1, 3, 7, 1, 3, 5]; let sum = 0;
      for (let i = 0; i < 9; i++) sum += Number(d[i]) * w[i];
      sum += Math.floor((Number(d[8]) * 5) / 10);
      return (10 - (sum % 10)) % 10 === Number(d[9]);
    };
    const brnInput = $('[data-brn]'), brnErr = $('[data-brn-error]');
    // 고객은 숫자만 입력해도 화면엔 사업자번호 형식(3-2-5)의 하이픈이 붙는다.
    // 서버는 _normalize_brn으로 숫자만 추출하므로 하이픈이 있어도 무방하다.
    const formatBrn = (v) => { const d = (v || '').replace(/\D/g, '').slice(0, 10); return [d.slice(0, 3), d.slice(3, 5), d.slice(5, 10)].filter(Boolean).join('-'); };
    if (brnInput) {
      // 숫자만 입력 강제: 한 글자 타이핑에서 숫자가 아니면 원천 차단(깜빡임 방지).
      // 붙여넣기는 막지 않고 input 단계에서 숫자만 걸러낸다(하이픈 포함 값도 허용).
      brnInput.addEventListener('beforeinput', (e) => { if (e.inputType === 'insertText' && e.data && /\D/.test(e.data)) e.preventDefault(); });
      brnInput.addEventListener('input', () => { brnInput.value = formatBrn(brnInput.value); });
    }
    // 전화번호도 숫자만: 타이핑은 원천 차단, 붙여넣기는 숫자만 남긴다.
    const phoneInput = form.querySelector('[data-phone]');
    if (phoneInput) {
      phoneInput.addEventListener('beforeinput', (e) => { if (e.inputType === 'insertText' && e.data && /\D/.test(e.data)) e.preventDefault(); });
      phoneInput.addEventListener('input', () => { phoneInput.value = phoneInput.value.replace(/\D/g, ''); });
    }
    if (brnInput) brnInput.addEventListener('blur', () => { if (brnErr) brnErr.hidden = brnValid(brnInput.value) || !brnInput.value; });

    // 필수 신원정보·동의·Turnstile이 온전할 때만 '다음'을 활성화한다.
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
    const consent = $('[data-consent]'), next2 = $('[data-next="2"]');
    const fld = (n) => (form.querySelector('[name="' + n + '"]') || {}).value || '';
    function validStep2() {
      if (!fld('company').trim() || !fld('person').trim() || !fld('phone').trim()) return false;
      if (!emailRe.test(fld('email').trim())) return false;
      if (!brnValid(fld('brn'))) return false;
      if (!consent || !consent.checked) return false;
      if (form.dataset.turnstile && !resuming) { const t = form.querySelector('[name="cf-turnstile-response"]'); if (!t || !t.value) return false; }
      return true;
    }
    function refreshStep2() { if (next2) next2.disabled = !validStep2(); }
    const step2fs = form.querySelector('[data-step="2"]');
    if (step2fs) { step2fs.addEventListener('input', refreshStep2); step2fs.addEventListener('change', refreshStep2); }
    // Turnstile은 input 이벤트를 쏘지 않으므로 콜백으로 재평가한다.
    window.onTurnstile = refreshStep2;
    window.offTurnstile = refreshStep2;

    // ── 로그인 고객: 내 정보로 채우기(회사 1개면 step2 진입 시 자동, 여러 개면 선택) ──
    const profileEndpoint = form.getAttribute('data-profile-endpoint');
    const fillWrap = $('[data-fill]'), fillSel = $('[data-fill-select]'), fillBtn = $('[data-fill-btn]'), fillNote = $('[data-fill-note]'), fillClear = $('[data-fill-clear]');
    let profileCompanies = [], profileEmail = '', autoFilled = false;
    const setVal = (n, v) => { const el = form.querySelector('[name="' + n + '"]'); if (el) el.value = v || ''; };
    function fillFromCompany(co) {
      if (!co) return;
      setVal('company', co.name);
      if (brnInput) brnInput.value = formatBrn(co.brn);
      setVal('person', co.person);
      if (phoneInput) phoneInput.value = String(co.tel || '').replace(/\D/g, '');
      setVal('email', profileEmail);
      if (brnErr) brnErr.hidden = true;
      if (fillNote) fillNote.hidden = false;
      refreshStep2();
    }
    function clearFill() {
      ['company', 'person', 'phone', 'email'].forEach((n) => setVal(n, ''));
      if (brnInput) brnInput.value = '';
      if (fillNote) fillNote.hidden = true;
      refreshStep2();
    }
    function autoFillStep2() {
      if (resuming || autoFilled) return;              // 재개 중엔 draft 값 유지, 자동채움은 한 번만
      if (profileCompanies.length === 1) { autoFilled = true; fillFromCompany(profileCompanies[0]); }
    }
    if (fillClear) fillClear.addEventListener('click', clearFill);
    if (fillBtn) fillBtn.addEventListener('click', () => {
      const idx = (fillSel && !fillSel.hidden) ? Number(fillSel.value) : 0;
      fillFromCompany(profileCompanies[idx] || profileCompanies[0]);
    });
    if (fillSel) fillSel.addEventListener('change', () => fillFromCompany(profileCompanies[Number(fillSel.value)] || profileCompanies[0]));
    async function loadProfile() {
      const sess = localStorage.getItem('miriboa_session');
      if (!sess || !profileEndpoint) return;
      try {
        const res = await fetch(profileEndpoint, { headers: { Authorization: 'Bearer ' + sess } });
        const d = await res.json().catch(() => null);
        if (!d || !d.ok || !Array.isArray(d.companies) || !d.companies.length) return;
        profileCompanies = d.companies; profileEmail = d.email || '';
        if (fillWrap) fillWrap.hidden = false;
        if (profileCompanies.length > 1 && fillSel) {
          fillSel.innerHTML = '';
          profileCompanies.forEach((co, i) => {
            const opt = document.createElement('option');
            opt.value = String(i);
            opt.textContent = (co.name || '') + ' · ' + formatBrn(co.brn);
            fillSel.appendChild(opt);
          });
          fillSel.hidden = false;
        }
        if (cur === 2) autoFillStep2();               // 이미 step2에 있으면 지금 채운다
      } catch (e) {}
    }
    loadProfile();

    $('[data-back="2"]').addEventListener('click', () => showStep(1));

    $('[data-next="2"]').addEventListener('click', async () => {
      const e2 = stepErr(2), verr = $('[data-verify-error]'), cerr = brnErr;
      if (e2) e2.hidden = true;
      if (!validStep2()) { refreshStep2(); return; }   // 버튼이 활성일 때만 도달하나 방어적으로 확인
      if (cerr) cerr.hidden = true; if (verr) verr.hidden = true;
      // 재개 중이면 새로 만들지 않고 기존 draft를 갱신한 뒤 서류 단계로.
      if (resuming && token) {
        const rb = form.querySelector('[data-next="2"]'); const rlbl = rb.innerHTML;
        rb.disabled = true; rb.textContent = '…';
        const ufd = new FormData();
        ['notice', 'notice_name', 'deadline', 'institution', 'stakes', 'company', 'brn', 'person', 'phone', 'email', 'note'].forEach((n) => {
          const f = form.querySelector('[name="' + n + '"]'); if (f) ufd.append(n, f.value);
        });
        const us = localStorage.getItem('miriboa_session');
        try {
          const ur = await fetch(manageBase + '/' + encodeURIComponent(token) + '/draft', { method: 'POST', body: ufd, headers: us ? { Authorization: 'Bearer ' + us } : {} });
          const ud = await ur.json().catch(() => null);
          if (ur.ok && ud && ud.ok && ud.verified) showStep(3);
          else if (ur.ok && ud && ud.ok && !ud.verified) { resuming = false; showCheckEmail(); }   // 이메일 바뀜(세션≠) → 재확인, 이 draft는 새 이메일 소유
          else if (ur.status === 422 && ud && ud.error === 'invalid_brn') { if (cerr) cerr.hidden = false; brnInput.focus(); }
          else if (e2) e2.hidden = false;
        } catch { if (e2) e2.hidden = false; }
        rb.disabled = false; rb.innerHTML = rlbl; refreshStep2();
        return;
      }
      const el = $('[data-elapsed]'); if (el) el.value = String(Date.now() - loadedAt);
      const btn = form.querySelector('[data-next="2"]'); const lbl = btn.innerHTML;
      btn.disabled = true; btn.textContent = '…';
      // draft로 보낼 필드만 추린 FormData
      const fd = new FormData();
      ['notice', 'notice_name', 'deadline', 'institution', 'stakes', 'src',
       'company', 'brn', 'person', 'phone', 'email', 'note', 'company_url', 'elapsed',
       'cf-turnstile-response'].forEach((n) => {
        const f = form.querySelector('[name="' + n + '"]'); if (f) fd.append(n, f.value);
      });
      // 로그인 세션이 있으면 실어 보낸다 — 세션 이메일이 입력 이메일과 같으면 서버가
      // 바로 진행(verified), 아니면 확인 메일을 보내고 token을 감춘다.
      const sess = localStorage.getItem('miriboa_session');
      try {
        const res = await fetch(draftEndpoint, { method: 'POST', body: fd, headers: sess ? { Authorization: 'Bearer ' + sess } : {} });
        const d = await res.json().catch(() => null);
        if (res.ok && d && d.ok && d.verified && d.token) { token = d.token; showStep(3); }
        else if (res.ok && d && d.ok && !d.verified) { showCheckEmail(); }   // 미인증 → 이메일 확인
        else if (res.status === 422 && d && d.error === 'invalid_brn') { if (cerr) cerr.hidden = false; brnInput.focus(); }
        else if (res.status === 403 && verr) { verr.hidden = false; }
        else if (e2) { e2.hidden = false; }
      } catch { if (e2) e2.hidden = false; }
      btn.innerHTML = lbl;
      const ts = window.turnstile; if (ts) ts.reset();   // 토큰 소거 → refreshStep2가 다시 비활성화
      refreshStep2();
    });

    // ── STEP 3: 문서 드롭존 + precheck ──
    const docInput = $('[data-docs-input]'), drop = $('[data-drop]'), filelist = $('[data-filelist]'), docChecking = $('[data-docs-checking]');
    const next3 = $('[data-next="3"]'), submitBtn = $('[data-submit]'), ndaCheck = $('[data-nda]');
    // step3: 응찰서류가 하나라도 올라와야 '다음'을 활성화한다.
    function refreshStep3() { if (next3) next3.disabled = !((docInput && docInput.files && docInput.files.length) || resumeHasDocs); }
    // step4: NDA(기밀유지)에 동의해야 '신청 완료'를 활성화한다.
    function refreshStep4() { if (submitBtn) submitBtn.disabled = !(ndaCheck && ndaCheck.checked); }
    if (ndaCheck) ndaCheck.addEventListener('change', refreshStep4);
    // NDA 전문은 페이지 이동 없이 모달로 확인한다.
    const ndaModal = document.querySelector('[data-nda-modal]');
    const openNda = () => { if (ndaModal && ndaModal.showModal) ndaModal.showModal(); };
    const closeNda = () => { if (ndaModal && ndaModal.close) ndaModal.close(); };
    const ndaOpenBtn = $('[data-nda-open]');
    if (ndaOpenBtn) ndaOpenBtn.addEventListener('click', openNda);
    if (ndaModal) {
      const cb = ndaModal.querySelector('[data-nda-close]'); if (cb) cb.addEventListener('click', closeNda);
      const ab = ndaModal.querySelector('[data-nda-agree]');
      if (ab) ab.addEventListener('click', () => { if (ndaCheck) { ndaCheck.checked = true; refreshStep4(); } closeNda(); });
      ndaModal.addEventListener('click', (e) => { if (e.target === ndaModal) closeNda(); });   // 백드롭 클릭 닫기
    }
    // 여러 번에 나눠 넣어도 쌓인다(FileList는 불변이라 배열로 관리). 같은 이름은 최신으로 교체.
    let docFiles = [], statusByName = {};
    const MAXF = 20, MAXB = 40 * 1024 * 1024;
    function syncInput() {
      const dt = new DataTransfer(); docFiles.forEach((f) => dt.items.add(f));
      if (docInput) docInput.files = dt.files;
    }
    // 읽히면 배지를 달지 않는다(못 읽는 경우 — 스캔의심·파싱실패·미지원 — 만 표시).
    function badgeFor(name) {
      const st = statusByName[name];
      if (!st || st.status === 'ok') return '';
      return '<span class="fbadge ' + st.status + '">' + esc(docBadges[st.status] || st.status) + '</span>';
    }
    function renderFiles() {
      if (!filelist) return; filelist.innerHTML = '';
      docFiles.forEach((f, i) => {
        const li = document.createElement('li');
        li.innerHTML = '<span class="fname">' + esc(f.name) + '</span>' + badgeFor(f.name) +
          '<button type="button" class="fdel" data-del="' + i + '" aria-label="' + esc(docRemove) + '" title="' + esc(docRemove) + '">&times;</button>';
        filelist.appendChild(li);
      });
    }
    function addFiles(list) {
      for (const f of list) {
        if (f.size > MAXB) continue;                                  // 개별 40MB 초과 제외
        docFiles = docFiles.filter((g) => g.name !== f.name);          // 같은 이름은 교체
        docFiles.push(f);
      }
      if (docFiles.length > MAXF) docFiles = docFiles.slice(0, MAXF);
      syncInput(); renderFiles(); refreshStep3();
      if (docFiles.length) precheckFiles();
    }
    function removeFile(i) {
      docFiles.splice(i, 1);
      syncInput(); renderFiles(); refreshStep3();
      if (docFiles.length) precheckFiles(); else if (docChecking) docChecking.hidden = true;
    }
    let pcSeq = 0;
    async function precheckFiles() {
      if (!precheckEndpoint || !docFiles.length) return; const seq = ++pcSeq;
      if (docChecking) docChecking.hidden = false;
      const fd = new FormData(); docFiles.forEach((f) => fd.append('files', f, f.name));
      try {
        const res = await fetch(precheckEndpoint, { method: 'POST', body: fd });
        const d = await res.json().catch(() => null);
        if (seq !== pcSeq) return; if (docChecking) docChecking.hidden = true;
        if (d && d.files) { statusByName = {}; d.files.forEach((r) => { statusByName[r.name] = r; }); renderFiles(); }
      } catch { if (seq === pcSeq && docChecking) docChecking.hidden = true; }
    }
    if (docInput) docInput.addEventListener('change', () => { addFiles([...docInput.files]); });
    if (filelist) filelist.addEventListener('click', (e) => {
      const b = e.target.closest('[data-del]'); if (b) removeFile(Number(b.getAttribute('data-del')));
    });
    if (drop && docInput) {
      ['dragenter', 'dragover'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.add('over'); }));
      ['dragleave', 'drop'].forEach((ev) => drop.addEventListener(ev, (e) => { e.preventDefault(); drop.classList.remove('over'); }));
      drop.addEventListener('drop', (e) => { if (e.dataTransfer) addFiles([...e.dataTransfer.files]); });
      drop.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); docInput.click(); } });
    }
    $('[data-back="3"]').addEventListener('click', () => showStep(2));
    if (next3) next3.addEventListener('click', () => { if (!(docInput && docInput.files.length)) { refreshStep3(); return; } showStep(4); });
    $('[data-back="4"]').addEventListener('click', () => showStep(3));

    // ── STEP 4 (NDA) → 확정 ──
    $('[data-submit]').addEventListener('click', async () => {
      const derr = $('[data-docs-error]'), e4 = stepErr(4), nerr = $('[data-nda-error]');
      if (e4) e4.hidden = true; if (nerr) nerr.hidden = true;
      if (!ndaCheck || !ndaCheck.checked) { if (nerr) nerr.hidden = false; refreshStep4(); return; }
      const hasNew = !!(docInput && docInput.files.length);
      if (!hasNew && !resumeHasDocs) { showStep(3); refreshStep3(); if (derr) derr.hidden = false; return; }
      if (!token) { if (e4) e4.hidden = false; return; }
      const btn = $('[data-submit]'); const lbl = btn.innerHTML; btn.disabled = true; btn.textContent = '…';
      try {
        // 1) 문서 업로드 — 새로 올린 게 있을 때만(재개 시 기존 서류가 있으면 생략)
        if (hasNew) {
          const fdDocs = new FormData();
          [...docInput.files].forEach((f) => fdDocs.append('documents', f, f.name));
          const up = await fetch(manageBase + '/' + encodeURIComponent(token) + '/documents', { method: 'POST', body: fdDocs });
          const ud = await up.json().catch(() => null);
          if (!up.ok || !ud || !ud.ok) throw new Error('upload');
        }
        // 2) 확정
        const fdFin = new FormData();
        const exp = form.querySelector('[name="express"]'); if (exp && exp.checked) fdFin.append('express', '1');
        const fin = await fetch(manageBase + '/' + encodeURIComponent(token) + '/finalize', { method: 'POST', body: fdFin });
        const fd = await fin.json().catch(() => null);
        if (fin.status === 402 && fd && fd.error === 'no_credit') {
          const nc = $('[data-no-credit]'); if (nc) nc.hidden = false;
          btn.innerHTML = lbl; btn.disabled = false; refreshStep4(); return;
        }
        if (fin.ok && fd && fd.ok) {
          const first = !!fd.first_time, paid = Number(fd.amount) > 0;
          const pf = sent.querySelector('[data-sent-first]'), pfx = sent.querySelector('[data-sent-first-express]'), pr = sent.querySelector('[data-sent-returning]');
          if (pf) pf.hidden = !(first && !paid);
          if (pfx) pfx.hidden = !(first && paid);
          if (pr) pr.hidden = first;
          const sm = sent.querySelector('[data-sent-manage]'), smLink = sent.querySelector('[data-sent-manage-link]');
          if (sm && smLink) { smLink.setAttribute('href', managePath + '?t=' + encodeURIComponent(token)); sm.hidden = false; }
          form.hidden = true; sent.hidden = false; sent.focus();
          sent.scrollIntoView({ behavior: 'smooth', block: 'center' });
          psteps.forEach((p) => { p.classList.remove('active'); p.classList.add('done'); });
          return;
        }
        throw new Error('finalize');
      } catch { if (e4) e4.hidden = false; }
      btn.innerHTML = lbl; refreshStep4();
    });
  }
</script>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  [hidden] { display: none !important; }
  .copy { display: flex; flex-direction: column; gap: 1.25rem; max-width: 46ch; }
  .price { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 1.1rem 1.25rem; background: var(--color-mist); display: flex; flex-direction: column; gap: 0.6rem; }
  .price .ph { color: var(--color-slate); }
  .price ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.5rem; }
  .price li { font-size: var(--step-0); color: var(--color-ink); }
  .price li.free { display: flex; flex-direction: column; gap: 0.15rem; }
  .price li.free span { font-size: var(--step--1); color: var(--color-slate); }
  .price .refund { font-size: var(--step--1); color: var(--color-slate); margin: 0; }
  .alt { color: var(--color-slate); margin: 0; }
  .alt a { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }

  .progress { list-style: none; margin: 0 0 1rem; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .pstep { display: flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .pstep .pnum { display: grid; place-items: center; width: 1.5rem; height: 1.5rem; border-radius: 999px; border: 1px solid var(--hairline); font-size: var(--step--1); }
  .pstep.active { color: var(--color-ink); }
  .pstep.active .pnum { border-color: var(--color-recovered); color: var(--color-recovered); }
  .pstep.done .pnum { background: var(--color-recovered); border-color: var(--color-recovered); color: #fff; }

  .form { display: flex; flex-direction: column; gap: 1.25rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  fieldset.step { border: 0; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 1rem; }
  legend { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); padding: 0; text-transform: uppercase; letter-spacing: 0.04em; }
  label { display: flex; flex-direction: column; gap: 0.4rem; }
  label > span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
