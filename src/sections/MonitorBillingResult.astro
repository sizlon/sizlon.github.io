---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Toss billing redirect landing. mode='success': the redirect carries ?authKey=
// & customerKey= (+ our token=); POST them to confirm to exchange the authKey for a
// billingKey and charge month 1. mode='fail': no charge was made — offer retry.

interface Props { lang: Lang; mode: 'success' | 'fail' }
const { lang, mode } = Astro.props;
const tr = t(lang);
const c = tr.monitor.subscribe;
const confirmEndpoint = site.billingConfirmEndpoint;
const profilePath = localizePath('/monitor/profile', lang);
const subscribePath = localizePath('/monitor/subscribe', lang);
---

<Base title={mode === 'success' ? c.successTitle : c.failTitle} description={c.lede} lang={lang}>
  <section class="section wrap narrow">
    {mode === 'success' ? (
      <div class="result" data-billing-success
           data-confirm-endpoint={confirmEndpoint || undefined}
           data-profile-path={profilePath}
           data-ok-title={c.successTitle} data-ok-body={c.successBody}
           data-profile-label={c.successProfile} data-err={c.error}>
        <span class="eyebrow">{c.eyebrow}</span>
        <p class="pending" data-pending>{c.successPending}</p>
        <div class="done" hidden data-done>
          <h1 data-title></h1>
          <p data-body></p>
          <p><a class="btn btn-primary" data-profile-link href={profilePath}>{c.successProfile}</a></p>
        </div>
        <p class="verr" hidden data-error>{c.error}</p>
      </div>
    ) : (
      <div class="result">
        <span class="eyebrow">{c.eyebrow}</span>
        <h1>{c.failTitle}</h1>
        <p>{c.failBody}</p>
        <p><a class="btn btn-primary" data-retry href={subscribePath}>{c.retry} <span class="arrow">&rarr;</span></a></p>
      </div>
    )}
  </section>
</Base>

<script>
  const root = document.querySelector<HTMLElement>('[data-billing-success]');
  if (root) {
    const q = new URLSearchParams(location.search);
    const token = q.get('token') || '';
    const authKey = q.get('authKey') || '';
    const customerKey = q.get('customerKey') || '';
    const endpoint = root.dataset.confirmEndpoint || '';
    const done = (ok: boolean) => {
      const pending = root.querySelector<HTMLElement>('[data-pending]');
      if (pending) pending.hidden = true;
      root.querySelector<HTMLElement>(ok ? '[data-done]' : '[data-error]')!.hidden = false;
    };
    (async () => {
      if (!token || !authKey || !customerKey || !endpoint) { done(false); return; }
      try {
        const fd = new FormData();
        fd.append('token', token); fd.append('authKey', authKey); fd.append('customerKey', customerKey);
        const res = await fetch(endpoint, { method: 'POST', body: fd });
        const data = await res.json().catch(() => null);
        if (res.ok && data && data.ok) {
          const title = root.querySelector<HTMLElement>('[data-title]');
          const body = root.querySelector<HTMLElement>('[data-body]');
          const link = root.querySelector<HTMLAnchorElement>('[data-profile-link]');
          if (title) title.textContent = root.dataset.okTitle || '';
          if (body) body.textContent = root.dataset.okBody || '';
          if (link) link.href = `${root.dataset.profilePath}?token=${encodeURIComponent(token)}`;
          done(true);
        } else { done(false); }
      } catch { done(false); }
    })();
  }
</script>

<style>
  .narrow { max-width: 52ch; }
  [hidden] { display: none !important; }
  .result { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .pending { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .done { display: flex; flex-direction: column; gap: 1rem; align-items: flex-start; }
  .verr { color: #b3261e; font-size: var(--step--1); }
</style>
