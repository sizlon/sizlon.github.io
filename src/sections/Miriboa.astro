---
import Base from '../layouts/Base.astro';
import JumpNav from '../components/JumpNav.astro';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.miriboa;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
    <div class="cta-row">
      <a class="btn btn-primary" href={`${localizePath('/contact', lang)}?topic=pilot`}>{c.ctaPrimary} <span class="arrow">&rarr;</span></a>
    </div>
    <JumpNav items={c.jump} label={c.jumpLabel} />
  </section>

  <section class="section wrap market" id="problem">
    <div class="market-copy">
      <span class="eyebrow">{c.marketEyebrow}</span>
      <h2>{c.marketH2}</h2>
      <p class="lede">{c.marketLede}</p>
    </div>
    <div class="market-figures">
      <dl class="stats">
        {c.marketStats.map((s) => (
          <div class="stat">
            <dt>{s.value}</dt>
            <dd>{s.label}</dd>
          </div>
        ))}
      </dl>
      <p class="market-note">{c.marketNote}</p>
    </div>
  </section>

  <section class="section wrap" id="capabilities">
    <ul class="caps">
      {c.caps.map((cap) => (
        <li class="cap">
          <h3>{cap.name}</h3>
          <p>{cap.text}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="section wrap flow" id="flow">
    <div class="flow-copy">
      <span class="eyebrow">{c.flowEyebrow}</span>
      <h2>{c.flowH2}</h2>
      <p class="lede">{c.flowLede}</p>
    </div>
    <ol class="steps">
      {c.steps.map((step, i) => (
        <li class="step">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{step.name}</h3>
            <p>{step.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="section wrap proof">
    <div class="proof-copy">
      <span class="eyebrow">{c.proofEyebrow}</span>
      <p class="lede">{c.proofLede}</p>
    </div>
    <dl class="stats">
      {c.stats.map((s) => (
        <div class="stat">
          <dt>{s.value}</dt>
          <dd>{s.label}</dd>
        </div>
      ))}
    </dl>
  </section>

  <section class="section wrap samples" id="samples">
    <div class="samples-copy">
      <span class="eyebrow">{c.samplesEyebrow}</span>
      <h2>{c.samplesH2}</h2>
      <p class="lede">{c.samplesLede}</p>
    </div>
    <ul class="sample-list">
      {c.samples.map((s) => (
        <li class="sample-card">
          <span class="sample-name">{s.name}</span>
          <span class="sample-meta">{s.meta}</span>
          <span class="sample-actions">
            {s.interactive && (
              <a class="sample-open" href={s.interactive} target="_blank" rel="noopener">{c.sampleOpen} &rarr;</a>
            )}
            <a class="sample-get" href={s.href} download>PDF &darr;</a>
          </span>
        </li>
      ))}
    </ul>
  </section>

  <section class="section wrap model">
    <span class="eyebrow">{c.modelEyebrow}</span>
    <p class="model-note">
      {c.modelNote} <a href={`${localizePath('/contact', lang)}?topic=pilot`}>{c.contactBtn} &rarr;</a>
    </p>
    <p class="model-note precheck-note">
      {c.precheckNote} <a href={localizePath('/precheck', lang)}>{c.precheckBtn} &rarr;</a>
    </p>
  </section>
</Base>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }
  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.5rem; }
  .caps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; }
  .cap { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 1.5rem; background: var(--color-mist); display: flex; flex-direction: column; gap: 0.5rem; }

  .market { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .market-copy { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .market-figures { display: flex; flex-direction: column; gap: 0.75rem; }
  .market-note { font-size: var(--step--1); color: color-mix(in srgb, var(--color-ink) 60%, var(--color-mist)); }

  .flow { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .flow-copy { display: flex; flex-direction: column; gap: 1rem; }
  .steps { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .step { display: flex; gap: 1rem; align-items: baseline; }
  .step .num { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-recovered); }
  .step h3 { margin-bottom: 0.25rem; }

  .proof { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .proof-copy { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .stats { margin: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1px; background: var(--hairline); border: 1px solid var(--hairline); border-radius: var(--radius); overflow: hidden; }
  .stat { background: var(--color-vellum); padding: 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .stat dt { font-family: var(--font-display); font-weight: 700; font-size: var(--step-2); letter-spacing: -0.02em; }
  .stat dd { margin: 0; font-size: var(--step--1); color: color-mix(in srgb, var(--color-ink) 72%, var(--color-mist)); }

  .samples { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .samples-copy { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .sample-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1rem; }
  .sample-card {
    display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap;
    border: 1px solid var(--hairline); border-radius: var(--radius); padding: 1.25rem 1.5rem;
    background: var(--color-mist);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .sample-card:hover { border-color: var(--color-recovered); transform: translateY(-2px); }
  .sample-name { font-weight: 600; }
  .sample-meta { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .sample-actions { margin-left: auto; display: flex; gap: 1.25rem; align-items: baseline; }
  .sample-open, .sample-get { font-weight: 600; font-size: var(--step--1); white-space: nowrap; text-decoration: none; }
  .sample-open { color: var(--color-recovered); }
  .sample-get { color: var(--color-slate); }
  .sample-get:hover, .sample-open:hover { text-decoration: underline; text-underline-offset: 3px; }

  .model { max-width: var(--measure); }
  .model-note { font-size: var(--step-1); }
  .model-note a { color: var(--color-ink); font-weight: 600; text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; white-space: nowrap; }

  @media (max-width: 760px) {
    .market, .flow, .proof { grid-template-columns: 1fr; }
  }
</style>
