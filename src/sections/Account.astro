---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
// Sizlon account hub. Three stacked sections:
//   1. Account   — company profile (view/edit contact) + security (password)
//   2. Miriboa   — billing summary + recent requests; full management on /manage
//   3. Crawler   — entitlement status; management in the portal
// Login/magic/SSO handled here; per-product management is delegated out.
interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.verifyManage;
const strings = {
  statusMap: c.statusMap, updatedLabel: c.updatedLabel, accountEmpty: c.accountEmpty,
  setPw: c.setPw,
  crawler: { have: c.crawlerHave, none: c.crawlerNone, noneIntro: c.crawlerNoneIntro, noneCta: c.crawlerNoneCta },
  profile: { company: c.profileCompany, brn: c.profileBrn, person: c.profilePerson, phone: c.profilePhone, email: c.profileEmail, save: c.profileSave, saved: c.profileSaved, error: c.profileError },
  billing: { free: c.billingFree, used: c.billingUsed, amtFree: c.amtFree },
  monitoring: { free: c.monitoringFree, paid: c.monitoringPaid, off: c.monitoringOff, manage: c.monitoringManage },
  credits: { chip: c.creditsChip },
  runsBadge: c.runsBadge,
};
---

<Base title={c.title} description={c.description} lang={lang}>
  <section
    class="section wrap account"
    data-auth-request={site.authRequestEndpoint}
    data-auth-verify={site.authVerifyEndpoint}
    data-auth-login={site.authLoginEndpoint}
    data-auth-logout={site.authLogoutEndpoint}
    data-auth-set-password={site.authSetPasswordEndpoint}
    data-account-requests={site.accountRequestsEndpoint}
    data-account-products={site.accountProductsEndpoint}
    data-account-profile={site.accountProfileEndpoint}
    data-account-path={localizePath('/account', lang)}
    data-home-path={localizePath('/', lang)}
    data-manage-path={localizePath('/manage', lang)}
    data-verify-path={localizePath('/verify-request', lang)}
    data-strings={JSON.stringify(strings)}
  >
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="loading" data-loading>{c.loading}</p>

    <!-- LOGIN (email + password; magic link for first-time/forgot) -->
    <div class="panel" hidden data-login>
      <p>{c.loginIntro}</p>
      <form class="loginform" data-login-form>
        <label><span>{c.loginEmail}</span>
          <input type="email" name="email" autocomplete="email" maxlength="180" required /></label>
        <label><span>{c.loginPassword}</span>
          <input type="password" name="password" autocomplete="current-password" maxlength="200" required /></label>
        <button class="btn btn-primary" type="submit">{c.loginBtn} <span class="arrow">&rarr;</span></button>
        <p class="verr" role="alert" hidden data-login-error>{c.loginError}</p>
      </form>
      <p class="alt"><button type="button" class="linkbtn" data-magic-link>{c.loginMagic}</button></p>
      <p class="ok" role="status" hidden data-login-sent>{c.loginSent}</p>
    </div>

    <!-- HUB -->
    <div class="panel hub" hidden data-account>
      <div class="acct-head">
        <span class="acct-email" data-acct-email></span>
        <button class="linkbtn" type="button" data-logout>{c.logout}</button>
      </div>

      <!-- 1. Account: company profile + security -->
      <section class="card">
        <h2>{c.sectionAccount}</h2>
        <h3 class="sub">{c.profileHeading}</h3>
        <div class="profile" data-profile></div>
        <div class="sec">
          <h3 class="sub">{c.securityHeading}</h3>
          <p class="hint" data-setpw-intro>{c.setPw.intro}</p>
          <form class="inlineform" data-setpw-form>
            <input type="password" name="password" autocomplete="new-password" minlength="8" maxlength="200" placeholder={c.setPw.new} required />
            <button class="btn btn-primary" type="submit">{c.setPw.save}</button>
          </form>
          <p class="ok" role="status" hidden data-setpw-saved>{c.setPw.saved}</p>
          <p class="verr" role="alert" hidden data-setpw-error>{c.setPw.weak}</p>
        </div>
      </section>

      <!-- 2. Miriboa: billing + recent requests -->
      <section class="card">
        <div class="cardhead"><h2>{c.miriboaHeading}</h2><span class="chip" hidden data-billing></span></div>
        <ul class="reqlist" data-reqlist></ul>
        <p class="statusnote" hidden data-account-empty>{c.accountEmpty}</p>
        <p class="monitoring" hidden data-monitoring data-subscribe-path={localizePath('/bid-monitoring/subscribe', lang)}>
          <span data-monitoring-status></span>
          <a class="alt" data-monitoring-manage href="#">{c.monitoringManage} <span class="arrow">&rarr;</span></a>
        </p>
        <div class="cardlinks">
          <a class="btn btn-primary" href={localizePath('/verify-request', lang)}>{c.newVerify} <span class="arrow">&rarr;</span></a>
          <a class="alt" href={localizePath('/bid-verification/credits', lang)}>{c.creditsBuy} <span class="arrow">&rarr;</span></a>
          <a class="alt" href={localizePath('/manage', lang)}>{c.manageLink} <span class="arrow">&rarr;</span></a>
        </div>
      </section>

      <!-- 3. Crawler Platform: entitlement status -->
      <section class="card">
        <div class="cardhead"><h2>{c.crawlerHeading}</h2><span class="chip" hidden data-crawler-status></span></div>
        <p class="hint" data-crawler-intro>{c.crawlerIntro}</p>
        <a class="btn btn-ghost cta" data-crawler-cta data-portal-href={site.portalLoginUrl} data-contact-href={localizePath('/contact', lang)} href={site.portalLoginUrl} rel="noopener">{c.crawlerPortal} <span class="arrow">&rarr;</span></a>
      </section>
    </div>

    <p class="alt">{c.altPrefix} <a href={localizePath('/contact', lang)}>{c.altQuestion}</a></p>
  </section>
</Base>

<script>
  const root = document.querySelector('.account');
  const authRequest = root && root.getAttribute('data-auth-request');
  const authVerify = root && root.getAttribute('data-auth-verify');
  const authLogin = root && root.getAttribute('data-auth-login');
  const authLogout = root && root.getAttribute('data-auth-logout');
  const authSetPassword = root && root.getAttribute('data-auth-set-password');
  const accountEndpoint = root && root.getAttribute('data-account-requests');
  const productsEndpoint = root && root.getAttribute('data-account-products');
  const profileEndpoint = root && root.getAttribute('data-account-profile');
  const accountPath = root && root.getAttribute('data-account-path') || '/account';
  const managePath = root && root.getAttribute('data-manage-path') || '/manage';
  const verifyPath = root && root.getAttribute('data-verify-path') || '/verify-request';
  // draft는 위저드에서 완료(서류·NDA·finalize), 접수건만 /manage 상세.
  const hrefFor = (r) => r.status === 'draft'
    ? (verifyPath + '?resume=' + encodeURIComponent(r.token))
    : (managePath + '?t=' + encodeURIComponent(r.token));
  let S = {};
  try { S = JSON.parse(root.getAttribute('data-strings') || '{}'); } catch { S = {}; }
  const $ = (s) => root && root.querySelector(s);
  const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
  const SKEY = 'miriboa_session';
  const q = new URLSearchParams(location.search);
  // 로그인 후 복귀 경로 (?return=/bid-verification/credits 등) — 내부 경로만 허용
  const returnTo = (() => { const r = q.get('return') || ''; return r.startsWith('/') && !r.startsWith('//') ? r : ''; })();
  const RECENT = 3;
  const bearer = () => ({ Authorization: 'Bearer ' + (localStorage.getItem(SKEY) || '') });
  const fmtWhen = (iso) => { if (!iso) return ''; return String(iso).slice(0, 16).replace('T', ' '); };
  const fmtBrn = (d) => { d = String(d || '').replace(/\D/g, ''); return d.length === 10 ? d.slice(0, 3) + '-' + d.slice(3, 5) + '-' + d.slice(5) : (d || ''); };
  const fmtAmt = (krw) => '₩' + Number(krw || 0).toLocaleString('en-US');

  const loading = $('[data-loading]'), loginP = $('[data-login]'), accountP = $('[data-account]');
  const show = (el) => { if (el) el.hidden = false; };
  const hideAll = () => { [loading, loginP, accountP].forEach((e) => { if (e) e.hidden = true; }); };

  async function boot() {
    const login = q.get('login');
    if (login) return verifyLogin(login);
    const sess = localStorage.getItem(SKEY);
    if (sess) return loadAccount(sess);
    hideAll(); show(loginP);
  }

  const loginForm = $('[data-login-form]');
  if (loginForm) loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const errEl = $('[data-login-error]'); if (errEl) errEl.hidden = true;
    const email = loginForm.querySelector('[name="email"]').value.trim();
    const password = loginForm.querySelector('[name="password"]').value;
    const btn = loginForm.querySelector('button'); btn.disabled = true;
    try {
      const fd = new FormData(); fd.append('email', email); fd.append('password', password);
      const res = await fetch(authLogin, { method: 'POST', body: fd, credentials: 'include' });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok && d.session) {
        localStorage.setItem(SKEY, d.session); try { window.dispatchEvent(new Event('miriboa-session-change')); } catch (e) {}
        if (returnTo) { location.href = returnTo; return; }
        renderHub(d.email, d.requests || [], !!d.has_password);
      } else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    btn.disabled = false;
  });

  const magicBtn = $('[data-magic-link]');
  if (magicBtn) magicBtn.addEventListener('click', async () => {
    const sentEl = $('[data-login-sent]'), errEl = $('[data-login-error]');
    if (errEl) errEl.hidden = true;
    const email = (loginForm && loginForm.querySelector('[name="email"]').value.trim()) || '';
    if (!email) { const inp = loginForm && loginForm.querySelector('[name="email"]'); if (inp) inp.focus(); return; }
    magicBtn.disabled = true;
    try {
      const fd = new FormData(); fd.append('email', email);
      const res = await fetch(authRequest, { method: 'POST', body: fd });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (sentEl) sentEl.hidden = false; if (loginForm) loginForm.hidden = true; magicBtn.hidden = true; }
      else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    magicBtn.disabled = false;
  });

  async function verifyLogin(token) {
    hideAll(); show(loading);
    try {
      const fd = new FormData(); fd.append('token', token);
      const res = await fetch(authVerify, { method: 'POST', body: fd, credentials: 'include' });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok && d.session) {
        localStorage.setItem(SKEY, d.session); try { window.dispatchEvent(new Event('miriboa-session-change')); } catch (e) {}
        if (returnTo) { location.href = returnTo; return; }
        history.replaceState(null, '', accountPath);
        renderHub(d.email, d.requests || [], !!d.has_password);
      } else { hideAll(); show(loginP); }
    } catch { hideAll(); show(loginP); }
  }

  async function loadAccount(session) {
    hideAll(); show(loading);
    try {
      const res = await fetch(accountEndpoint, { headers: { Authorization: 'Bearer ' + session } });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) renderHub(d.email, d.requests || [], !!d.has_password);
      else { localStorage.removeItem(SKEY); try { window.dispatchEvent(new Event('miriboa-session-change')); } catch (e) {} hideAll(); show(loginP); }
    } catch { hideAll(); show(loginP); }
  }

  function renderHub(email, requests, hasPassword) {
    hideAll();
    const em = $('[data-acct-email]'); if (em) em.textContent = email;
    const setpwIntro = $('[data-setpw-intro]');
    if (setpwIntro && S.setPw) setpwIntro.textContent = hasPassword ? S.setPw.intro : S.setPw.introFirst;
    renderRequests(requests.slice(0, RECENT));
    show(accountP);
    loadProfile(email);
    updateCrawler();
  }

  // ── 미리보아 최근 신청 (금액 포함) ──
  function renderRequests(requests) {
    const list = $('[data-reqlist]'), empty = $('[data-account-empty]');
    if (list) {
      list.innerHTML = '';
      requests.forEach((r) => {
        const st = (S.statusMap && S.statusMap[r.status]) || r.status;
        const title = ((r.notice_no || '') + ' ' + (r.notice_name || '')).trim() || '—';
        const when = fmtWhen(r.updated_at || r.created_at);
        let amt = '';
        if (r.status !== 'draft') {
          amt = Number(r.amount_krw) > 0 ? fmtAmt(r.amount_krw) : (S.billing && S.billing.amtFree) || '';
          amt = amt ? '<span class="rq-amt' + (Number(r.amount_krw) > 0 ? '' : ' free') + '">' + esc(amt) + '</span>' : '';
        }
        const li = document.createElement('li');
        li.innerHTML = '<a href="' + esc(hrefFor(r)) + '">'
          + '<span class="rq-main"><span class="rq-title">' + esc(title) + '</span>'
          + '<span class="rq-when">' + esc((S.updatedLabel || '') + ' ' + when) + '</span></span>'
          + '<span class="rq-meta">'
          + (r.credit_used ? '<span class="rq-runs">' + esc((S.runsBadge || '').replace('{n}', String(r.verify_count)).replace('{max}', String(r.max_verifications))) + '</span>' : '')
          + '<span class="rq-status s-' + esc(r.status) + '">' + esc(st) + '</span>' + amt + '</span>'
          + '</a>';
        list.appendChild(li);
      });
    }
    if (empty) empty.hidden = requests.length > 0;
  }

  // ── 회사 정보 (조회/수정) + 청구 요약 ──
  async function loadProfile(email) {
    if (!profileEndpoint) return;
    let d = null;
    try {
      const res = await fetch(profileEndpoint, { headers: bearer() });
      d = await res.json().catch(() => null);
    } catch { return; }
    if (!d || !d.ok) return;
    renderProfile(d.companies || [], email);
    const chip = $('[data-billing]');
    if (chip && S.billing && !chip.dataset.credits) {
      const anyFree = (d.companies || []).some((co) => !co.first_free_used);
      chip.textContent = anyFree ? S.billing.free : S.billing.used;
      chip.classList.add(anyFree ? 'free' : 'used');
      chip.hidden = false;
    }
  }

  function renderProfile(companies, email) {
    const wrap = $('[data-profile]'); if (!wrap) return;
    const p = S.profile || {};
    wrap.innerHTML = '';
    if (!companies.length) { wrap.hidden = true; return; }
    companies.forEach((co) => {
      const div = document.createElement('div');
      div.className = 'company';
      div.innerHTML =
        '<dl>'
        + '<div><dt>' + esc(p.company) + '</dt><dd>' + esc(co.name || '—') + '</dd></div>'
        + '<div><dt>' + esc(p.brn) + '</dt><dd>' + esc(fmtBrn(co.brn)) + '</dd></div>'
        + '<div><dt>' + esc(p.person) + '</dt><dd><input class="pf" data-person value="' + esc(co.person || '') + '" maxlength="80" /></dd></div>'
        + '<div><dt>' + esc(p.phone) + '</dt><dd><input class="pf" data-phone inputmode="numeric" value="' + esc(co.tel || '') + '" maxlength="20" /></dd></div>'
        + '<div><dt>' + esc(p.email) + '</dt><dd>' + esc(email) + '</dd></div>'
        + '</dl>'
        + '<div class="pfrow"><button type="button" class="btn btn-primary" data-save-profile data-brn="' + esc(co.brn) + '">' + esc(p.save) + '</button>'
        + '<span class="ok" hidden data-pf-ok>' + esc(p.saved) + '</span>'
        + '<span class="verr" hidden data-pf-err>' + esc(p.error) + '</span></div>';
      wrap.appendChild(div);
    });
    wrap.hidden = false;
  }

  const profileWrap = $('[data-profile]');
  if (profileWrap) profileWrap.addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-save-profile]'); if (!btn) return;
    const box = btn.closest('.company'); if (!box) return;
    const okEl = box.querySelector('[data-pf-ok]'), errEl = box.querySelector('[data-pf-err]');
    if (okEl) okEl.hidden = true; if (errEl) errEl.hidden = true;
    const person = (box.querySelector('[data-person]') || {}).value || '';
    const tel = ((box.querySelector('[data-phone]') || {}).value || '').replace(/\D/g, '');
    if (!person.trim()) { if (errEl) errEl.hidden = false; return; }
    btn.disabled = true;
    try {
      const fd = new FormData(); fd.append('brn', btn.getAttribute('data-brn') || ''); fd.append('person', person.trim()); fd.append('tel', tel);
      const res = await fetch(profileEndpoint, { method: 'POST', body: fd, headers: bearer() });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (okEl) okEl.hidden = false; }
      else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    btn.disabled = false;
  });

  // ── 제품 상태 (모니터링 구독 + Crawler) ──
  async function updateCrawler() {
    if (!productsEndpoint) return;
    let d = null;
    try {
      const res = await fetch(productsEndpoint, { headers: bearer() });
      d = await res.json().catch(() => null);
    } catch { return; }
    if (!d || !d.ok) return;
    // 검증 크레딧 잔액 — billing chip 을 크레딧 표시로 (크레딧 모델이 첫검증무료를 대체).
    if (d.credits && S.credits) {
      const chip = $('[data-billing]');
      if (chip) {
        chip.textContent = (S.credits.chip || '').replace('{n}', String(d.credits.balance));
        chip.classList.add('free'); chip.dataset.credits = '1'; chip.hidden = false;
      }
    }
    // 모니터링(무료 알림·자격 사전판정) 구독 상태 — 관리(해지·상태)는 구독 페이지로.
    const mon = d.monitoring, ms = S.monitoring || {};
    if (mon) {
      const wrap = $('[data-monitoring]'), stat = $('[data-monitoring-status]'), mg = $('[data-monitoring-manage]');
      const paid = mon.billingStatus === 'active' || mon.billingStatus === 'past_due';
      const txt = mon.active
        ? (paid ? (ms.paid || '').replace('{amt}', '₩' + Number(mon.amount || 0).toLocaleString()) : ms.free)
        : ms.off;
      if (stat) stat.textContent = txt || '';
      if (mg && wrap && mon.token) mg.setAttribute('href', (wrap.getAttribute('data-subscribe-path') || '') + '?token=' + encodeURIComponent(mon.token));
      else if (mg) mg.hidden = true;
      if (wrap) wrap.hidden = false;
    }
    if (!d.crawler_known) return;
    const cw = S.crawler || {};
    const badge = $('[data-crawler-status]'), intro = $('[data-crawler-intro]'), cta = $('[data-crawler-cta]');
    if (d.crawler) {
      if (badge) { badge.textContent = cw.have || ''; badge.classList.add('have'); badge.hidden = false; }
    } else {
      if (badge) { badge.textContent = cw.none || ''; badge.classList.add('none'); badge.hidden = false; }
      if (intro && cw.noneIntro) intro.textContent = cw.noneIntro;
      if (cta) {
        const contact = cta.getAttribute('data-contact-href');
        if (contact) cta.setAttribute('href', contact);
        cta.removeAttribute('rel');
        if (cw.noneCta && cta.firstChild) cta.firstChild.textContent = cw.noneCta + ' ';
      }
    }
  }

  const logoutBtn = $('[data-logout]');
  if (logoutBtn) logoutBtn.addEventListener('click', () => {
    const sess = localStorage.getItem(SKEY);
    localStorage.removeItem(SKEY); try { window.dispatchEvent(new Event('miriboa-session-change')); } catch (e) {}
    if (authLogout) { try { fetch(authLogout, { method: 'POST', credentials: 'include', headers: sess ? { Authorization: 'Bearer ' + sess } : {}, keepalive: true }); } catch (e) {} }
    // 로그아웃 후엔 홈으로 — 방금 나온 로그인 화면을 다시 보여주지 않는다.
    location.href = (root && root.getAttribute('data-home-path')) || '/';
  });

  const setpwForm = $('[data-setpw-form]');
  if (setpwForm) setpwForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const savedEl = $('[data-setpw-saved]'), errEl = $('[data-setpw-error]');
    if (savedEl) savedEl.hidden = true; if (errEl) errEl.hidden = true;
    const session = localStorage.getItem(SKEY);
    const password = setpwForm.querySelector('[name="password"]').value;
    if (!session) { location.href = accountPath; return; }
    if (password.length < 8) { if (errEl) errEl.hidden = false; return; }
    const btn = setpwForm.querySelector('button'); btn.disabled = true;
    try {
      const fd = new FormData(); fd.append('password', password);
      const res = await fetch(authSetPassword, { method: 'POST', body: fd, headers: { Authorization: 'Bearer ' + session } });
      const d = await res.json().catch(() => null);
      if (res.ok && d && d.ok) { if (savedEl) savedEl.hidden = false; setpwForm.reset(); }
      else if (errEl) errEl.hidden = false;
    } catch { if (errEl) errEl.hidden = false; }
    btn.disabled = false;
  });

  boot();
</script>

<style>
  [hidden] { display: none !important; }
  .account { max-width: 680px; display: flex; flex-direction: column; gap: 1rem; }
  .loading, .statusnote { color: var(--color-slate); }
  .statusnote { padding: 0.9rem 1.1rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .verr { color: #b3261e; font-size: var(--step--1); }
  .ok { color: var(--color-recovered); font-weight: 600; font-size: var(--step--1); }
  .panel { display: flex; flex-direction: column; gap: 1.1rem; }
  .hub { gap: 1.25rem; }
  .alt { color: var(--color-slate); margin: 0; font-size: var(--step--1); }
  .alt a, a.alt { color: var(--color-ink); text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; }

  .loginform { display: flex; flex-direction: column; gap: 0.7rem; max-width: 22rem; }
  .loginform label { display: flex; flex-direction: column; gap: 0.4rem; }
  .loginform label span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  .loginform input, .inlineform input, .profile :global(input.pf) { font-family: var(--font-body); font-size: var(--step-0); color: var(--color-ink); background: var(--color-vellum); border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.6rem 0.75rem; }
  .loginform .btn { align-self: flex-start; }

  .acct-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .acct-email { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
