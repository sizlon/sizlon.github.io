---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';
import { connectorUrl } from '../config/site';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.connector;
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="head section wrap">
    <span class="eyebrow">{c.eyebrow}</span>
    <h1>{c.h1}</h1>
    <p class="lede">{c.lede}</p>
  </section>

  <section class="section wrap add" id="add">
    <div class="add-copy">
      <span class="eyebrow">{c.addEyebrow}</span>
      <h2>{c.addH2}</h2>
      <p class="lede">{c.addLede}</p>
      <p class="add-note">{c.addNote}</p>
    </div>
    <div class="url-card">
      <code id="connector-url">{connectorUrl}</code>
      <button type="button" id="copy-url" data-copy={connectorUrl}>Copy</button>
    </div>
  </section>

  <section class="section wrap" id="tools">
    <span class="eyebrow">{c.toolsEyebrow}</span>
    <ul class="tools">
      {c.tools.map((tool) => (
        <li class="tool">
          <h3><code>{tool.name}</code></h3>
          <p>{tool.text}</p>
        </li>
      ))}
    </ul>
    <p class="privacy"><strong>{c.privacyEyebrow}</strong> — {c.privacyText}</p>
  </section>

  <section class="section wrap stages" id="stages">
    <div class="stages-copy">
      <span class="eyebrow">{c.stageEyebrow}</span>
      <h2>{c.stageH2}</h2>
      <p class="lede">{c.stageLede}</p>
      <p class="stage-cta">
        {c.ctaText} <a href={localizePath('/products/miriboa', lang)}>{c.ctaBtn} &rarr;</a>
      </p>
    </div>
    <ol class="stage-list">
      {c.stages.map((s, i) => (
        <li class="stage">
          <span class="num">{String(i + 1).padStart(2, '0')}</span>
          <div>
            <h3>{s.name} <span class="tag">{s.tag}</span></h3>
            <p>{s.text}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
</Base>

<script>
  const btn = document.getElementById('copy-url');
  if (btn) {
    const original = btn.textContent;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(btn.dataset.copy ?? '');
        btn.textContent = '✓';
        setTimeout(() => { btn.textContent = original; }, 1600);
      } catch {
        // Clipboard blocked (insecure context / permission) — select instead so
        // the user can copy manually rather than getting silence.
        const el = document.getElementById('connector-url');
        if (el) {
          const range = document.createRange();
          range.selectNodeContents(el);
          const sel = window.getSelection();
          sel?.removeAllRanges();
          sel?.addRange(range);
        }
      }
    });
  }
</script>

<style>
  .head { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); padding-bottom: 0; }

  .add { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: center; }
  .add-copy { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .add-note { font-size: var(--step--1); color: color-mix(in srgb, var(--color-ink) 60%, var(--color-mist)); }
  .url-card {
    display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
    border: 1px solid var(--hairline); border-radius: var(--radius);
    padding: 1.5rem; background: var(--color-mist);
  }
  .url-card code { font-family: var(--font-mono); font-size: var(--step-0); word-break: break-all; }
  .url-card button {
    margin-left: auto; font: inherit; font-size: var(--step--1); font-weight: 600;
    padding: 0.4rem 0.9rem; border: 1px solid var(--hairline); border-radius: var(--radius);
    background: var(--color-vellum); color: var(--color-ink); cursor: pointer;
    transition: border-color 0.15s ease;
  }
  .url-card button:hover { border-color: var(--color-recovered); }

  .tools { list-style: none; margin: 0 0 1.5rem; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.25rem; }
  .tool { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 1.5rem; background: var(--color-mist); display: flex; flex-direction: column; gap: 0.5rem; }
  .tool h3 code { font-family: var(--font-mono); font-size: var(--step--1); }
  .privacy { max-width: var(--measure); font-size: var(--step--1); color: color-mix(in srgb, var(--color-ink) 72%, var(--color-mist)); }

  .stages { display: grid; grid-template-columns: 0.9fr 1.1fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  .stages-copy { display: flex; flex-direction: column; gap: 1rem; max-width: var(--measure); }
  .stage-cta a { color: var(--color-ink); font-weight: 600; text-decoration: underline; text-decoration-color: var(--color-recovered); text-underline-offset: 3px; white-space: nowrap; }
  .stage-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 1.25rem; }
  .stage { display: flex; gap: 1rem; align-items: baseline; }
  .stage .num { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-recovered); }
  .stage h3 { margin-bottom: 0.25rem; }
  .tag { font-family: var(--font-mono); font-size: var(--step--2); font-weight: 500; color: var(--color-slate); white-space: nowrap; }

  @media (max-width: 760px) {
    .add, .stages { grid-template-columns: 1fr; }
  }
</style>
