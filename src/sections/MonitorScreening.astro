---
import Base from '../layouts/Base.astro';
import { site } from '../config/site';
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';
// Paid eligibility-screening application (account signup path). One form collects
// alert settings (email/sectors/keywords) AND the company credentials the
// screening judges against. POST to site.subscribeScreeningEndpoint creates the
// pending subscription + profile + account; the confirmation email's link
// (confirm?next=billing) verifies the email and 302s straight to checkout.
// Same defense stack as the free form: Turnstile, honeypot, min-fill timer.

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const m = tr.monitor;           // shared alert labels/sectors
const p = tr.monitor.profile;   // credential labels/hints (same as profile form)
const s = tr.monitor.screening; // this page's copy
const endpoint = site.subscribeScreeningEndpoint;
const turnstileKey = site.turnstileSiteKey;
---

<Base title={s.title} description={s.lede} lang={lang}>
  <section class="section wrap grid">
    <div class="copy">
      <span class="eyebrow">{s.eyebrow}</span>
      <h1>{s.h1}</h1>
      <p class="lede">{s.lede}</p>
    </div>

    <div class="formcol">
      <div class="beta-note" role="note">
        <strong>{tr.monitor.beta.title}</strong>
        <p>{tr.monitor.beta.body}</p>
      </div>
      <form class="form" method="post" action={endpoint || undefined}
            data-screening-form data-sending={s.sending} data-turnstile={turnstileKey ? 'on' : undefined}>

        <h2 class="formpart">{s.alertHeading}</h2>

        <label>
          <span>{m.labels.email}</span>
          <input type="email" name="email" autocomplete="email" maxlength="180" required />
        </label>

        <fieldset class="sectors">
          <legend>{m.labels.sectors}</legend>
          {m.sectorList.map((x) => (
            <label class="check">
              <input type="checkbox" name="sectors" value={x.value} />
              <span>{x.label}</span>
            </label>
          ))}
        </fieldset>

        <label>
          <span>{m.labels.keywords}</span>
          <input type="text" name="keywords" maxlength="200" />
          <small class="hint">{m.keywordsHint}</small>
        </label>

        <h2 class="formpart">{s.profileHeading}</h2>
        <p class="hint parthint">{s.profileHint}</p>

        <label>
          <span>{p.labels.region}</span>
          <input type="text" name="region" maxlength="60" />
          <small class="hint">{p.hints.region}</small>
        </label>

        <label>
          <span>{p.labels.size}</span>
          <select name="size">
            <option value="">{p.sizePlaceholder}</option>
            {p.sizeList.map((x) => <option value={x.value}>{x.label}</option>)}
          </select>
        </label>

        <label>
          <span>{p.labels.licenses}</span>
          <textarea name="licenses" rows="3" maxlength="1000"></textarea>
          <small class="hint">{p.hints.licenses}</small>
        </label>

        <label>
          <span>{p.labels.track_record}</span>
          <textarea name="track_record" rows="3" maxlength="2000"></textarea>
          <small class="hint">{p.hints.track_record}</small>
        </label>

        <label>
          <span>{p.labels.grades}</span>
          <input type="text" name="grades" maxlength="200" />
          <small class="hint">{p.hints.grades}</small>
        </label>

        <label class="check">
          <input type="checkbox" name="clean" value="1" />
          <span>{p.labels.clean}</span>
        </label>

        <div class="hp" aria-hidden="true">
          <label>Company URL<input type="text" name="company_url" tabindex="-1" autocomplete="off" /></label>
        </div>
        <input type="hidden" name="elapsed" value="" data-elapsed />

        {turnstileKey && <div class="cf-turnstile" data-sitekey={turnstileKey}></div>}
        {turnstileKey && <p class="verr" hidden data-verify-error>{m.verifyNeeded}</p>}
        <p class="verr" hidden data-need-error>{m.needSector}</p>
        <p class="verr" hidden data-send-error>{m.sendError}</p>

        <button class="btn btn-primary" type="submit">{s.submit} <span class="arrow">&rarr;</span></button>
        <p class="note eyebrow">{s.note}</p>
      </form>

      <div class="sent" hidden data-screening-sent>
        <h2>{s.sentTitle}</h2>
        <p>{s.sentBody}</p>
      </div>
    </div>
  </section>
</Base>

{turnstileKey && (
  <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
)}

<script>
  // Same contract as the free signup form: server enforces honeypot/min-fill/
  // Turnstile; this mirrors the 422 checks for UX and swaps to the sent state.
  const loadedAt = Date.now();
  const form = document.querySelector<HTMLFormElement>('[data-screening-form]');
  const sent = document.querySelector<HTMLElement>('[data-screening-sent]');
  if (form && sent) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const hp = form.querySelector<HTMLInputElement>('[name="company_url"]');
      if (hp && hp.value) return; // bot
      const endpoint = form.getAttribute('action');
      if (!endpoint) return;
      const verr = document.querySelector<HTMLElement>('[data-verify-error]');
      const nerr = document.querySelector<HTMLElement>('[data-need-error]');
      const serr = document.querySelector<HTMLElement>('[data-send-error]');
      const sectors = form.querySelectorAll<HTMLInputElement>('[name="sectors"]:checked');
      const kw = form.querySelector<HTMLInputElement>('[name="keywords"]');
      if (sectors.length === 0 && !(kw && kw.value.trim())) {
        if (nerr) nerr.hidden = false;
        return;
      }
      if (nerr) nerr.hidden = true;
      if (form.dataset.turnstile) {
        const tok = form.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
        if (!tok || !tok.value) { if (verr) verr.hidden = false; return; }
        if (verr) verr.hidden = true;
      }
      if (serr) serr.hidden = true;
      const elapsed = form.querySelector<HTMLInputElement>('[data-elapsed]');
      if (elapsed) elapsed.value = String(Date.now() - loadedAt);
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = btn ? btn.innerHTML : '';
      if (btn) { btn.disabled = true; btn.textContent = form.dataset.sending || 'Submitting…'; }
      try {
        const res = await fetch(endpoint, { method: 'POST', body: new FormData(form) });
        const data = await res.json().catch(() => null);
        if (res.ok && data && data.ok) {
          form.hidden = true;
          sent.hidden = false;
          sent.scrollIntoView({ behavior: 'smooth', block: 'center' });
          return;
        }
        if (res.status === 403 && verr) verr.hidden = false;
        else if (serr) serr.hidden = false;
      } catch {
        if (serr) serr.hidden = false;
      }
      if (btn) { btn.disabled = false; btn.innerHTML = label; }
      const ts = (window as { turnstile?: { reset: () => void } }).turnstile;
      if (ts) ts.reset();
    });
  }
</script>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1.2fr; gap: clamp(2rem, 1rem + 4vw, 4rem); align-items: start; }
  [hidden] { display: none !important; }
  .copy { display: flex; flex-direction: column; gap: 1rem; max-width: 46ch; position: sticky; top: 5rem; }
  .beta-note { border: 1px solid #9a6700; border-radius: var(--radius); background: color-mix(in srgb, #9a6700 7%, var(--color-vellum)); padding: 0.9rem 1.1rem; margin-bottom: 1rem; }
  .beta-note strong { color: #9a6700; font-size: var(--step--1); }
  .beta-note p { font-size: var(--step--1); color: var(--color-slate); margin: 0.3rem 0 0; }
  .form { display: flex; flex-direction: column; gap: 1rem; padding: 1.75rem; border: 1px solid var(--hairline); border-radius: var(--radius); background: var(--color-mist); }
  .formpart { font-family: var(--font-mono); font-size: var(--step-0); color: var(--color-ink); margin: 0.5rem 0 0; padding-top: 0.75rem; border-top: 1px solid var(--hairline); }
  .formpart:first-of-type { margin-top: 0; padding-top: 0; border-top: 0; }
  .parthint { margin-top: -0.5rem; }
  label { display: flex; flex-direction: column; gap: 0.4rem; }
  label > span { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); }
  input[type="email"], input[type="text"], textarea, select { font-family: var(--font-body); font-size: var(--step-0); color: var(--color-ink); background: var(--color-vellum); border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.7rem 0.85rem; }
  input:focus, textarea:focus, select:focus { outline: 2px solid var(--color-recovered); outline-offset: 1px; border-color: transparent; }
  .hint { font-size: var(--step--1); color: var(--color-slate); }
  fieldset.sectors { border: 1px solid var(--hairline); border-radius: var(--radius); padding: 0.9rem 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem 1rem; margin: 0; }
  fieldset.sectors legend { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); padding: 0 0.4rem; }
  label.check { flex-direction: row; align-items: center; gap: 0.5rem; }
  label.check input { width: 1.05rem; height: 1.05rem; accent-color: var(--color-recovered); }
  label.check span { font-size: var(--step-0); color: var(--color-ink); }
  .form .btn { align-self: flex-start; }
  .note { margin-top: 0.25rem; }
  .verr { color: #b3261e; font-size: var(--step--1); }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .sent { padding: 1.75rem; border: 1px solid var(--color-recovered); border-radius: var(--radius); background: var(--color-mist); display: flex; flex-direction: column; gap: 0.6rem; }
  .sent h2 { font-size: var(--step-1); }
  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } .copy { position: static; } fieldset.sectors { grid-template-columns: 1fr; } }
</style>
