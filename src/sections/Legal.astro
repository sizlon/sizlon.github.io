---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';

interface Props { lang: Lang; doc: 'terms' | 'privacy' | 'licenses' }
const { lang, doc } = Astro.props;
const tr = t(lang);
const c = tr.legal[doc];
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="section wrap legal">
    <span class="eyebrow">{tr.footer.legal}</span>
    <h1>{c.title}</h1>
    <p class="lede">{c.lede}</p>
    <p class="meta">{tr.legal.updatedLabel}: {tr.legal.updated}</p>

    {c.sections.map((s) => (
      <div class="block">
        <h2>{s.h}</h2>
        {s.p.map((para) => <p>{para}</p>)}
      </div>
    ))}
  </section>
</Base>

<style>
  .legal { max-width: var(--measure); display: flex; flex-direction: column; gap: 1rem; }
  .meta { font-family: var(--font-mono); font-size: var(--step--1); color: var(--color-slate); margin-top: -0.25rem; }
  .block { display: flex; flex-direction: column; gap: 0.6rem; margin-top: 1.25rem; }
  .block h2 { font-size: var(--step-1); }
  .block p { color: color-mix(in srgb, var(--color-ink) 82%, var(--color-vellum)); }
</style>
