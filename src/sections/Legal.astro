---
import Base from '../layouts/Base.astro';
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';

interface Props { lang: Lang; doc: 'terms' | 'privacy' | 'licenses' }
const { lang, doc } = Astro.props;
const tr = t(lang);
const c = tr.legal[doc];
---

<Base title={c.title} description={c.description} lang={lang}>
  <section class="section wrap legal">
    <span class="eyebrow">{tr.footer.legal}</span>
    <h1>{c.title}</h1>
    <p class="lede">{c.lede}</p>
    <p class="stub">{tr.legal.stub}</p>
  </section>
</Base>

<style>
  .legal { max-width: var(--measure); display: flex; flex-direction: column; gap: 1rem; }
  .stub { color: var(--color-slate); font-family: var(--font-mono); font-size: var(--step--1); }
</style>
