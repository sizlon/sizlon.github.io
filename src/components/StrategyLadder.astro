---
// Crawler Platform's concrete expression of the brand heal language: the real,
// ordered extraction strategy ladder. Cheapest stable strategy first; browser
// automation is the last resort, never the default. Order carries information,
// so the numbered rungs are justified here (a true sequence). Strategy names are
// product terms — kept in English in every locale; only notes/aria translate.
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const l = t(lang).ladder;
const rungs = [
  { n: '01', name: 'Direct API', note: l.cheapest },
  { n: '02', name: 'GraphQL' },
  { n: '03', name: 'Embedded JSON' },
  { n: '04', name: 'JSON-LD' },
  { n: '05', name: 'Static HTML' },
  { n: '06', name: 'Rendered DOM' },
  { n: '07', name: 'Browser automation', note: l.lastResort },
];
---

<ol class="ladder" aria-label={l.aria}>
  {rungs.map((r, i) => (
    <li class:list={['rung', { first: i === 0, last: i === rungs.length - 1 }]}>
      <span class="n">{r.n}</span>
      <span class="name">{r.name}</span>
      {r.note && <span class="note">{r.note}</span>}
    </li>
  ))}
</ol>

<style>
  .ladder {
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .rung {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.1rem;
    border-bottom: 1px solid var(--hairline);
  }
  .rung:last-child { border-bottom: 0; }
  .n {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--color-slate);
  }
  .name { font-weight: 600; }
  .note {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--color-slate);
  }
  /* the preferred rung reads recovered; the last resort reads as the fault tone */
  .rung.first { background: color-mix(in srgb, var(--color-recovered) 12%, var(--color-vellum)); }
  .rung.first .note { color: color-mix(in srgb, var(--color-recovered) 70%, var(--color-ink)); }
  .rung.last .note { color: var(--color-fault); }
</style>
