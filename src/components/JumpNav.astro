---
/*
 * One-line in-page anchor row for the longest pages — an eyebrow-style
 * signpost under the hero CTA, not a table of contents. Section ids are
 * language-neutral; labels come from content[lang].
 */
interface Props {
  items: readonly { id: string; label: string }[];
  label: string;
}
const { items, label } = Astro.props;
---

<nav class="jump" aria-label={label}>
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="sep" aria-hidden="true">·</span>}
      <a href={`#${item.id}`}>{item.label}</a>
    </>
  ))}
</nav>

<style>
  .jump {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.75rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    margin-top: 0.75rem;
  }
  .jump a {
    color: var(--color-slate);
    text-decoration: none;
  }
  .jump a:hover {
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-color: var(--color-recovered);
    text-underline-offset: 3px;
  }
  .sep { color: var(--hairline); user-select: none; }
</style>
