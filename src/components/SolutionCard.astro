---
import type { Solution } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { solution: Solution; lang: Lang }
const { solution, lang } = Astro.props;
const tr = t(lang);
const statusLabel = tr.common.solutionStatus[solution.status];
const categoryLabel = tr.common.categories[solution.categoryKey];
const blurb = tr.common.solutionBlurbs[solution.slug];
const href = solution.href ? localizePath(solution.href, lang) : undefined;
const Tag = href ? 'a' : 'div';
---

<Tag class:list={['card', `is-${solution.status}`]} href={href}>
  <div class="top">
    <span class="eyebrow">{categoryLabel}</span>
    <span class="status">{statusLabel}</span>
  </div>
  <h3>{solution.name}</h3>
  <p class="blurb">{blurb}</p>
  {href && <span class="more">{tr.common.explore} <span class="arrow">&rarr;</span></span>}
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.6rem;
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    background: var(--color-mist);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  a.card:hover { border-color: var(--color-recovered); transform: translateY(-2px); }
  .top { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
  .status {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--color-slate);
  }
  .is-live .status { color: var(--color-recovered); }
  .blurb { color: color-mix(in srgb, var(--color-ink) 76%, var(--color-mist)); }
  .more {
    margin-top: 0.4rem;
    font-weight: 600;
    font-size: var(--step--1);
    color: var(--color-ink);
  }
  .more .arrow { transition: transform 0.15s ease; display: inline-block; }
  a.card:hover .more .arrow { transform: translateX(3px); }
</style>
