---
import { site, nav } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath, logicalPath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
const logical = logicalPath(Astro.url);
const homeHref = localizePath('/', lang);
---

<header class="nav band-ink">
  <div class="wrap nav-inner">
    <a class="brand" href={homeHref}>sizlon</a>

    <nav class="links" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={localizePath(item.href, lang)}
          class="link"
          aria-current={logical === item.href ? 'page' : undefined}
        >
          {tr.nav[item.key]}
        </a>
      ))}
    </nav>

    <div class="utility">
      <a class="portal" href={site.portalLoginUrl} rel="noopener">{tr.common.portalLogin} &rarr;</a>
      <span class="lang" aria-label="Language">
        <a href={localizePath(logical, 'en')} aria-current={lang === 'en' ? 'true' : undefined}>EN</a>
        <span class="sep">/</span>
        <a href={localizePath(logical, 'ko')} aria-current={lang === 'ko' ? 'true' : undefined}>KO</a>
      </span>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--hairline-dark);
    backdrop-filter: saturate(1.1);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    min-height: 64px;
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-1);
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--color-mist);
  }
  .links {
    display: flex;
    gap: 1.25rem;
    margin-inline-start: auto;
    flex-wrap: wrap;
  }
  .link {
    font-size: var(--step--1);
    text-decoration: none;
    color: var(--slate-on-dark);
    padding: 0.25rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .link:hover { color: var(--color-mist); }
  .link[aria-current='page'] {
    color: var(--color-mist);
    border-color: var(--color-recovered);
  }
  .utility {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }
  .portal {
    text-decoration: none;
    color: var(--color-recovered);
    white-space: nowrap;
  }
  .lang { color: var(--slate-on-dark); }
  .lang a { color: var(--slate-on-dark); text-decoration: none; }
  .lang a:hover { color: var(--color-mist); }
  .lang a[aria-current] { color: var(--color-mist); }
  .lang .sep { opacity: 0.5; margin: 0 0.15em; }

  @media (max-width: 720px) {
    .links { display: none; }
    .nav-inner { gap: 1rem; }
  }
</style>
