---
import { site, solutions, crawlerPages, miriboaPages, legalLinks } from '../config/site';
import type { Lang } from '../i18n/content';
import { t, localizePath } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const tr = t(lang);
---

<footer class="footer band-ink">
  <div class="wrap footer-inner">
    <div class="col brandcol">
      <a class="brand" href={localizePath('/', lang)}>
        <img src="/logo/sizlon-logo-white.svg" alt="Sizlon" width="95" height="24" />
      </a>
      <p class="tag">{tr.footer.tagline}</p>
    </div>

    <nav class="col" aria-label="Products">
      <span class="eyebrow">{tr.footer.products}</span>
      {solutions.filter((s) => s.href).map((s) => (
        <a href={localizePath(s.href!, lang)}>{s.name}</a>
      ))}
    </nav>

    <nav class="col" aria-label="Crawler Platform">
      <span class="eyebrow">{tr.footer.crawler}</span>
      {crawlerPages.map((item) => <a href={localizePath(item.href, lang)}>{tr.nav[item.key]}</a>)}
    </nav>

    <nav class="col" aria-label="Miriboa">
      <span class="eyebrow">{tr.footer.miriboa}</span>
      {miriboaPages.map((item) => <a href={localizePath(item.href, lang)}>{tr.nav[item.key]}</a>)}
    </nav>

    <nav class="col" aria-label="Legal">
      <span class="eyebrow">{tr.footer.legal}</span>
      {legalLinks.map((item) => <a href={localizePath(item.href, lang)}>{tr.legalNav[item.key]}</a>)}
    </nav>

    <div class="col">
      <span class="eyebrow">{tr.footer.getInTouch}</span>
      <a href={localizePath('/verify-request', lang)}>{tr.common.verifyDocs}</a>
      <a href={`${localizePath('/contact', lang)}?topic=demo`}>{tr.common.requestDemo}</a>
      <a href={`mailto:${site.contactEmail}`}>{site.contactEmail}</a>
    </div>
  </div>

  <div class="wrap bizinfo">
    <span>{tr.footer.business}</span>
  </div>

  <div class="wrap baseline">
    <span>&copy; {new Date().getFullYear()} Sizlon</span>
    <span class="note">{tr.footer.baseline}</span>
  </div>
</footer>

<style>
  .footer { border-top: 1px solid var(--hairline-dark); padding-top: var(--section-y); }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr 1.2fr;
    gap: 2rem;
    padding-bottom: 3rem;
  }
  .col { display: flex; flex-direction: column; gap: 0.6rem; align-items: flex-start; }
  .col a {
    text-decoration: none;
    color: var(--slate-on-dark);
    font-size: var(--step--1);
  }
  .col a:hover { color: var(--color-mist); }
  .brand { display: inline-flex; align-items: center; }
  .brand img { display: block; height: 24px; width: auto; }
  .tag { color: var(--slate-on-dark); font-size: var(--step--1); }
  .bizinfo {
    padding-top: 1.25rem;
    border-top: 1px solid var(--hairline-dark);
    font-size: var(--step--1);
    color: var(--slate-on-dark);
    line-height: 1.7;
  }
  .baseline {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    padding-block: 1rem 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--slate-on-dark);
  }
  /* 6열은 중간 폭에서 각 열이 너무 좁아진다 — 3열로 접었다가 모바일에서 2열로 */
  @media (max-width: 1080px) {
    .footer-inner { grid-template-columns: 1.6fr 1fr 1fr; }
  }
  @media (max-width: 720px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }
</style>
