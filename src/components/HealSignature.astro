---
// Brand signature: an abstract self-healing seam. A data path flows, fractures,
// re-routes to a recovered path, and a confidence reading settles. Domain-agnostic
// so it holds as solutions are added. CSS-driven; reduced-motion shows the healed
// end state. Each solution gets its own concrete expression (Crawler = the ladder).
import type { Lang } from '../i18n/content';
import { t } from '../i18n/utils';

interface Props { lang: Lang }
const { lang } = Astro.props;
const s = t(lang).signature;
---

<figure class="heal" aria-label={s.label}>
  <svg viewBox="0 0 520 300" role="img" preserveAspectRatio="xMidYMid meet">
    <!-- incoming flow -->
    <line class="trunk" x1="20" y1="96" x2="250" y2="96" />

    <!-- the rung that breaks -->
    <line class="brittle" x1="250" y1="96" x2="500" y2="96" />
    <g class="spark" transform="translate(250 96)">
      <line x1="-7" y1="-7" x2="7" y2="7" />
      <line x1="7" y1="-7" x2="-7" y2="7" />
    </g>

    <!-- re-routed, recovered path -->
    <path class="reroute" d="M250 96 C 300 96, 300 200, 360 200 L 500 200" />

    <circle class="node node-in" cx="20" cy="96" r="4" />
    <circle class="node node-out" cx="500" cy="200" r="5" />

    <!-- confidence meter -->
    <g class="meter" transform="translate(250 250)">
      <rect class="meter-track" x="0" y="0" width="250" height="8" rx="4" />
      <rect class="meter-fill" x="0" y="0" width="250" height="8" rx="4" />
    </g>
  </svg>

  <figcaption>
    <span class="eyebrow">{s.tag}</span>
    <span class="state">{s.state} <span class="conf">{s.conf}<span class="cursor" aria-hidden="true"></span></span></span>
  </figcaption>
</figure>

<style>
  .heal {
    margin: 0;
    width: 100%;
    max-width: 520px;
  }
  svg { width: 100%; height: auto; display: block; }

  line,
  path { fill: none; stroke-linecap: round; }

  /* timeline: 7s loop, sequenced by per-element delays/keyframes */
  .trunk {
    stroke: var(--slate-on-dark);
    stroke-width: 2.5;
    stroke-dasharray: 6 10;
    animation: flow 1.1s linear infinite;
  }
  .brittle {
    stroke: var(--slate-on-dark);
    stroke-width: 2.5;
    animation: brittle 7s ease-in-out infinite;
  }
  .spark {
    stroke: var(--color-fault);
    stroke-width: 2.5;
    opacity: 0;
    animation: spark 7s ease-in-out infinite;
  }
  .reroute {
    stroke: var(--color-recovered);
    stroke-width: 3;
    stroke-dasharray: 360;
    stroke-dashoffset: 360;
    animation: knit 7s ease-in-out infinite;
  }
  .node { fill: var(--slate-on-dark); }
  .node-out { animation: arrive 7s ease-in-out infinite; }

  .meter-track { fill: var(--hairline-dark); }
  .meter-fill {
    fill: var(--color-recovered);
    transform-origin: left center;
    transform: scaleX(0);
    animation: settle 7s ease-in-out infinite;
  }

  figcaption {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-top: 0.75rem;
  }
  .state {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--color-recovered);
  }
  .conf { color: var(--slate-on-dark); margin-inline-start: 0.5rem; }
  .cursor {
    display: inline-block;
    width: 0.5em;
    height: 1em;
    margin-inline-start: 0.1em;
    background: var(--color-recovered);
    vertical-align: text-bottom;
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes flow { to { stroke-dashoffset: -16; } }
  @keyframes brittle {
    0%, 18% { opacity: 1; }
    26%, 100% { opacity: 0.12; stroke: var(--color-fault); }
  }
  @keyframes spark {
    0%, 18% { opacity: 0; }
    22% { opacity: 1; }
    40%, 100% { opacity: 0; }
  }
  @keyframes knit {
    0%, 30% { stroke-dashoffset: 360; }
    62%, 100% { stroke-dashoffset: 0; }
  }
  @keyframes arrive {
    0%, 55% { fill: var(--slate-on-dark); r: 5px; }
    70%, 100% { fill: var(--color-recovered); r: 6px; }
  }
  @keyframes settle {
    0%, 58% { transform: scaleX(0); }
    84%, 100% { transform: scaleX(0.9); }
  }
  @keyframes blink { 50% { opacity: 0; } }

  @media (prefers-reduced-motion: reduce) {
    .trunk { animation: none; stroke-dasharray: none; }
    .brittle { animation: none; opacity: 0.12; }
    .spark { animation: none; opacity: 0; }
    .reroute { animation: none; stroke-dashoffset: 0; }
    .node-out { animation: none; fill: var(--color-recovered); }
    .meter-fill { animation: none; transform: scaleX(0.9); }
    .cursor { animation: none; }
  }
</style>
