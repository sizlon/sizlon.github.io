---
// Moved to the dedicated Miriboa service site (2026-07-23 split). Query-string
// preserving JS redirect — token links (?token=, ?t=) live in sent emails.
export function getStaticPaths() {
  return [''].map((s) => ({ params: { slug: s || undefined } }));
}
const { slug } = Astro.params;
const target = `https://miriboa.sizlon.io/manage${slug ? `/${slug}` : ''}`;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting…</title>
    <script is:inline define:vars={{ target }}>location.replace(target + location.search);</script>
    <meta http-equiv="refresh" content={`1;url=${target}`} />
    <link rel="canonical" href={target} />
  </head>
  <body><p>Moved: <a href={target}>{target}</a></p></body>
</html>
