#!/usr/bin/env bash
#
# Local pre-push gate for sizlon.github.io — dpurix·sizlon-platform 훅과 같은 규칙.
# 이 레포는 PUBLIC(GitHub Pages 호스팅)이라, 실수로 커밋한 시크릿은 즉시 전
# 세계 공개 + 히스토리 영구 박제가 된다. 그 한 번의 실수를 push 전에 막는다.
#
# On EVERY push (any ref, non-runtime 포함):
#   [secrets] gitleaks — full-history secret scan. 이 레포가 public이라 가장
#             중요한 게이트다. 오탐은 .gitleaksignore에 핑거프린트로 고정.
#             SKIP_GITLEAKS=1로 스킵.
#
# On a push that updates `main` (runtime 파일이 바뀐 경우만):
#   [build] astro build — Pages CI와 같은 빌드. 깨진 빌드를 push해 사이트가
#           내려가는 걸 로컬에서 먼저 잡는다. npm/node_modules 없으면 경고 후
#           스킵(보안 게이트가 아니라 편의 게이트라 블로킹하지 않는다).
#
# Non-runtime pushes: 변경 파일 전부가 *.md / docs/** / .github/workflows/** /
# .vscode/** / .editorconfig / LICENSE / .gitignore 면 빌드를 스킵한다(시크릿
# 스캔은 항상 실행). .githooks/**·.gitleaksignore는 절대 스킵 대상이 아니다.
# 신규 ref·범위 해석 불가는 풀 게이트. 강제 실행: FORCE_CHECKS=1 git push
#
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass a single push:   git push --no-verify
#
set -uo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT" || exit 1

# --- read the pushed refs once: classify + detect non-runtime pushes --------- #
ZERO=0000000000000000000000000000000000000000
NON_RUNTIME_RE='^$|\.md$|^docs/|^\.github/workflows/|^\.vscode/|^\.editorconfig$|^LICENSE$|(^|/)\.gitignore$'
push_to_main=0
non_runtime_only=1
saw_range=0
while read -r _local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main) push_to_main=1 ;;
  esac
  [ "$local_sha" = "$ZERO" ] && continue   # ref deletion — publishes nothing new
  saw_range=1
  if [ "$remote_sha" = "$ZERO" ]; then
    non_runtime_only=0                     # new ref — range unknown, run full gates
    continue
  fi
  if ! changed="$(git diff --name-only "$remote_sha".."$local_sha" 2>/dev/null)"; then
    non_runtime_only=0                     # range not resolvable locally — be safe
  elif printf '%s\n' "$changed" | grep -qvE "$NON_RUNTIME_RE"; then
    non_runtime_only=0
  fi
done
[ "$saw_range" -eq 1 ] || non_runtime_only=0

# --- every push: secret scan over the full history (never skipped by rule) --- #
if [ "${SKIP_GITLEAKS:-0}" = "1" ]; then
  echo "pre-push: [secrets] gitleaks scan skipped (SKIP_GITLEAKS=1)."
elif ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-push: [secrets] WARNING: gitleaks unavailable — skipping the secret scan." >&2
else
  echo "pre-push: [secrets] gitleaks — scanning full history for committed secrets…"
  if ! gitleaks git --no-banner --redact "$REPO_ROOT"; then
    echo "" >&2
    echo "pre-push: gitleaks found a committed secret — push blocked." >&2
    echo "          Rotate + rewrite history; confirmed false positives go in .gitleaksignore." >&2
    exit 1
  fi
fi

if [ "$non_runtime_only" -eq 1 ] && [ "${FORCE_CHECKS:-0}" != "1" ]; then
  echo "pre-push: non-runtime push (docs/workflows/editor-config only) — build skipped."
  echo "          Run it anyway with: FORCE_CHECKS=1 git push"
  exit 0
fi
if [ "$push_to_main" -eq 0 ]; then
  exit 0
fi

# --- main push with runtime changes: the Pages build (best-effort) ----------- #
if ! command -v npm >/dev/null 2>&1; then
  echo "pre-push: [build] WARNING: npm unavailable — skipping the build gate." >&2
  echo "          (fnm/nvm node may not be on the hook's PATH — that's fine; CI still builds.)" >&2
  exit 0
fi
if [ ! -d node_modules ]; then
  echo "pre-push: [build] WARNING: node_modules missing — run 'npm ci', skipping build gate." >&2
  exit 0
fi
echo "pre-push: [build] astro build — same build as Pages CI…"
if ! npm run build >/dev/null 2>&1; then
  echo "" >&2
  echo "pre-push: astro build FAILED — push blocked (would break the live site)." >&2
  echo "          Reproduce with: npm run build   |   bypass with: git push --no-verify" >&2
  exit 1
fi

echo "pre-push: all checks passed — allowing push."
exit 0
